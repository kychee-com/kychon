{
  "name": "kychon",
  "version": "0.5.12",
  "description": "AI-powered membership/community portal template for Run402",
  "type": "module",
  "workspaces": [
    "packages/sdk"
  ],
  "scripts": {
    "dev": "tsx scripts/generate-seed-sql.ts && astro dev",
    "build": "npm run build:sdk && tsx scripts/generate-seed-sql.ts && astro build && tsx scripts/generate-static-page-aliases.ts",
    "build:sdk": "npm run build --workspace @kychon/sdk",
    "preview": "astro preview",
    "generate-seed": "tsx scripts/generate-seed-sql.ts",
    "test": "npm run build:sdk && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deploy": "node deploy.js",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "npm run build:sdk && astro check && tsc --noEmit",
    "check:seeds": "tsx scripts/smoke-check-seeds.ts",
    "ui:architecture-check": "tsx scripts/ui-architecture-check.ts",
    "ui:bundle-report": "tsx scripts/ui-bundle-report.ts",
    "ui:capture-routes": "tsx scripts/ui-capture-routes.ts",
    "ui:css-collisions": "tsx scripts/ui-css-collision-report.ts",
    "check": "npm run build:sdk && npm run ui:architecture-check && tsx scripts/smoke-check-seeds.ts && vitest run && biome check . && astro check && tsc --project tsconfig.scripts.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kychee-com/kychon.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.4.10",
    "@run402/sdk": "2.27.0",
    "@tailwindcss/vite": "4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/sortablejs": "^1.15.9",
    "@vitest/coverage-v8": "^3.1.1",
    "astro": "^6.1.3",
    "fast-check": "^4.1.1",
    "happy-dom": "^20.9.0",
    "run402": "2.27.0",
    "tailwindcss": "4.2.4",
    "tsx": "4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "@astrojs/react": "5.0.4",
    "@kychon/sdk": "file:packages/sdk",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tooltip": "1.2.8",
    "@run402/astro": "2.3.0",
    "@run402/functions": "^3.2.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.14.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sonner": "2.0.7",
    "sortablejs": "1.15.7",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "ultrahtml": "1.6.0"
  },
  "overrides": {
    "yaml-language-server": "1.23.0"
  }
}
