{
  "name": "kychon",
  "version": "0.1.0",
  "description": "AI-powered membership/community portal template for Run402",
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/generate-seed-sql.ts && astro dev",
    "build": "tsx scripts/generate-seed-sql.ts && astro build",
    "preview": "astro preview",
    "generate-seed": "tsx scripts/generate-seed-sql.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deploy": "node deploy.js",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "astro check && tsc --noEmit",
    "check:seeds": "tsx scripts/smoke-check-seeds.ts",
    "check": "tsx scripts/smoke-check-seeds.ts && vitest run && biome check . && astro check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kychee-com/kychon.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@biomejs/biome": "^2.4.10",
    "@run402/sdk": "1.57.2",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^3.1.1",
    "astro": "^6.1.3",
    "fast-check": "^4.1.1",
    "happy-dom": "^17.4.4",
    "tsx": "4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
