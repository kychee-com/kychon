---
// SSR-guarded. auth.user() + Astro.redirect rather than auth.requireUser()
// (Astro catches thrown exceptions and renders 500 instead of letting the
// platform translate the AuthRequiredError into a 303). <AccountSecurity> is
// the hosted password / passkeys / sessions / identities panel — SSR-only
// (reads auth.account.getSecurity()), so it lives on this guarded page.
export const prerender = false;
import { auth } from '@run402/functions';
import { AccountSecurity } from '@run402/astro/components';
import ProfilePageApp from '../components/kychon/ProfilePageApp';
import Portal from '../layouts/Portal.astro';
import '../styles/auth-hosted.css';

const user = await auth.user();
if (!user) {
  return Astro.redirect(`/join?returnTo=${encodeURIComponent(Astro.url.pathname)}`, 303);
}
---
<Portal title="Profile">
  <div class="mx-auto w-full max-w-xl space-y-6 px-4 py-8 sm:px-6 lg:px-8">
    <ProfilePageApp client:load />
    <section class="space-y-3">
      <h2 class="text-xl font-semibold tracking-normal">Account &amp; security</h2>
      <p class="text-sm text-muted-foreground">Manage your password, passkeys, active sessions, and connected accounts.</p>
      <AccountSecurity sections={["password", "passkeys", "sessions", "identities"]} />
    </section>
  </div>
</Portal>
