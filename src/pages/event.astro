---
import Portal from '../layouts/Portal.astro';
---
<Portal title="Event">
  <div class="container" style="max-width:48rem">
    <p class="mb-2"><a href="/events.html">&larr; All Events</a></p>
    <div id="event-detail"></div>
  </div>
</Portal>

<script>
  import {
    createEventRegistrationOption,
    del,
    get,
    getEventRegistrationOptions,
    patch,
    post,
    updateEventRegistrationOption,
    updateEventTimezone,
  } from '../lib/api';
  import { getSession, isAdmin, isAuthenticated } from '../lib/auth';
  import { ready, siteConfig, translateItems } from '../lib/config';
  import { formatEventDateTime } from '../lib/event-display';
  import {
    eventTimezonePayload,
    registrationOptionPayload,
    renderRegistrationOptions,
    visibleRegistrationOptions,
  } from '../lib/event-registration';

  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = String(s || '');
    return d.innerHTML;
  }

  function showToast(message: string, type = 'info') {
    (window as any).__wl_showToast?.(message, type);
  }

  async function initEvent() {
    await ready;
    const id = new URLSearchParams(window.location.search).get('id');
    if (!id) {
      document.getElementById('event-detail')!.innerHTML = '<p>Event not found.</p>';
      return;
    }

    try {
      const events = await get(`events?id=eq.${id}&limit=1`);
      if (events.length === 0) {
        document.getElementById('event-detail')!.innerHTML = '<p>Event not found.</p>';
        return;
      }
      const event = events[0];
      await translateItems('event', [event], ['title', 'description']);

      if (event.is_members_only && !isAuthenticated()) {
        document.getElementById('event-detail')!.innerHTML = '<p>This event is for members only. Please sign in.</p>';
        return;
      }

      const rsvps = await get(`event_rsvps?event_id=eq.${id}&select=*,members(display_name,avatar_url)`);
      const registrationOptions = await getEventRegistrationOptions(Number(id)).catch(() => []);
      const goingCount = rsvps.filter((r: any) => r.status === 'going').length;
      const maybeCount = rsvps.filter((r: any) => r.status === 'maybe').length;

      const session = getSession();
      const memberId = session?.user?.member?.id;
      const myRsvp = memberId ? rsvps.find((r: any) => r.member_id === memberId) : null;

      renderEvent(event, rsvps, registrationOptions, goingCount, maybeCount, myRsvp, memberId);
    } catch (_e) {
      document.getElementById('event-detail')!.innerHTML = '<p>Error loading event.</p>';
    }
  }

  function renderEvent(
    event: any,
    rsvps: any[],
    registrationOptions: any[],
    goingCount: number,
    maybeCount: number,
    myRsvp: any,
    memberId: number | undefined,
  ) {
    const container = document.getElementById('event-detail');
    if (!container) return;

    const dateTime = formatEventDateTime(event, undefined, siteConfig, { dateStyle: 'long' });
    const visibleOptions = visibleRegistrationOptions(registrationOptions);
    const registrationHtml = renderRegistrationOptions(visibleOptions);

    const capacityPct = event.capacity ? Math.min(100, Math.round((goingCount / event.capacity) * 100)) : 0;
    const spotsLeft = event.capacity ? event.capacity - goingCount : null;
    const isFull = event.capacity && goingCount >= event.capacity;

    const admin = isAdmin();
    container.innerHTML = `
      ${event.image_url ? `<img src="${esc(event.image_url)}" alt="" style="width:100%;max-height:300px;object-fit:cover;border-radius:var(--radius);margin-bottom:1.5rem"${admin ? ` data-editable-image="events.${event.id}.image_url"` : ''}>` : ''}
      <h1${admin ? ` data-editable="events.${event.id}.title"` : ''}>${esc(event.title)}</h1>
      <p class="text-muted">${esc(dateTime.dateTimeLabel)}</p>
      ${event.location ? `<p class="text-muted"${admin ? ` data-editable="events.${event.id}.location"` : ''}>\u{1F4CD} ${esc(event.location)}</p>` : ''}
      ${event.is_members_only ? '<span class="badge badge-primary mb-1">Members Only</span>' : ''}

      <div class="mt-2">${event.description || ''}</div>

      ${registrationHtml}

      <div class="card mt-2">
        <div class="flex justify-between items-center mb-1">
          <strong>${visibleOptions.length ? 'Kychon RSVP' : `${goingCount} going${maybeCount ? `, ${maybeCount} maybe` : ''}`}</strong>
          ${event.capacity ? `<span class="text-sm text-muted">${spotsLeft} of ${event.capacity} spots left</span>` : ''}
        </div>
        ${visibleOptions.length ? `<p class="text-sm text-muted mb-1">Source registration options are listed above. Use RSVP here only for Kychon attendance tracking.</p>` : ''}
        ${event.capacity ? `<div style="height:6px;background:var(--color-border);border-radius:3px;overflow:hidden"><div style="width:${capacityPct}%;height:100%;background:var(--color-primary);border-radius:3px"></div></div>` : ''}

        ${
          memberId
            ? `
          <div class="flex gap-1 mt-2" id="rsvp-buttons">
            <button class="btn ${myRsvp?.status === 'going' ? 'btn-primary' : 'btn-secondary'} btn-sm" data-rsvp="going" ${isFull && myRsvp?.status !== 'going' ? 'disabled' : ''}>Going</button>
            <button class="btn ${myRsvp?.status === 'maybe' ? 'btn-primary' : 'btn-secondary'} btn-sm" data-rsvp="maybe">Maybe</button>
            ${myRsvp ? '<button class="btn btn-secondary btn-sm" data-rsvp="cancel">Cancel RSVP</button>' : ''}
          </div>
        `
            : '<p class="text-sm text-muted mt-1">Sign in to RSVP</p>'
        }
      </div>

      ${
        rsvps.filter((r: any) => r.status === 'going' || r.status === 'maybe').length > 0
          ? `
        <div class="mt-2">
          <h3 class="mb-1">Attendees</h3>
          ${rsvps
            .filter((r: any) => r.status !== 'cancelled')
            .map(
              (r: any) => `
            <div class="member-card">
              ${
                r.members?.avatar_url
                  ? `<img class="member-avatar" src="${esc(r.members.avatar_url)}" alt="">`
                  : `<div class="member-avatar" style="background:var(--color-primary);display:flex;align-items:center;justify-content:center;color:white;font-weight:600">${(r.members?.display_name || '?')[0].toUpperCase()}</div>`
              }
              <div class="member-info">
                <span class="member-name">${esc(r.members?.display_name || 'Member')}</span>
                <span class="badge badge-${r.status === 'going' ? 'success' : 'warning'} ml-1">${r.status}</span>
              </div>
            </div>
          `,
            )
            .join('')}
        </div>
      `
          : ''
      }

      ${
        isAdmin()
          ? `
        <div class="mt-2 flex gap-1">
          <button class="btn btn-danger btn-sm" id="event-delete">Delete Event</button>
        </div>
        <section class="card mt-2" id="event-timezone-admin">
          <h3 class="mb-1">Event Timezone</h3>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem">
            <div class="form-group">
              <label class="form-label">Source timezone</label>
              <input class="form-input" id="event-source-timezone" placeholder="Australia/Sydney" value="${esc(event.source_timezone || '')}">
            </div>
            <div class="form-group">
              <label class="form-label">Source label</label>
              <input class="form-input" id="event-source-timezone-label" placeholder="AEST / AEDT" value="${esc(event.source_timezone_label || '')}">
            </div>
            <div class="form-group">
              <label class="form-label">Display mode</label>
              <select class="form-select" id="event-time-display-mode">
                <option value="visitor"${event.time_display_mode !== 'source' ? ' selected' : ''}>Visitor local time</option>
                <option value="source"${event.time_display_mode === 'source' ? ' selected' : ''}>Source timezone</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Review state</label>
              <input class="form-input" id="event-import-review-state" placeholder="needs_review" value="${esc(event.import_review_state || '')}">
            </div>
          </div>
          <button class="btn btn-primary btn-sm" id="event-timezone-save">Save timezone</button>
        </section>
        <section class="card mt-2" id="event-registration-admin">
          <div class="flex justify-between items-center mb-1">
            <h3>Registration Options</h3>
            <button class="btn btn-secondary btn-sm" id="event-registration-add">Add option</button>
          </div>
          ${renderRegistrationAdmin(registrationOptions)}
          <button class="btn btn-primary btn-sm" id="event-registration-save">Save registration options</button>
        </section>
      `
          : ''
      }
    `;

    bindAdminEditors(event, registrationOptions);

    // RSVP handlers
    container.querySelectorAll('[data-rsvp]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const action = (btn as HTMLElement).dataset.rsvp!;
        const eventId = event.id;

        try {
          if (action === 'cancel' && myRsvp) {
            await del(`event_rsvps?id=eq.${myRsvp.id}`);
            showToast('RSVP cancelled', 'info');
          } else if (myRsvp) {
            await patch(`event_rsvps?id=eq.${myRsvp.id}`, { status: action });
            showToast(action === 'going' ? "You're going!" : 'Marked as maybe', 'success');
          } else {
            await post('event_rsvps', { event_id: eventId, member_id: memberId, status: action });
            showToast(action === 'going' ? "You're going!" : 'Marked as maybe', 'success');
          }
          if (action !== 'cancel' && memberId) {
            await post('activity_log', {
              member_id: memberId,
              action: 'rsvp',
              metadata: { event_title: event.title, event_id: eventId },
            });
          }
        } catch (_e) {
          showToast('Could not update RSVP', 'error');
        }
        await initEvent();
      });
    });

    // Delete handler
    document.getElementById('event-delete')?.addEventListener('click', async () => {
      if (!confirm('Delete this event?')) return;
      await del(`events?id=eq.${event.id}`);
      const { navigate } = await import('astro:transitions/client');
      navigate('/events.html');
    });
  }

  function renderRegistrationAdmin(options: any[]): string {
    if (!options.length) {
      return '<p class="text-sm text-muted mb-1">No structured registration options yet.</p>';
    }
    return options
      .sort((a, b) => Number(a.position || 0) - Number(b.position || 0))
      .map((option) => `
        <fieldset class="mb-1" data-registration-editor="${option.id}" style="padding:1rem;border:1px solid var(--color-border);border-radius:var(--radius)">
          <div style="display:grid;grid-template-columns:5rem 1fr 8rem 8rem;gap:0.75rem">
            <div class="form-group"><label class="form-label">Order</label><input class="form-input" data-reg-field="position" type="number" value="${esc(option.position ?? 0)}"></div>
            <div class="form-group"><label class="form-label">Label</label><input class="form-input" data-reg-field="label" value="${esc(option.label || '')}"></div>
            <div class="form-group"><label class="form-label">Amount</label><input class="form-input" data-reg-field="price_amount" type="number" step="0.01" value="${esc(option.price_amount ?? '')}"></div>
            <div class="form-group"><label class="form-label">Currency</label><input class="form-input" data-reg-field="currency" value="${esc(option.currency || '')}" placeholder="AUD"></div>
          </div>
          <div class="form-group"><label class="form-label">Raw price label</label><input class="form-input" data-reg-field="raw_price_label" value="${esc(option.raw_price_label || '')}"></div>
          <div class="form-group"><label class="form-label">Description</label><textarea class="form-textarea" data-reg-field="description" rows="2">${esc(option.description || '')}</textarea></div>
          <div style="display:grid;grid-template-columns:1fr 8rem 8rem 10rem;gap:0.75rem">
            <div class="form-group"><label class="form-label">Guest policy</label><input class="form-input" data-reg-field="guest_policy" value="${esc(option.guest_policy || '')}"></div>
            <div class="form-group"><label class="form-label">Capacity</label><input class="form-input" data-reg-field="capacity" type="number" value="${esc(option.capacity ?? '')}"></div>
            <div class="form-group"><label class="form-label">Spaces left</label><input class="form-input" data-reg-field="spaces_left" type="number" value="${esc(option.spaces_left ?? '')}"></div>
            <div class="form-group">
              <label class="form-label">Availability</label>
              <select class="form-select" data-reg-field="availability_status">
                ${['available', 'waitlist', 'full', 'closed', 'unknown'].map((status) => `<option value="${status}"${option.availability_status === status ? ' selected' : ''}>${status}</option>`).join('')}
              </select>
            </div>
          </div>
          <div class="form-group"><label class="form-label">Cancellation note</label><input class="form-input" data-reg-field="cancellation_note" value="${esc(option.cancellation_note || '')}"></div>
          <div class="form-group"><label class="form-label">Source registration URL</label><input class="form-input" data-reg-field="source_registration_url" value="${esc(option.source_registration_url || '')}"></div>
          <div class="flex gap-1">
            <label class="flex items-center gap-1"><input type="checkbox" data-reg-field="reviewed" ${option.review_state === 'reviewed' ? 'checked' : ''}> Reviewed</label>
            <label class="flex items-center gap-1"><input type="checkbox" data-reg-field="is_disabled" ${option.is_disabled ? 'checked' : ''}> Hidden/disabled</label>
          </div>
        </fieldset>
      `)
      .join('');
  }

  function collectRegistrationPayload(editor: HTMLElement): any {
    const read = (field: string) => {
      const el = editor.querySelector(`[data-reg-field="${field}"]`) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null;
      return el?.value ?? '';
    };
    const reviewed = (editor.querySelector('[data-reg-field="reviewed"]') as HTMLInputElement | null)?.checked;
    const disabled = (editor.querySelector('[data-reg-field="is_disabled"]') as HTMLInputElement | null)?.checked;
    return registrationOptionPayload({
      position: read('position'),
      label: read('label'),
      description: read('description'),
      price_amount: read('price_amount'),
      currency: read('currency'),
      raw_price_label: read('raw_price_label'),
      guest_policy: read('guest_policy'),
      capacity: read('capacity'),
      spaces_left: read('spaces_left'),
      availability_status: read('availability_status'),
      cancellation_note: read('cancellation_note'),
      source_registration_url: read('source_registration_url'),
      review_state: reviewed ? 'reviewed' : 'needs_review',
      is_disabled: disabled,
    });
  }

  function bindAdminEditors(event: any, registrationOptions: any[]) {
    if (!isAdmin()) return;

    document.getElementById('event-timezone-save')?.addEventListener('click', async () => {
      const payload = eventTimezonePayload({
        source_timezone: (document.getElementById('event-source-timezone') as HTMLInputElement | null)?.value,
        source_timezone_label: (document.getElementById('event-source-timezone-label') as HTMLInputElement | null)?.value,
        time_display_mode: (document.getElementById('event-time-display-mode') as HTMLSelectElement | null)?.value,
        import_review_state: (document.getElementById('event-import-review-state') as HTMLInputElement | null)?.value,
      });
      await updateEventTimezone(event.id, payload);
      showToast('Timezone saved', 'success');
      await initEvent();
    });

    document.getElementById('event-registration-add')?.addEventListener('click', async () => {
      await createEventRegistrationOption({
        event_id: event.id,
        position: registrationOptions.length + 1,
        label: 'New registration option',
        availability_status: 'unknown',
        review_state: 'needs_review',
      });
      showToast('Registration option added', 'success');
      await initEvent();
    });

    document.getElementById('event-registration-save')?.addEventListener('click', async () => {
      const editors = [...document.querySelectorAll<HTMLElement>('[data-registration-editor]')];
      for (const editor of editors) {
        const id = editor.dataset.registrationEditor;
        if (!id) continue;
        await updateEventRegistrationOption(Number(id), collectRegistrationPayload(editor));
      }
      showToast('Registration options saved', 'success');
      await initEvent();
    });
  }

  initEvent();
  document.addEventListener('astro:after-swap', initEvent);
  document.addEventListener('wl-locale-changed', initEvent);
  document.addEventListener('wl-auth-changed', initEvent);
</script>
