---
// Portal.astro — Main layout. The page is three zones — header, main, footer —
// where header/footer chrome is BAKED at build time from the active project's
// typed seed module, and main content is each page's own slot.
import { ClientRouter } from 'astro:transitions';
import ConfigProvider from '../components/ConfigProvider.astro';
import AuthProvider from '../components/AuthProvider.astro';
import AuthModal from '../components/AuthModal.astro';
import Toast from '../components/Toast.astro';
import AdminEditor from '../components/AdminEditor.astro';
import DemoBanner from '../components/DemoBanner.astro';

import { getActiveProjectSeed } from '../seeds';
import { renderBlock } from '../lib/blocks';
import type { BlockRenderContext, Section } from '../lib/blocks';

interface Props {
  title: string;
}

const { title } = Astro.props;

// --- Build-time bake of chrome zones ---
// Bake context: the build has no auth, so render the public + feature-on view.
// At runtime, hydrate replaces with the live DB state (which knows admin/auth).
const seed = await getActiveProjectSeed();
const featureFromSeed = (flag: string): boolean => {
  const v = (seed.site_config as Record<string, any>)[flag];
  if (v === undefined) return true; // default features visible at bake time
  if (typeof v === 'object' && v && 'value' in v) return Boolean((v as any).value);
  return Boolean(v);
};
const bakeCtx: BlockRenderContext = {
  admin: false,
  locale: 'en',
  authenticated: false,
  role: null,
  isFeatureEnabled: featureFromSeed,
  currentPath: '/',
  siteName: ((): string => {
    const v = (seed.site_config as Record<string, any>).site_name;
    if (typeof v === 'object' && v && 'value' in v) return String((v as any).value);
    return String(v ?? '');
  })(),
  logoUrl: ((): string => {
    const v = (seed.site_config as Record<string, any>).logo_url;
    if (typeof v === 'object' && v && 'value' in v) return String((v as any).value);
    return String(v ?? '');
  })(),
};

const seedAsSections = seed.sections as unknown as Section[];

const headerHtml = seedAsSections
  .filter((s) => s.zone === 'header' && s.visible !== false)
  .sort((a, b) => a.position - b.position)
  .map((s) => renderBlock(s, bakeCtx))
  .join('');

const footerHtml = seedAsSections
  .filter((s) => s.zone === 'footer' && s.visible !== false)
  .sort((a, b) => a.position - b.position)
  .map((s) => renderBlock(s, bakeCtx))
  .join('');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/nav-dropdown.css">
  <link rel="stylesheet" href="/css/a11y.css">
  <ClientRouter />
  <script is:inline>
    (function applyTheme() {
      var t = localStorage.getItem('wl_theme');
      if (!t) t = window.matchMedia('(prefers-color-scheme:dark)').matches ? 'dark' : 'light';
      if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      else document.documentElement.removeAttribute('data-theme');
    })();
    document.addEventListener('astro:after-swap', function () {
      var t = localStorage.getItem('wl_theme');
      if (!t) t = window.matchMedia('(prefers-color-scheme:dark)').matches ? 'dark' : 'light';
      if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      else document.documentElement.removeAttribute('data-theme');
    });
  </script>
  <script is:inline>
    // Set the current year for footer_copyright blocks. Idempotent across SPA navigations.
    (function setYear() {
      var y = new Date().getFullYear();
      document.querySelectorAll('[data-year="auto"]').forEach(function (el) {
        el.textContent = String(y);
      });
    })();
    document.addEventListener('astro:after-swap', function () {
      var y = new Date().getFullYear();
      document.querySelectorAll('[data-year="auto"]').forEach(function (el) {
        el.textContent = String(y);
      });
    });
  </script>
  <script is:inline src="/js/env.js"></script>
</head>
<body>
  <a href="#main-content" class="wl-skip-nav">Skip to main content</a>
  <DemoBanner />
  <div class="page">
    <nav id="zone-header" class="nav" data-zone="header" aria-label="Primary navigation" transition:persist>
      <div class="container" set:html={headerHtml}></div>
    </nav>

    <main class="page-content" id="main-content">
      <slot />
    </main>

    <footer id="zone-footer" class="footer" data-zone="footer" aria-label="Site footer" transition:persist>
      <div class="container" set:html={footerHtml}></div>
    </footer>
    <AuthModal />
  </div>

  <AuthProvider />
  <ConfigProvider />
  <Toast />
  <AdminEditor />

  <script>
    function initAnimations() {
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
        || document.documentElement.classList.contains('wl-reduced-motion');

      if (prefersReducedMotion) {
        document.querySelectorAll('.section').forEach(el => el.classList.add('section-visible'));
        new MutationObserver(mutations => mutations.forEach(m =>
          m.addedNodes.forEach(n => { if ((n as Element).classList?.contains('section')) (n as Element).classList.add('section-visible'); })
        )).observe(document.body, { childList: true, subtree: true });
        return;
      }

      let staggerIndex = 0;
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          el.style.transitionDelay = `${staggerIndex * 100}ms`;
          staggerIndex++;
          el.classList.add('section-visible');
          observer.unobserve(el);
          if (el.classList.contains('section-stats')) animateStatCounters(el);
        });
        setTimeout(() => { staggerIndex = 0; }, 50);
      }, { threshold: 0.15 });

      document.querySelectorAll('main .section').forEach(el => observer.observe(el));

      new MutationObserver((mutations) => {
        mutations.forEach((m) => {
          m.addedNodes.forEach((node) => {
            if ((node as Element).classList?.contains('section') && (node as Element).closest('main')) {
              observer.observe(node as Element);
            }
          });
        });
      }).observe(document.body, { childList: true, subtree: true });

      setTimeout(() => {
        document.querySelectorAll('main .section:not(.section-visible)').forEach(el => el.classList.add('section-visible'));
      }, 2000);
    }

    function animateStatCounters(section: Element) {
      section.querySelectorAll('.stat-value').forEach((el) => {
        const text = el.textContent?.trim() || '';
        const match = text.match(/^([^\d]*?)([\d,]+(?:\.\d+)?)(.*)$/);
        if (!match) return;
        const prefix = match[1], numStr = match[2].replace(/,/g, ''), suffix = match[3];
        const target = parseFloat(numStr);
        const isInteger = numStr.indexOf('.') === -1;
        const duration = 1500, start = performance.now();
        function frame(now: number) {
          const t = Math.min((now - start) / duration, 1);
          const eased = t >= 1 ? 1 : 1 - 2 ** (-10 * t);
          const current = eased * target;
          const formatted = isInteger
            ? Math.round(current).toLocaleString()
            : current.toFixed(numStr.split('.')[1].length).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
          el.textContent = prefix + formatted + suffix;
          if (t < 1) requestAnimationFrame(frame);
        }
        requestAnimationFrame(frame);
      });
    }

    initAnimations();
    document.addEventListener('astro:after-swap', initAnimations);
  </script>

  <script>
    import { bindNavDropdowns } from '../lib/nav-dropdown';
    function bind() { bindNavDropdowns(); }
    bind();
    document.addEventListener('astro:after-swap', bind);
    document.addEventListener('wl-content-rendered', bind);
  </script>

  <div id="wl-sr-live" class="wl-sr-live" aria-live="polite" aria-atomic="true"></div>
</body>
</html>
