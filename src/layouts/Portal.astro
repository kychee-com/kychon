---
// Portal.astro — Main layout. The page is three zones — header, main, footer —
// where header/footer chrome is BAKED at build time from the active project's
// typed seed module, and main content is each page's own slot.
import { ClientRouter } from 'astro:transitions';
import '../styles/globals.css';
import ConfigProvider from '../components/ConfigProvider.astro';
import AuthProvider from '../components/AuthProvider.astro';
import AuthModal from '../components/AuthModal.astro';
import Toast from '../components/Toast.astro';
import AdminEditor from '../components/AdminEditor.astro';
import DemoBanner from '../components/DemoBanner.astro';
import AdminBar from '../components/AdminBar.astro';
import MediaPickerHost from '../components/MediaPickerHost.astro';
import AdminZoneAddButton from '../components/kychon/AdminZoneAddButton';

import { getBuildTimeManifest } from '@run402/astro/build-manifest';

import { resolveActiveProjectSeed } from '../seeds';
import { bakeChrome } from '../lib/chrome-bake';
import { buildCspValue } from '../lib/csp';
import { isDemoModeSeed } from '../lib/demo-mode';
import { constrainedContainerClass } from '../lib/ui/container';

interface Props {
  title: string;
  robots?: string;
  /**
   * Per-page `<head>` injection point. Used by `index.astro` to splice in
   * a hero preload `<link>` derived from the bake's manifest. Trusted HTML
   * (we control all callers); rendered via `set:html` after the chrome's
   * baked head tags.
   */
  extraHead?: string;
}

const { title, robots, extraHead } = Astro.props;

// --- Build-time bake of chrome zones ---
// The bake can come from a typed seed, an external port snapshot, or a neutral
// fallback. Runtime hydrate still replaces this with live DB state.
const { seed } = await resolveActiveProjectSeed();
const chrome = bakeChrome(seed, title);
const renderDemoBanner = isDemoModeSeed(seed);

const cspValue = buildCspValue();

// --- Inline the asset manifest ---
// Inlining `window.__KYCHON_ASSET_MANIFEST` synchronously into <head> means
// every React island's first render — EventsPageApp, EventsListIsland,
// EventDetailPageApp, the slideshow carousel — sees a populated manifest
// before lookupAssetRef() ever runs. Without this, a first-visit hit
// (empty localStorage seed) raced the async /_assets-manifest.json fetch
// in page-render.ts:fetchManifest: React committed the fallback <img>,
// the manifest landed 100-300ms later, and we needed an onManifestChanged
// event listener to force the upgrade to <picture>. Inline kills the
// race at the source — the manifest is in HTML before any JS module
// even starts parsing. ~60KB raw, ~12KB gzipped per page; cost worth
// paying to drop the timing workaround.
//
// `.replace(/</g, '\\u003c')` escapes any `</script>` in the data
// (defensive — Vinyl assets shouldn't contain that, but cheap insurance).
const inlineManifest = getBuildTimeManifest();
const inlineManifestScript = inlineManifest
  ? `window.__KYCHON_ASSET_MANIFEST = ${JSON.stringify(inlineManifest).replace(/</g, '\\u003c')};`
  : '';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Content-Security-Policy" content={cspValue}>
  <meta name="referrer" content="strict-origin-when-cross-origin">
  {robots && <meta name="robots" content={robots}>}
  <title>{chrome.title}</title>
  {chrome.isSvgFavicon
    ? <link rel="icon" type="image/svg+xml" href={chrome.faviconUrl} />
    : <link rel="icon" href={chrome.faviconUrl} />}
  {chrome.cdnOrigin && (
    <link rel="preconnect" href={chrome.cdnOrigin} crossorigin />
  )}
  {extraHead && <Fragment set:html={extraHead} />}
  {chrome.fontHead && <Fragment set:html={chrome.fontHead} />}
  {chrome.customCss && <style is:inline set:html={chrome.customCss}></style>}
  <style id="wl-theme-vars" is:inline set:html={`:root { ${chrome.themeFontVarsCss} }`}></style>
  <link rel="stylesheet" href="/css/admin-editing.css">
  {inlineManifestScript && <script is:inline set:html={inlineManifestScript}></script>}
  <ClientRouter />
  <script is:inline>
    (function applyTheme() {
      var t = localStorage.getItem('wl_theme');
      if (!t) t = window.matchMedia('(prefers-color-scheme:dark)').matches ? 'dark' : 'light';
      if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      else document.documentElement.removeAttribute('data-theme');
    })();
    document.addEventListener('astro:after-swap', function () {
      var t = localStorage.getItem('wl_theme');
      if (!t) t = window.matchMedia('(prefers-color-scheme:dark)').matches ? 'dark' : 'light';
      if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      else document.documentElement.removeAttribute('data-theme');
    });
  </script>
  <script is:inline src="/js/env.js"></script>
</head>
<body>
  <a
    href="#main-content"
    class="absolute -top-full left-4 z-[1000] rounded-[var(--radius)] bg-[var(--color-primary)] px-6 py-3 text-sm font-semibold text-white no-underline transition-[top] duration-150 focus:top-3 focus:text-white"
  >Skip to main content</a>
  {renderDemoBanner && <DemoBanner />}
  <AdminBar />
  <MediaPickerHost />
  <div class="flex min-h-screen flex-col">
    <nav id="zone-header" data-nav-shell data-zone="header" aria-label="Primary navigation" transition:persist>
      <div class={constrainedContainerClass} data-layout-container set:html={chrome.headerHtml}></div>
      <AdminZoneAddButton zone="header" />
    </nav>
    <div data-fullbleed-host data-zone-fullbleed="header" transition:persist></div>

    <main class="flex-1 py-8" id="main-content">
      <slot />
    </main>

    <footer id="zone-footer" data-footer-shell data-zone="footer" aria-label="Site footer" transition:persist>
      <div class={constrainedContainerClass} data-layout-container set:html={chrome.footerHtml}></div>
      <div data-fullbleed-host></div>
      <AdminZoneAddButton zone="footer" />
    </footer>
    <AuthModal />
  </div>

  <AuthProvider />
  <ConfigProvider />
  <Toast />
  <AdminEditor />

  <script>
    import { bindNavDropdowns } from '../lib/nav-dropdown';
    function bind() { bindNavDropdowns(); }
    bind();
    document.addEventListener('astro:after-swap', bind);
    document.addEventListener('wl-content-rendered', bind);
  </script>

  <script>
    import { hydratePage, currentPageSlug } from '../lib/page-render';
    function hydrateChrome() { void hydratePage(currentPageSlug()); }
    hydrateChrome();
    document.addEventListener('astro:after-swap', hydrateChrome);
    document.addEventListener('wl-locale-changed', hydrateChrome);
    document.addEventListener('wl-auth-changed', hydrateChrome);
    document.addEventListener('wl-config-changed', hydrateChrome);
    document.addEventListener('wl-sections-changed', hydrateChrome);
  </script>

  <div id="wl-sr-live" class="sr-only" aria-live="polite" aria-atomic="true"></div>
</body>
</html>
