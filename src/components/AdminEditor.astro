---
// AdminEditor.astro — Inline editing for admins
// Loaded with client:idle — only initializes after page settles
// Supports: text, rich text (Tiptap), image upload, JSONB paths, drag reorder
---
<div id="admin-editor-root"></div>

<script>
  import { patch, get } from '../lib/api';
  import { clearCache, ready } from '../lib/config';

  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = String(s || '');
    return d.innerHTML;
  }

  function getAPI(): string {
    return window.__KYCHON_API || 'https://api.run402.com';
  }
  function getAnonKey(): string {
    return window.__KYCHON_ANON_KEY || '';
  }
  function getToken(): string {
    const session = JSON.parse(localStorage.getItem('wl_session') || '{}');
    return session.access_token || '';
  }

  // --- Admin CSS (loaded once) ---
  let cssLoaded = false;
  function loadAdminCSS() {
    if (cssLoaded) return;
    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = '/css/admin-editing.css';
    document.head.appendChild(link);
    cssLoaded = true;
  }

  // --- Toast notifications ---
  function showToast(message: string, type: 'success' | 'error' = 'success') {
    const existing = document.querySelector('.admin-toast');
    if (existing) existing.remove();
    const toast = document.createElement('div');
    toast.className = `admin-toast ${type}`;
    toast.textContent = message;
    document.body.appendChild(toast);
    setTimeout(() => {
      toast.classList.add('out');
      setTimeout(() => toast.remove(), 200);
    }, 2000);
  }

  // --- Save animation on element ---
  function flashSave(el: HTMLElement, success: boolean) {
    el.classList.remove('admin-save-success', 'admin-save-error');
    void el.offsetWidth; // force reflow
    el.classList.add(success ? 'admin-save-success' : 'admin-save-error');
    setTimeout(() => el.classList.remove('admin-save-success', 'admin-save-error'), 700);
  }

  // --- Parse data-editable attribute ---
  // Supports: "table.id.field" (flat) or "table.id.column.jsonpath" (JSONB)
  interface EditTarget {
    table: string;
    id: string;
    field: string;
    jsonPath?: string;
  }

  function parseEditTarget(attr: string): EditTarget | null {
    const parts = attr.split('.');
    if (parts.length === 3) {
      return { table: parts[0], id: parts[1], field: parts[2] };
    } else if (parts.length >= 4) {
      // Support nested paths: sections.523.config.items.0.value
      return { table: parts[0], id: parts[1], field: parts[2], jsonPath: parts.slice(3).join('.') };
    }
    return null;
  }

  // --- Nested object set: "items.0.value" → config.items[0].value = newValue ---
  function setNested(obj: any, path: string, value: any) {
    const keys = path.split('.');
    let cur = obj;
    for (let i = 0; i < keys.length - 1; i++) {
      const k = /^\d+$/.test(keys[i]) ? parseInt(keys[i]) : keys[i];
      if (cur[k] === undefined) cur[k] = /^\d+$/.test(keys[i + 1]) ? [] : {};
      cur = cur[k];
    }
    const lastKey = /^\d+$/.test(keys[keys.length - 1]) ? parseInt(keys[keys.length - 1]) : keys[keys.length - 1];
    cur[lastKey] = value;
  }

  // --- Find closest data-editable-config (on self or parent) ---
  function findConfig(el: HTMLElement): { configEl: HTMLElement; config: any } | null {
    let cur: HTMLElement | null = el;
    while (cur) {
      const attr = cur.getAttribute('data-editable-config');
      if (attr) return { configEl: cur, config: JSON.parse(attr) };
      cur = cur.parentElement;
    }
    return null;
  }

  // --- Save helper: handles flat, JSONB, nested JSONB, and site_config ---
  async function saveField(el: HTMLElement, target: EditTarget, newValue: any): Promise<boolean> {
    try {
      if (target.jsonPath) {
        // JSONB: read-modify-write with nested path support
        const found = findConfig(el);
        if (!found) {
          console.error('Missing data-editable-config for JSONB edit');
          return false;
        }
        const { configEl, config } = found;
        setNested(config, target.jsonPath, newValue);
        await patch(`${target.table}?id=eq.${target.id}`, { [target.field]: config });
        configEl.setAttribute('data-editable-config', JSON.stringify(config));
      } else if (target.table === 'site_config') {
        // site_config uses key=eq.{id} instead of id=eq.{id}
        await patch(`site_config?key=eq.${target.id}`, { value: newValue });
      } else {
        await patch(`${target.table}?id=eq.${target.id}`, { [target.field]: newValue });
      }
      if (target.table === 'site_config' || target.table === 'sections' || target.table === 'pages') {
        clearCache('wl_cache_site_config');
      }
      return true;
    } catch (e) {
      console.error('Save failed:', e);
      return false;
    }
  }

  // --- Simple text editing via contenteditable ---
  const boundText = new WeakSet();

  function initEditableText() {
    document.querySelectorAll('[data-editable]').forEach((el) => {
      if (boundText.has(el)) return;
      boundText.add(el);
      const htmlEl = el as HTMLElement;
      htmlEl.setAttribute('data-lpignore', 'true'); // prevent LastPass interference
      let original = '';

      htmlEl.addEventListener('click', (e) => {
        // Don't activate if clicking a link inside
        if ((e.target as HTMLElement).closest('a')) return;
        if (htmlEl.contentEditable === 'true') return; // already editing
        original = htmlEl.textContent?.trim() || '';
        htmlEl.contentEditable = 'true';
        htmlEl.setAttribute('data-lpignore', 'true');
        // Place cursor — first click sets contentEditable but browser already
        // processed the click on a non-editable element, so no cursor appears.
        // Fix by programmatically selecting all text so the user can type.
        requestAnimationFrame(() => {
          htmlEl.focus();
          const sel = window.getSelection();
          if (sel) {
            const range = document.createRange();
            range.selectNodeContents(htmlEl);
            sel.removeAllRanges();
            sel.addRange(range);
          }
        });
      });

      htmlEl.addEventListener('blur', async () => {
        htmlEl.contentEditable = 'false';
        const attr = htmlEl.dataset.editable!;
        const target = parseEditTarget(attr);
        if (!target) return;
        const newText = htmlEl.textContent?.trim() || '';
        if (newText === original) return; // no change
        const ok = await saveField(htmlEl, target, newText);
        flashSave(htmlEl, ok);
        if (ok) showToast('Saved');
        else showToast('Save failed', 'error');
      });

      htmlEl.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          htmlEl.blur();
        }
        if (e.key === 'Escape') {
          htmlEl.textContent = original;
          htmlEl.blur();
        }
      });
    });
  }

  // --- Rich text editing via Tiptap ---
  let tiptapLoaded = false;
  let Editor: any, StarterKit: any;

  async function loadTiptap() {
    if (tiptapLoaded) return;
    try {
      const core = await import('https://esm.sh/@tiptap/core@2');
      const starter = await import('https://esm.sh/@tiptap/starter-kit@2');
      Editor = core.Editor;
      StarterKit = starter.default || starter.StarterKit;
      tiptapLoaded = true;
    } catch (e) {
      console.error('Failed to load Tiptap:', e);
    }
  }

  const boundRich = new WeakSet();

  function initEditableRich() {
    document.querySelectorAll('[data-editable-rich]').forEach((el) => {
      if (boundRich.has(el)) return;
      boundRich.add(el);
      const htmlEl = el as HTMLElement;
      htmlEl.setAttribute('data-lpignore', 'true');
      let editor: any = null;

      htmlEl.addEventListener('click', async () => {
        if (editor) return;
        await loadTiptap();
        if (!Editor) return;
        const originalContent = htmlEl.innerHTML;
        htmlEl.classList.add('tiptap-active');
        htmlEl.setAttribute('data-lpignore', 'true');
        // Clear original content — Tiptap will render its own editable copy
        htmlEl.innerHTML = '';

        editor = new Editor({
          element: htmlEl,
          extensions: [StarterKit],
          content: originalContent,
          onBlur: async () => {
            const attr = htmlEl.dataset.editableRich!;
            const target = parseEditTarget(attr);
            if (!target) return;
            const html = editor.getHTML();
            editor.destroy();
            editor = null;
            htmlEl.classList.remove('tiptap-active');
            // Restore rendered content (either saved or original)
            htmlEl.innerHTML = html;
            const ok = await saveField(htmlEl, target, html);
            flashSave(htmlEl, ok);
            if (ok) showToast('Saved');
            else showToast('Save failed', 'error');
          },
        });
      });
    });
  }

  // --- Image editing via click-to-upload (base64 JSON) ---
  const boundImage = new WeakSet();

  function initEditableImage() {
    document.querySelectorAll('[data-editable-image]').forEach((el) => {
      if (boundImage.has(el)) return;
      boundImage.add(el);
      const htmlEl = el as HTMLElement;

      htmlEl.addEventListener('click', (e) => {
        // Don't trigger image upload if clicking a child text-editable element
        const target = e.target as HTMLElement;
        if (target.closest('[data-editable]') || target.closest('[data-editable-rich]')) return;
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = 'image/*';
        input.addEventListener('change', async () => {
          const file = input.files?.[0];
          if (!file) return;

          // Show upload state
          htmlEl.classList.add('uploading');
          const spinner = document.createElement('div');
          spinner.className = 'admin-upload-spinner';
          htmlEl.style.position = 'relative';
          htmlEl.appendChild(spinner);

          try {
            const attr = htmlEl.dataset.editableImage!;
            const target = parseEditTarget(attr);
            const storageName = `assets/${Date.now()}_${file.name}`;

            // Upload directly to Run402 storage (avoids function body size limit)
            const res = await fetch(`${getAPI()}/storage/v1/upload/${storageName}`, {
              method: 'POST',
              headers: {
                apikey: getAnonKey(),
                Authorization: `Bearer ${getToken()}`,
                'Content-Type': file.type || 'application/octet-stream',
              },
              body: file,
            });

            if (res.ok) {
              const data = await res.json();
              const url = data.url || `/storage/${storageName}`;

              // Update the image element
              const img = htmlEl.tagName === 'IMG' ? htmlEl as HTMLImageElement : htmlEl.querySelector('img');
              if (img) img.src = url;

              // Save URL to database
              if (target) {
                await saveField(htmlEl, target, url);
              }
              showToast('Image uploaded');
            } else {
              const err = await res.text();
              console.error('Upload failed:', err);
              showToast('Upload failed', 'error');
            }
          } catch (e) {
            console.error('Image upload error:', e);
            showToast('Upload failed', 'error');
          } finally {
            htmlEl.classList.remove('uploading');
            spinner.remove();
          }
        });
        input.click();
      });
    });
  }

  // --- Drag-to-reorder (document-level, supports cross-zone) ---
  // composable-layout: one document-level handler. Source zone is determined
  // from `closest('[data-zone]')`; target zone the same. Cross-zone drops PATCH
  // both `zone` and `position` together. Empty zones acquire a "Drop here"
  // placeholder via the body.admin-dragging class (CSS rule below).
  let draggedEl: HTMLElement | null = null;
  let dropIndicator: HTMLElement | null = null;
  let sourceZone: string | null = null;

  function ensureIndicator(): HTMLElement {
    if (!dropIndicator) {
      dropIndicator = document.createElement('div');
      dropIndicator.className = 'admin-drop-indicator';
    }
    // column-span-rows: indicator width tracks the dragged block's span so the
    // preview matches what'll actually land. Default to '1' when nothing is
    // being dragged or the dragged block has no span attribute.
    const span = draggedEl?.getAttribute('data-column-span') || '1';
    dropIndicator.setAttribute('data-column-span', span);
    return dropIndicator;
  }

  function findZoneContainer(el: Element | null): HTMLElement | null {
    if (!el) return null;
    return (el.closest('[data-zone]') as HTMLElement | null);
  }

  function findZoneItemHost(zone: HTMLElement): HTMLElement {
    // Header / footer: the inner .container holds blocks. Main: the #sections
    // child or the page <main> itself.
    const inner = zone.querySelector(':scope > .container') as HTMLElement | null;
    if (inner) return inner;
    const sections = zone.querySelector('#sections') as HTMLElement | null;
    if (sections) return sections;
    return zone;
  }

  function ensureDragHandle(el: HTMLElement) {
    if (el.querySelector(':scope > .admin-drag-handle')) return;
    const handle = document.createElement('div');
    handle.className = 'admin-drag-handle';
    handle.draggable = true;
    handle.addEventListener('dragstart', (e) => {
      draggedEl = el;
      const zone = findZoneContainer(el);
      sourceZone = zone?.dataset.zone || null;
      document.body.classList.add('admin-dragging');
      el.classList.add('dragging');
      e.dataTransfer!.effectAllowed = 'move';
      e.dataTransfer!.setData('text/plain', el.dataset.sortableId || '');
    });
    el.appendChild(handle);
  }

  function bindSortableHandles() {
    document.querySelectorAll<HTMLElement>('[data-sortable-id]').forEach(ensureDragHandle);
  }

  function initSortable() {
    bindSortableHandles();
    if ((document as any).__sortableDocBound) return;
    (document as any).__sortableDocBound = true;

    document.addEventListener('dragover', (e) => {
      if (!draggedEl) return;
      const target = e.target as HTMLElement | null;
      const zone = findZoneContainer(target);
      if (!zone) return;
      e.preventDefault();
      (e as DragEvent).dataTransfer!.dropEffect = 'move';

      const indicator = ensureIndicator();
      const itemHost = findZoneItemHost(zone);
      const overItem = (target?.closest('[data-sortable-id]') as HTMLElement | null);
      if (overItem && overItem !== draggedEl && itemHost.contains(overItem)) {
        const rect = overItem.getBoundingClientRect();
        const midY = rect.top + rect.height / 2;
        if ((e as DragEvent).clientY < midY) overItem.before(indicator);
        else overItem.after(indicator);
      } else if (itemHost.children.length === 0 || (itemHost.children.length === 1 && itemHost.contains(indicator))) {
        if (!itemHost.contains(indicator)) itemHost.appendChild(indicator);
      } else {
        const last = itemHost.lastElementChild as HTMLElement | null;
        if (last && last !== indicator) {
          itemHost.appendChild(indicator);
        }
      }
    });

    document.addEventListener('drop', async (e) => {
      if (!draggedEl) return;
      const targetZoneEl = findZoneContainer(e.target as HTMLElement | null);
      const indicator = dropIndicator;
      if (!targetZoneEl || !indicator || !indicator.parentElement) {
        cleanupDrag();
        return;
      }
      e.preventDefault();
      const targetZone = targetZoneEl.dataset.zone!;
      indicator.replaceWith(draggedEl);
      const moved = draggedEl;
      const wasCrossZone = sourceZone !== targetZone;
      cleanupDrag();
      await persistOrder(moved, sourceZone || 'main', targetZone);
      if (wasCrossZone) maybeOfferGlobalPromotion(moved, targetZone as 'header' | 'main' | 'footer');
    });

    document.addEventListener('dragend', cleanupDrag);
  }

  function cleanupDrag() {
    if (draggedEl) draggedEl.classList.remove('dragging');
    if (dropIndicator) dropIndicator.remove();
    document.body.classList.remove('admin-dragging');
    draggedEl = null;
    dropIndicator = null;
    sourceZone = null;
  }

  async function persistOrder(moved: HTMLElement, fromZone: string, toZone: string) {
    const targetZoneEl = findZoneContainer(moved);
    if (!targetZoneEl) return;
    const targetHost = findZoneItemHost(targetZoneEl);
    const targetSiblings = Array.from(targetHost.querySelectorAll<HTMLElement>('[data-sortable-id]'));
    const updates: Promise<any>[] = [];
    targetSiblings.forEach((sib, idx) => {
      const sid = sib.dataset.sortableId;
      if (!sid) return;
      const [table, id] = sid.split('.');
      if (!table || !id) return;
      const body: Record<string, any> = { position: idx + 1 };
      if (sib === moved && fromZone !== toZone) body.zone = toZone;
      updates.push(patch(`${table}?id=eq.${id}`, body));
    });
    // Renumber source zone too (close the gap left behind)
    if (fromZone !== toZone) {
      const sourceZoneEl = document.querySelector(`[data-zone="${fromZone}"]`) as HTMLElement | null;
      if (sourceZoneEl) {
        const sourceHost = findZoneItemHost(sourceZoneEl);
        Array.from(sourceHost.querySelectorAll<HTMLElement>('[data-sortable-id]')).forEach(
          (sib, idx) => {
            const sid = sib.dataset.sortableId;
            if (!sid) return;
            const [table, id] = sid.split('.');
            if (!table || !id) return;
            updates.push(patch(`${table}?id=eq.${id}`, { position: idx + 1 }));
          },
        );
      }
    }
    try {
      await Promise.all(updates);
      // Bust caches so subsequent navigations see the new order/zone.
      Object.keys(localStorage)
        .filter((k) => k.startsWith('wl_cache_sections_'))
        .forEach((k) => localStorage.removeItem(k));
      showToast('Order saved');
    } catch (e) {
      console.error('Failed to persist order:', e);
      showToast('Save failed', 'error');
    }
  }

  function maybeOfferGlobalPromotion(moved: HTMLElement, targetZone: 'header' | 'main' | 'footer') {
    if (targetZone !== 'header' && targetZone !== 'footer') return;
    const sid = moved.dataset.sortableId;
    if (!sid) return;
    const [table, id] = sid.split('.');
    if (table !== 'sections' || !id) return;
    // Look up scope from the row.
    get(`sections?id=eq.${id}&select=scope`).then((rows: any[]) => {
      const scope = rows[0]?.scope || 'page';
      if (scope === 'global') return;
      showPromotionTooltip(moved, parseInt(id, 10));
    }).catch(() => {});
  }

  function showPromotionTooltip(target: HTMLElement, sectionId: number) {
    document.querySelector('.admin-promotion-tooltip')?.remove();
    const tip = document.createElement('div');
    tip.className = 'admin-promotion-tooltip';
    tip.innerHTML = `
      <span>This now appears here only.</span>
      <button class="btn btn-sm btn-primary" type="button" data-make-global="${sectionId}">Make global</button>
      <button class="admin-tooltip-close" type="button" aria-label="Dismiss">&times;</button>
    `;
    document.body.appendChild(tip);
    const rect = target.getBoundingClientRect();
    tip.style.position = 'fixed';
    tip.style.top = `${Math.max(8, rect.top - 56)}px`;
    tip.style.left = `${Math.max(8, rect.left)}px`;
    const dismiss = () => tip.remove();
    setTimeout(dismiss, 5000);
    tip.querySelector('.admin-tooltip-close')?.addEventListener('click', dismiss);
    tip.querySelector('[data-make-global]')?.addEventListener('click', async () => {
      try {
        await patch(`sections?id=eq.${sectionId}`, { scope: 'global' });
        Object.keys(localStorage)
          .filter((k) => k.startsWith('wl_cache_sections_'))
          .forEach((k) => localStorage.removeItem(k));
        showToast('Saved — appears on all pages');
      } catch (e) {
        console.error('Promotion failed:', e);
        showToast('Save failed', 'error');
      } finally {
        dismiss();
      }
    });
  }

  // --- Nav editor overlay ---
  // composable-layout: nav lives as a block in `sections` (zone='header',
  // section_type='nav'). The popover edits `config.items` on that block.
  let navEditorOpen = false;
  let navBlockId: number | null = null;

  function initNavEditor() {
    // Document-level delegation so newly hydrated nav blocks pick up the click.
    if ((document.body as any).__navEditorBound) return;
    (document.body as any).__navEditorBound = true;
    document.addEventListener('click', (e) => {
      const t = e.target as HTMLElement | null;
      const btn = t?.closest('[data-nav-edit]') as HTMLElement | null;
      if (!btn) return;
      e.preventDefault();
      const sid = parseInt(btn.dataset.navEdit || '', 10);
      if (Number.isFinite(sid)) {
        navBlockId = sid;
        openNavEditor();
      }
    });
  }

  async function openNavEditor() {
    if (navEditorOpen) return;
    navEditorOpen = true;

    // Fetch current nav block config
    let navItems: any[] = [];
    try {
      const id = navBlockId;
      const rows = id != null
        ? await get(`sections?id=eq.${id}`)
        : await get(`sections?section_type=eq.nav&zone=eq.header&order=position.asc&limit=1`);
      const row = rows[0];
      if (row) {
        navBlockId = row.id;
        navItems = (row.config && Array.isArray(row.config.items)) ? row.config.items : [];
      }
    } catch { navItems = []; }

    // Create overlay
    const backdrop = document.createElement('div');
    backdrop.className = 'admin-popover-backdrop';

    const panel = document.createElement('div');
    panel.className = 'admin-nav-editor';
    panel.innerHTML = `
      <div class="admin-nav-editor-header">
        <h3>Edit Navigation</h3>
        <div style="display:flex;gap:0.5rem">
          <button class="btn btn-primary btn-sm" id="nav-editor-save">Save</button>
          <button class="btn btn-secondary btn-sm" id="nav-editor-cancel">Cancel</button>
        </div>
      </div>
      <div id="nav-editor-items"></div>
      <button class="btn btn-secondary btn-sm mt-1" id="nav-editor-add">+ Add item</button>
    `;

    document.body.appendChild(backdrop);
    document.body.appendChild(panel);

    // Resolve a navItem object given its dotted path: e.g. "0" → navItems[0],
    // "0.children.2" → navItems[0].children[2].
    function getByPath(path: string): any {
      const parts = path.split('.');
      let cur: any = { children: navItems };
      for (let i = 0; i < parts.length; i++) {
        const key = parts[i];
        if (key === 'children') {
          cur = cur.children;
        } else {
          const idx = parseInt(key, 10);
          cur = cur[idx];
        }
      }
      return cur;
    }
    // Resolve the parent array (the array that contains the indexed item).
    function getParentArray(path: string): { arr: any[]; idx: number } {
      const parts = path.split('.');
      const lastIdx = parseInt(parts[parts.length - 1], 10);
      const parentParts = parts.slice(0, -1);
      let cur: any = { children: navItems };
      for (let i = 0; i < parentParts.length; i++) {
        const key = parentParts[i];
        if (key === 'children') {
          cur = cur.children;
        } else {
          const idx = parseInt(key, 10);
          cur = cur[idx];
        }
      }
      // cur is the parent object. The array is cur (if we went into children/navItems).
      const arr = Array.isArray(cur) ? cur : cur.children;
      return { arr, idx: lastIdx };
    }
    function countDescendants(item: any): number {
      const kids = Array.isArray(item.children) ? item.children : [];
      let n = kids.length;
      for (const k of kids) n += countDescendants(k);
      return n;
    }
    function renderRow(item: any, path: string, depth: number): string {
      const tooDeep = depth >= 2
        ? `<div class="admin-nav-depth-warn" style="font-size:0.75rem;color:var(--color-warning,#b08000);margin:0.125rem 0 0.25rem 0">Nested deeper than 2 levels — may not render well on mobile</div>`
        : '';
      const childCount = Array.isArray(item.children) ? item.children.length : 0;
      const guide = depth > 0 ? '<div class="admin-nav-guide" aria-hidden="true"></div>' : '';
      const childRows = (Array.isArray(item.children) ? item.children : [])
        .map((c: any, ci: number) => renderRow(c, `${path}.children.${ci}`, depth + 1))
        .join('');
      const childContainer = childCount > 0
        ? `<div class="admin-nav-children" data-children-of="${path}">${childRows}</div>`
        : '';
      return `
        <div class="admin-nav-item-row admin-nav-row-depth-${depth}" data-path="${path}" data-depth="${depth}" draggable="true" style="margin-left:${depth * 1.5}rem">
          ${guide}
          <div class="drag-handle" title="Drag to reorder">&#9776;</div>
          <input type="text" value="${esc(item.label || '')}" data-field="label" placeholder="Label">
          <input type="text" value="${esc(item.href || '')}" data-field="href" placeholder="/page.html (optional if has children)">
          <select data-field="visibility">
            <option value="public"${item.public ? ' selected' : ''}>Public</option>
            <option value="auth"${item.auth ? ' selected' : ''}>Members</option>
            <option value="admin"${item.admin ? ' selected' : ''}>Admin</option>
          </select>
          <button class="btn btn-secondary btn-sm" data-add-child="${path}" title="Add child item">+ child</button>
          <button class="remove-btn" title="Remove">&times;</button>
          ${tooDeep}
        </div>
        ${childContainer}
      `;
    }

    function renderItems() {
      const container = panel.querySelector('#nav-editor-items')!;
      container.innerHTML = navItems
        .map((item: any, i: number) => renderRow(item, String(i), 0))
        .join('');

      // Bind row events
      container.querySelectorAll('.admin-nav-item-row').forEach((row) => {
        const path = (row as HTMLElement).dataset.path!;

        // Input changes
        row.querySelectorAll(':scope > input, :scope > select').forEach((input) => {
          input.addEventListener('change', () => {
            const field = (input as HTMLElement).dataset.field!;
            const item = getByPath(path);
            if (!item) return;
            if (field === 'visibility') {
              const val = (input as HTMLSelectElement).value;
              delete item.public;
              delete item.auth;
              delete item.admin;
              if (val === 'public') item.public = true;
              else if (val === 'auth') item.auth = true;
              else if (val === 'admin') item.admin = true;
            } else {
              item[field] = (input as HTMLInputElement).value;
            }
          });
        });

        // Add child
        row.querySelector(':scope > [data-add-child]')?.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const item = getByPath(path);
          if (!item) return;
          if (!Array.isArray(item.children)) item.children = [];
          item.children.push({ label: 'New Link', href: '/', public: true });
          renderItems();
        });

        // Remove (with subtree confirmation if children present)
        row.querySelector(':scope > .remove-btn')?.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const { arr, idx } = getParentArray(path);
          const item = arr[idx];
          if (!item) return;
          const descendants = countDescendants(item);
          if (descendants > 0) {
            const word = descendants === 1 ? 'child' : 'children';
            if (!confirm(`Remove this item and its ${descendants} ${word}?`)) return;
          }
          arr.splice(idx, 1);
          renderItems();
        });

        // Drag reorder — scoped to the same parent array.
        row.addEventListener('dragstart', (e) => {
          (e as DragEvent).dataTransfer!.setData('text/plain', path);
          (e as DragEvent).dataTransfer!.effectAllowed = 'move';
          (row as HTMLElement).style.opacity = '0.4';
        });
        row.addEventListener('dragend', () => {
          (row as HTMLElement).style.opacity = '1';
        });
        row.addEventListener('dragover', (e) => {
          const dt = (e as DragEvent).dataTransfer;
          if (!dt) return;
          const fromPath = dt.getData('text/plain') || '';
          // Only accept drops within the same parent scope.
          const fromParent = fromPath.split('.').slice(0, -1).join('.');
          const toParent = path.split('.').slice(0, -1).join('.');
          if (fromParent === toParent) {
            e.preventDefault();
            dt.dropEffect = 'move';
          }
        });
        row.addEventListener('drop', (e) => {
          const dt = (e as DragEvent).dataTransfer;
          if (!dt) return;
          const fromPath = dt.getData('text/plain');
          if (!fromPath || fromPath === path) return;
          const fromParent = fromPath.split('.').slice(0, -1).join('.');
          const toParent = path.split('.').slice(0, -1).join('.');
          if (fromParent !== toParent) return;
          e.preventDefault();
          const fromIdx = parseInt(fromPath.split('.').pop()!, 10);
          const toIdx = parseInt(path.split('.').pop()!, 10);
          const fromCtx = getParentArray(fromPath);
          const [moved] = fromCtx.arr.splice(fromIdx, 1);
          fromCtx.arr.splice(toIdx, 0, moved);
          renderItems();
        });
      });
    }

    renderItems();

    // Add top-level item
    panel.querySelector('#nav-editor-add')?.addEventListener('click', () => {
      navItems.push({ label: 'New Link', href: '/', public: true });
      renderItems();
    });

    // Save — PATCH the nav block's `config.items`. read-modify-write so we
    // don't clobber other config keys on the row.
    panel.querySelector('#nav-editor-save')?.addEventListener('click', async () => {
      try {
        if (navBlockId == null) throw new Error('No nav block id resolved');
        const rows = await get(`sections?id=eq.${navBlockId}`);
        const current = rows[0]?.config || {};
        const newConfig = { ...current, items: navItems };
        await patch(`sections?id=eq.${navBlockId}`, { config: newConfig });
        // Bust per-slug section caches so chrome blocks re-render with new nav.
        Object.keys(localStorage)
          .filter((k) => k.startsWith('wl_cache_sections_'))
          .forEach((k) => localStorage.removeItem(k));
        showToast('Navigation saved');
        closeNavEditor();
        document.dispatchEvent(new CustomEvent('wl-content-rendered'));
      } catch (e) {
        console.error('Nav save failed:', e);
        showToast('Save failed', 'error');
      }
    });

    // Cancel
    panel.querySelector('#nav-editor-cancel')?.addEventListener('click', closeNavEditor);
    backdrop.addEventListener('click', closeNavEditor);

    function closeNavEditor() {
      panel.remove();
      backdrop.remove();
      navEditorOpen = false;
    }
  }

  // --- Hero editor overlay ---
  // Surfaced by the generic section-edit popover for hero blocks (the
  // "Hero settings…" link). Also retains its own document-level click
  // listener on `data-hero-edit="<sid>"` for legacy callers/tests. The
  // popover contains: mode toggle (Background/Foreground), and when
  // foreground is selected, fields for image_url/alt/aspect, logo
  // overlay/position/max_height, caption_html (textarea), 3x3 caption
  // position picker, and text_position toggle. Switching modes when the
  // previous mode's fields are dirty prompts a confirm.
  let heroEditorOpen = false;

  type HeroMode = 'background' | 'foreground';
  type HeroAspect = 'auto' | '16/9' | '4/3' | '21/9';
  type HeroLogoPos = 'left' | 'center' | 'right';
  type HeroCaptionPos =
    | 'top-left' | 'top-center' | 'top-right'
    | 'right-middle' | 'bottom-right' | 'bottom-center'
    | 'bottom-left' | 'left-middle';
  type HeroTextPos = 'over_image' | 'below_image';

  interface HeroDraft {
    heading?: string;
    subheading?: string;
    cta_text?: string;
    cta_href?: string;
    mode?: HeroMode;
    bg_image?: string;
    image_url?: string;
    image_alt?: string;
    image_aspect?: HeroAspect;
    logo_overlay_url?: string;
    logo_position?: HeroLogoPos;
    logo_max_height?: string;
    caption_html?: string;
    caption_position?: HeroCaptionPos;
    text_position?: HeroTextPos;
    [k: string]: any;
  }

  function initHeroEditor() {
    if ((document.body as any).__heroEditorBound) return;
    (document.body as any).__heroEditorBound = true;
    document.addEventListener('click', (e) => {
      const t = e.target as HTMLElement | null;
      const btn = t?.closest('[data-hero-edit]') as HTMLElement | null;
      if (!btn) return;
      e.preventDefault();
      const sid = parseInt(btn.dataset.heroEdit || '', 10);
      if (Number.isFinite(sid)) openHeroEditor(sid);
    });
  }

  function hasForegroundFieldsSet(cfg: HeroDraft): boolean {
    return Boolean(
      cfg.image_url || cfg.image_alt || cfg.logo_overlay_url ||
      cfg.caption_html ||
      (cfg.image_aspect && cfg.image_aspect !== 'auto') ||
      (cfg.caption_position && cfg.caption_position !== 'bottom-right') ||
      (cfg.text_position && cfg.text_position !== 'over_image') ||
      (cfg.logo_position && cfg.logo_position !== 'left') ||
      (cfg.logo_max_height && cfg.logo_max_height !== '120px'),
    );
  }

  function hasBackgroundFieldsSet(cfg: HeroDraft): boolean {
    return Boolean(cfg.bg_image);
  }

  async function openHeroEditor(sid: number) {
    if (heroEditorOpen) return;
    heroEditorOpen = true;

    let cfg: HeroDraft = {};
    try {
      const rows = await get(`sections?id=eq.${sid}`);
      cfg = (rows[0]?.config as HeroDraft) || {};
    } catch {
      cfg = {};
    }
    if (!cfg.mode) cfg.mode = 'background';

    const backdrop = document.createElement('div');
    backdrop.className = 'admin-popover-backdrop';
    const panel = document.createElement('div');
    panel.className = 'admin-popover admin-hero-editor';
    panel.setAttribute('role', 'dialog');
    panel.setAttribute('aria-label', 'Hero settings');
    panel.style.maxWidth = '560px';

    document.body.appendChild(backdrop);
    document.body.appendChild(panel);

    function close() {
      panel.remove();
      backdrop.remove();
      heroEditorOpen = false;
    }
    backdrop.addEventListener('click', close);

    function captionGridHtml(selected: HeroCaptionPos | undefined): string {
      const positions: (HeroCaptionPos | null)[] = [
        'top-left', 'top-center', 'top-right',
        'left-middle', null, 'right-middle',
        'bottom-left', 'bottom-center', 'bottom-right',
      ];
      const sel = selected || 'bottom-right';
      const cells = positions.map((p) => {
        if (p === null) return `<div class="caption-grid-cell caption-grid-disabled" aria-hidden="true"></div>`;
        const isSelected = p === sel ? ' aria-pressed="true"' : ' aria-pressed="false"';
        const cls = p === sel ? 'caption-grid-cell selected' : 'caption-grid-cell';
        return `<button type="button" class="${cls}" data-caption-pos="${p}"${isSelected} title="${p}">●</button>`;
      }).join('');
      return `<div class="caption-grid">${cells}</div>`;
    }

    function render() {
      const mode = cfg.mode || 'background';
      panel.innerHTML = `
        <div class="popover-header">
          <h3>Hero settings</h3>
          <div style="display:flex;gap:0.5rem">
            <button class="btn btn-primary btn-sm" data-action="save">Save</button>
            <button class="btn btn-secondary btn-sm" data-action="cancel">Cancel</button>
          </div>
        </div>
        <div class="hero-editor-body">
          <fieldset class="hero-mode-toggle">
            <legend>Mode</legend>
            <label><input type="radio" name="hero-mode" value="background"${mode === 'background' ? ' checked' : ''}> Background image</label>
            <label><input type="radio" name="hero-mode" value="foreground"${mode === 'foreground' ? ' checked' : ''}> Foreground image</label>
          </fieldset>
          ${mode === 'foreground' ? renderForegroundFieldset() : renderBackgroundFieldset()}
        </div>
      `;
      bindForm();
    }

    function renderBackgroundFieldset(): string {
      return `
        <fieldset class="hero-mode-fields">
          <legend>Background image</legend>
          <label class="field">
            <span>Background image URL</span>
            <input type="text" data-field="bg_image" value="${esc(cfg.bg_image || '')}" placeholder="/assets/hero.jpg">
          </label>
          <p class="text-muted text-sm">The image is rendered as a CSS <code>background-image: cover</code> at fixed height. Use this for mood/decoration. Switch to Foreground for banners that must show their full content.</p>
        </fieldset>
      `;
    }

    function renderForegroundFieldset(): string {
      const aspect = cfg.image_aspect || 'auto';
      const logoPos = cfg.logo_position || 'left';
      const textPos = cfg.text_position || 'over_image';
      return `
        <fieldset class="hero-mode-fields">
          <legend>Foreground image</legend>
          <label class="field">
            <span>Image URL</span>
            <input type="text" data-field="image_url" value="${esc(cfg.image_url || '')}" placeholder="/assets/banner.png">
          </label>
          <label class="field">
            <span>Image alt text <em>(required for a11y)</em></span>
            <input type="text" data-field="image_alt" value="${esc(cfg.image_alt || '')}" placeholder="Founded 1880, banner">
          </label>
          <label class="field">
            <span>Aspect ratio</span>
            <select data-field="image_aspect">
              <option value="auto"${aspect === 'auto' ? ' selected' : ''}>Auto (native)</option>
              <option value="16/9"${aspect === '16/9' ? ' selected' : ''}>16:9</option>
              <option value="4/3"${aspect === '4/3' ? ' selected' : ''}>4:3</option>
              <option value="21/9"${aspect === '21/9' ? ' selected' : ''}>21:9 (cinema)</option>
            </select>
          </label>
          <label class="field">
            <span>Logo overlay URL <em>(optional)</em></span>
            <input type="text" data-field="logo_overlay_url" value="${esc(cfg.logo_overlay_url || '')}" placeholder="/assets/logo.svg">
          </label>
          <fieldset class="field-radio">
            <legend>Logo position</legend>
            <label><input type="radio" name="logo_position" value="left"${logoPos === 'left' ? ' checked' : ''}> Left</label>
            <label><input type="radio" name="logo_position" value="center"${logoPos === 'center' ? ' checked' : ''}> Center</label>
            <label><input type="radio" name="logo_position" value="right"${logoPos === 'right' ? ' checked' : ''}> Right</label>
          </fieldset>
          <label class="field">
            <span>Logo max height (CSS, e.g. 120px)</span>
            <input type="text" data-field="logo_max_height" value="${esc(cfg.logo_max_height || '120px')}">
          </label>
          <label class="field">
            <span>Caption HTML <em>(allowed: &lt;br&gt;, &lt;strong&gt;, &lt;em&gt;, &lt;a&gt;)</em></span>
            <textarea data-field="caption_html" rows="3" placeholder="Founded 1880&lt;br&gt;Alexandria, VA">${esc(cfg.caption_html || '')}</textarea>
          </label>
          <div class="field">
            <span>Caption position</span>
            ${captionGridHtml(cfg.caption_position)}
          </div>
          <fieldset class="field-radio">
            <legend>Heading position</legend>
            <label><input type="radio" name="text_position" value="over_image"${textPos === 'over_image' ? ' checked' : ''}> Over the image</label>
            <label><input type="radio" name="text_position" value="below_image"${textPos === 'below_image' ? ' checked' : ''}> Below the image</label>
          </fieldset>
        </fieldset>
      `;
    }

    function bindForm() {
      panel.querySelectorAll<HTMLInputElement>('input[name="hero-mode"]').forEach((radio) => {
        radio.addEventListener('change', () => {
          const newMode = radio.value as HeroMode;
          if (newMode === cfg.mode) return;
          // Confirm on switch when previous mode is dirty.
          const prevDirty = cfg.mode === 'background'
            ? hasBackgroundFieldsSet(cfg)
            : hasForegroundFieldsSet(cfg);
          if (prevDirty) {
            const ok = confirm(`Switching modes will clear the ${cfg.mode}-specific fields. Continue?`);
            if (!ok) {
              // Restore the radio.
              const prev = panel.querySelector<HTMLInputElement>(`input[name="hero-mode"][value="${cfg.mode}"]`);
              if (prev) prev.checked = true;
              return;
            }
          }
          if (newMode === 'foreground') {
            // Clear background-only fields.
            delete cfg.bg_image;
          } else {
            // Clear foreground-only fields.
            delete cfg.image_url;
            delete cfg.image_alt;
            delete cfg.image_aspect;
            delete cfg.logo_overlay_url;
            delete cfg.logo_position;
            delete cfg.logo_max_height;
            delete cfg.caption_html;
            delete cfg.caption_position;
            delete cfg.text_position;
          }
          cfg.mode = newMode;
          render();
        });
      });

      panel.querySelectorAll<HTMLElement>('[data-field]').forEach((el) => {
        const field = (el as HTMLElement).dataset.field!;
        el.addEventListener('input', () => {
          cfg[field] = (el as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement).value;
        });
        el.addEventListener('change', () => {
          cfg[field] = (el as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement).value;
        });
      });

      panel.querySelectorAll<HTMLInputElement>('input[name="logo_position"]').forEach((r) => {
        r.addEventListener('change', () => {
          if (r.checked) cfg.logo_position = r.value as HeroLogoPos;
        });
      });
      panel.querySelectorAll<HTMLInputElement>('input[name="text_position"]').forEach((r) => {
        r.addEventListener('change', () => {
          if (r.checked) cfg.text_position = r.value as HeroTextPos;
        });
      });

      panel.querySelectorAll<HTMLElement>('[data-caption-pos]').forEach((cell) => {
        cell.addEventListener('click', () => {
          const pos = cell.dataset.captionPos as HeroCaptionPos;
          cfg.caption_position = pos;
          panel.querySelectorAll<HTMLElement>('[data-caption-pos]').forEach((c) => {
            const same = c === cell;
            c.classList.toggle('selected', same);
            c.setAttribute('aria-pressed', same ? 'true' : 'false');
          });
        });
      });

      panel.querySelector<HTMLButtonElement>('[data-action="cancel"]')?.addEventListener('click', close);
      panel.querySelector<HTMLButtonElement>('[data-action="save"]')?.addEventListener('click', async () => {
        try {
          // Read current config so we don't clobber unrelated keys (heading,
          // subheading, cta_text/href live outside this popover).
          const rows = await get(`sections?id=eq.${sid}`);
          const current = (rows[0]?.config as HeroDraft) || {};
          const merged: HeroDraft = { ...current };
          // Common scalar fields preserved from the row.
          // Apply popover-specific fields.
          merged.mode = cfg.mode;
          if (cfg.mode === 'foreground') {
            delete merged.bg_image;
            merged.image_url = cfg.image_url || '';
            merged.image_alt = cfg.image_alt || '';
            merged.image_aspect = cfg.image_aspect || 'auto';
            merged.logo_overlay_url = cfg.logo_overlay_url || '';
            merged.logo_position = cfg.logo_position || 'left';
            merged.logo_max_height = cfg.logo_max_height || '120px';
            merged.caption_html = cfg.caption_html || '';
            merged.caption_position = cfg.caption_position || 'bottom-right';
            merged.text_position = cfg.text_position || 'over_image';
          } else {
            delete merged.image_url;
            delete merged.image_alt;
            delete merged.image_aspect;
            delete merged.logo_overlay_url;
            delete merged.logo_position;
            delete merged.logo_max_height;
            delete merged.caption_html;
            delete merged.caption_position;
            delete merged.text_position;
            merged.bg_image = cfg.bg_image || '';
          }
          await patch(`sections?id=eq.${sid}`, { config: merged });
          Object.keys(localStorage)
            .filter((k) => k.startsWith('wl_cache_sections_'))
            .forEach((k) => localStorage.removeItem(k));
          showToast('Hero saved');
          close();
          document.dispatchEvent(new CustomEvent('wl-content-rendered'));
        } catch (e) {
          console.error('Hero save failed:', e);
          showToast('Save failed', 'error');
        }
      });
    }

    render();
  }

  // --- Section actions: remove / scope-toggle / add-section (delegated) ---
  function initSectionActions() {
    if ((document.body as any).__sectionActionsBound) return;
    (document.body as any).__sectionActionsBound = true;

    document.addEventListener('click', async (e) => {
      const t = e.target as HTMLElement | null;
      if (!t) return;

      // Remove section
      const removeBtn = t.closest('[data-section-remove]') as HTMLElement | null;
      if (removeBtn) {
        e.preventDefault();
        const id = removeBtn.dataset.sectionRemove;
        if (!id) return;
        if (!confirm('Remove this section?')) return;
        try {
          const { del } = await import('../lib/api');
          await del(`sections?id=eq.${id}`);
          Object.keys(localStorage)
            .filter((k) => k.startsWith('wl_cache_sections_'))
            .forEach((k) => localStorage.removeItem(k));
          removeBtn.closest('[data-sortable-id]')?.remove();
          showToast('Section removed');
        } catch (err) {
          console.error('Failed to remove section:', err);
          showToast('Remove failed', 'error');
        }
        return;
      }

      // Scope toggle
      const scopeBtn = t.closest('[data-scope-toggle]') as HTMLElement | null;
      if (scopeBtn) {
        e.preventDefault();
        const id = scopeBtn.dataset.scopeToggle;
        const next = scopeBtn.dataset.scopeNext as 'page' | 'global' | undefined;
        if (!id || !next) return;
        try {
          await patch(`sections?id=eq.${id}`, { scope: next });
          Object.keys(localStorage)
            .filter((k) => k.startsWith('wl_cache_sections_'))
            .forEach((k) => localStorage.removeItem(k));
          showToast(next === 'global' ? 'Saved — appears on all pages' : 'Saved — appears on this page only');
          // Update DOM attributes so subsequent toggles reflect new state.
          const sectionEl = scopeBtn.closest('[data-sortable-id]') as HTMLElement | null;
          if (sectionEl) {
            sectionEl.setAttribute('data-section-scope', next);
            const flipped = next === 'global' ? 'page' : 'global';
            scopeBtn.dataset.scopeNext = flipped;
            scopeBtn.textContent = flipped === 'global' ? 'Make global' : 'Make page-only';
            scopeBtn.title = scopeBtn.textContent;
            const existingPill = sectionEl.querySelector('.admin-section-actions .admin-scope-pill');
            if (next === 'global' && !existingPill) {
              const pill = document.createElement('span');
              pill.className = 'admin-scope-pill';
              pill.textContent = 'Global';
              scopeBtn.before(pill);
            } else if (next === 'page' && existingPill) {
              existingPill.remove();
            }
          }
        } catch (err) {
          console.error('Scope toggle failed:', err);
          showToast('Save failed', 'error');
        }
        return;
      }

      // Add section in zone
      const addBtn = t.closest('[data-zone-add]') as HTMLElement | null;
      if (addBtn) {
        e.preventDefault();
        const zone = addBtn.dataset.zoneAdd as 'header' | 'main' | 'footer' | undefined;
        if (!zone) return;
        openZoneAddPicker(zone);
        return;
      }

      // column-span-rows: per-block edit popover (span radio + scope + remove)
      const editBtn = t.closest('[data-section-edit]') as HTMLElement | null;
      if (editBtn) {
        e.preventDefault();
        const id = parseInt(editBtn.dataset.sectionEdit || '', 10);
        if (Number.isFinite(id)) openSectionEditPopover(id);
        return;
      }
    });
  }

  function ensureZoneAddButtons() {
    document.querySelectorAll<HTMLElement>('[data-zone]').forEach((zoneEl) => {
      const zone = zoneEl.dataset.zone;
      if (!zone) return;
      if (zoneEl.querySelector(':scope > .admin-zone-add-btn')) return;
      const btn = document.createElement('button');
      btn.className = 'admin-zone-add-btn';
      btn.type = 'button';
      btn.dataset.zoneAdd = zone;
      btn.textContent = `+ Add to ${zone}`;
      zoneEl.appendChild(btn);
    });
  }

  async function openZoneAddPicker(zone: 'header' | 'main' | 'footer') {
    const { BLOCK_TYPES } = await import('../lib/blocks');
    document.querySelector('.admin-popover-backdrop')?.remove();
    document.querySelector('.admin-popover')?.remove();

    const candidates = Object.entries(BLOCK_TYPES).filter(
      ([, t]) => !t.zoneHints || t.zoneHints.includes(zone),
    );

    const backdrop = document.createElement('div');
    backdrop.className = 'admin-popover-backdrop';
    const popover = document.createElement('div');
    popover.className = 'admin-popover';
    popover.innerHTML = `
      <h3>Add block to ${zone}</h3>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:0.5rem">
        ${candidates.map(([type, def]) => `
          <button class="card" type="button" style="cursor:pointer;text-align:center;padding:1rem" data-block-type="${type}">
            <div style="font-size:1.5rem">${def.icon}</div>
            <div style="font-weight:600">${def.label}</div>
          </button>
        `).join('')}
      </div>
    `;
    document.body.appendChild(backdrop);
    document.body.appendChild(popover);

    const close = () => { popover.remove(); backdrop.remove(); };
    backdrop.addEventListener('click', close);

    popover.querySelectorAll<HTMLElement>('[data-block-type]').forEach((el) => {
      el.addEventListener('click', async () => {
        const type = el.dataset.blockType!;
        const def = BLOCK_TYPES[type];
        if (!def) return;
        // Determine slug + scope based on zone:
        // - header / footer → global, page_slug='*'
        // - main → page-scoped, slug from URL
        let pageSlug: string;
        let scope: 'page' | 'global';
        if (zone === 'header' || zone === 'footer') {
          pageSlug = '*';
          scope = 'global';
        } else {
          scope = 'page';
          const path = window.location.pathname;
          if (path === '/' || path === '/index.html') pageSlug = 'index';
          else if (path === '/page.html') pageSlug = new URLSearchParams(window.location.search).get('slug') || 'index';
          else pageSlug = path.replace(/^\//, '').replace(/\.html$/, '') || 'index';
        }
        const zoneEl = document.querySelector(`[data-zone="${zone}"]`) as HTMLElement | null;
        const existingCount = zoneEl?.querySelectorAll('[data-sortable-id]').length || 0;
        try {
          const { post } = await import('../lib/api');
          await post('sections', {
            page_slug: pageSlug,
            zone,
            scope,
            section_type: type,
            config: def.defaultConfig,
            position: existingCount + 1,
            visible: true,
          });
          Object.keys(localStorage)
            .filter((k) => k.startsWith('wl_cache_sections_'))
            .forEach((k) => localStorage.removeItem(k));
          showToast('Block added');
          close();
          document.dispatchEvent(new CustomEvent('wl-content-rendered'));
        } catch (err) {
          console.error('Failed to add block:', err);
          showToast('Add failed', 'error');
        }
      });
    });
  }

  // --- Embed-block edit popover ---
  // Triggered by clicking the pencil button (data-embed-edit) on any embed
  // block. Renders a provider selector + dynamic params form + trust gate
  // (for the generic iframe provider). Reads the section row, lets the admin
  // change provider/params/heading, then PATCHes the row's `config`.
  let embedEditorOpen = false;

  function initEmbedEditor() {
    if ((document.body as any).__embedEditorBound) return;
    (document.body as any).__embedEditorBound = true;
    document.addEventListener('click', (e) => {
      const t = e.target as HTMLElement | null;
      const btn = t?.closest('[data-embed-edit]') as HTMLElement | null;
      if (!btn) return;
      e.preventDefault();
      e.stopPropagation();
      const sid = parseInt(btn.dataset.embedEdit || '', 10);
      if (Number.isFinite(sid)) openEmbedEditor(sid);
    });
  }

  function extractVideoId(provider: string, raw: string): string | null {
    if (!raw) return null;
    const trimmed = raw.trim();
    if (provider === 'youtube') {
      const patterns = [
        /youtube\.com\/watch\?v=([\w-]{6,})/,
        /youtu\.be\/([\w-]{6,})/,
        /youtube\.com\/embed\/([\w-]{6,})/,
        /youtube\.com\/shorts\/([\w-]{6,})/,
      ];
      for (const re of patterns) {
        const m = trimmed.match(re);
        if (m) return m[1];
      }
      // Already a bare ID?
      if (/^[\w-]{6,}$/.test(trimmed)) return trimmed;
    }
    if (provider === 'vimeo') {
      const m = trimmed.match(/vimeo\.com\/(?:video\/)?(\d+)/);
      if (m) return m[1];
      if (/^\d+$/.test(trimmed)) return trimmed;
    }
    return null;
  }

  async function openEmbedEditor(sectionId: number) {
    if (embedEditorOpen) return;
    embedEditorOpen = true;

    const { PROVIDERS } = await import('../lib/blocks/embed-providers');

    let row: any = null;
    try {
      const rows = await get(`sections?id=eq.${sectionId}`);
      row = rows[0];
    } catch (err) {
      console.error('Failed to load embed block:', err);
      showToast('Could not load embed', 'error');
      embedEditorOpen = false;
      return;
    }
    if (!row) {
      showToast('Block not found', 'error');
      embedEditorOpen = false;
      return;
    }

    const cfg: any = row.config || {};
    let providerId: string = cfg.provider || 'youtube';
    let params: any = { ...(cfg.params || {}) };
    let heading: string = cfg.heading || '';
    let trustAck: boolean = cfg.trust_acknowledged === true;
    let trustedHost: string = '';

    const backdrop = document.createElement('div');
    backdrop.className = 'admin-popover-backdrop';
    const panel = document.createElement('div');
    panel.className = 'admin-popover admin-embed-editor';

    function trustHostFor(srcVal: string): string {
      try {
        return new URL(srcVal).host;
      } catch {
        return '';
      }
    }

    function renderForm() {
      const provider = PROVIDERS[providerId];
      if (!provider) return;
      const fields = Object.entries(provider.paramsSchema)
        .map(([key, schema]) => {
          const labelText = schema.label || key;
          const required = schema.required ? ' <span class="admin-embed__req">*</span>' : '';
          const helpHtml = schema.help
            ? `<div class="admin-embed__help">${esc(schema.help)}</div>`
            : '';
          const value = params[key] != null ? String(params[key]) : '';
          let input = '';
          if (schema.type === 'select' && schema.options) {
            const opts = schema.options
              .map((o) => {
                const sel = String(value) === o ? ' selected' : '';
                return `<option value="${esc(o)}"${sel}>${esc(o)}</option>`;
              })
              .join('');
            input = `<select data-param="${esc(key)}"><option value=""></option>${opts}</select>`;
          } else if (schema.type === 'number') {
            input =
              `<input type="number" data-param="${esc(key)}" value="${esc(value)}" ` +
              `placeholder="${esc(schema.placeholder || '')}" ${schema.required ? 'required' : ''}>`;
          } else {
            input =
              `<input type="text" data-param="${esc(key)}" value="${esc(value)}" ` +
              `placeholder="${esc(schema.placeholder || '')}" ${schema.required ? 'required' : ''}>`;
          }
          return `
            <div class="admin-embed__field">
              <label>${esc(labelText)}${required}</label>
              ${input}
              ${helpHtml}
            </div>
          `;
        })
        .join('');

      // Provider-specific helper UI
      let helperUi = '';
      if (providerId === 'youtube' || providerId === 'vimeo') {
        helperUi = `
          <div class="admin-embed__helper">
            <label>Paste a ${providerId === 'youtube' ? 'YouTube' : 'Vimeo'} URL to extract the ID</label>
            <div style="display:flex;gap:0.5rem">
              <input type="text" id="embed-url-helper" placeholder="https://${providerId === 'youtube' ? 'www.youtube.com/watch?v=...' : 'vimeo.com/...'}" style="flex:1">
              <button type="button" class="btn btn-secondary btn-sm" id="embed-url-extract">Extract</button>
            </div>
          </div>
        `;
      }

      // Trust gate for generic iframe
      let trustUi = '';
      if (providerId === 'iframe') {
        trustedHost = trustHostFor(String(params.src || ''));
        const labelHost = trustedHost || 'this source';
        trustUi = `
          <div class="admin-embed__trust" role="alert">
            <strong>⚠ External content</strong>
            <p>This block embeds content from a source Kychon hasn't verified.
               Visitors run any scripts the source serves.</p>
            <label class="admin-embed__trust-check">
              <input type="checkbox" id="embed-trust-check" ${trustAck && trustedHost ? 'checked' : ''}>
              <span>I trust <code id="embed-trust-host">${esc(labelHost)}</code></span>
            </label>
          </div>
        `;
      }

      panel.innerHTML = `
        <div class="admin-embed__header">
          <h3>Edit embed</h3>
          <div class="admin-embed__actions">
            <button class="btn btn-primary btn-sm" id="embed-save">Save</button>
            <button class="btn btn-secondary btn-sm" id="embed-cancel">Cancel</button>
          </div>
        </div>
        <div class="admin-embed__field">
          <label>Provider</label>
          <select id="embed-provider">
            ${Object.entries(PROVIDERS)
              .map(
                ([id, p]) =>
                  `<option value="${esc(id)}"${
                    id === providerId ? ' selected' : ''
                  }>${esc(p.icon)} ${esc(p.label)}</option>`,
              )
              .join('')}
          </select>
        </div>
        <div class="admin-embed__field">
          <label>Heading (optional)</label>
          <input type="text" id="embed-heading" value="${esc(heading)}" placeholder="Block heading shown above the embed">
        </div>
        ${helperUi}
        <fieldset class="admin-embed__params">
          <legend>Provider params</legend>
          ${fields}
        </fieldset>
        ${trustUi}
      `;

      // Bind input changes
      panel.querySelectorAll<HTMLElement>('[data-param]').forEach((el) => {
        el.addEventListener('input', () => {
          const key = el.dataset.param!;
          if (el instanceof HTMLInputElement) {
            params[key] = el.type === 'number' ? (el.value === '' ? undefined : Number(el.value)) : el.value;
          } else if (el instanceof HTMLSelectElement) {
            params[key] = el.value;
          }
          // Re-evaluate trust host when iframe src changes
          if (providerId === 'iframe' && key === 'src') {
            const newHost = trustHostFor(String(params.src || ''));
            const hostEl = panel.querySelector('#embed-trust-host');
            if (hostEl) hostEl.textContent = newHost || 'this source';
            if (newHost !== trustedHost) {
              trustedHost = newHost;
              trustAck = false;
              const cb = panel.querySelector('#embed-trust-check') as HTMLInputElement | null;
              if (cb) cb.checked = false;
              updateSaveEnabled();
            }
          }
          updateSaveEnabled();
        });
      });

      panel.querySelector('#embed-provider')?.addEventListener('change', (ev) => {
        const newId = (ev.target as HTMLSelectElement).value;
        if (newId !== providerId) {
          providerId = newId;
          // Reset params when switching providers
          params = {};
          trustAck = false;
          trustedHost = '';
          renderForm();
          updateSaveEnabled();
        }
      });

      panel.querySelector('#embed-heading')?.addEventListener('input', (ev) => {
        heading = (ev.target as HTMLInputElement).value;
      });

      panel.querySelector('#embed-url-extract')?.addEventListener('click', () => {
        const helper = panel.querySelector('#embed-url-helper') as HTMLInputElement | null;
        if (!helper) return;
        const id = extractVideoId(providerId, helper.value);
        if (id) {
          params.video_id = id;
          const target = panel.querySelector('[data-param="video_id"]') as HTMLInputElement | null;
          if (target) target.value = id;
          showToast('Video ID extracted', 'success');
          updateSaveEnabled();
        } else {
          showToast('Could not extract video ID from that URL', 'error');
        }
      });

      panel.querySelector('#embed-trust-check')?.addEventListener('change', (ev) => {
        trustAck = (ev.target as HTMLInputElement).checked;
        updateSaveEnabled();
      });

      panel.querySelector('#embed-save')?.addEventListener('click', save);
      panel.querySelector('#embed-cancel')?.addEventListener('click', close);

      updateSaveEnabled();
    }

    function updateSaveEnabled() {
      const btn = panel.querySelector('#embed-save') as HTMLButtonElement | null;
      if (!btn) return;
      let enabled = true;
      const provider = PROVIDERS[providerId];
      if (!provider) enabled = false;
      else {
        for (const [key, schema] of Object.entries(provider.paramsSchema)) {
          if (schema.required && (params[key] == null || params[key] === '')) {
            enabled = false;
            break;
          }
        }
      }
      // Trust gate for iframe blocks the save until checked.
      if (providerId === 'iframe' && (!trustedHost || !trustAck)) enabled = false;
      btn.disabled = !enabled;
    }

    async function save() {
      const provider = PROVIDERS[providerId];
      if (!provider) return;
      // Optimistic-validate by running buildSrc here so we surface errors
      // before saving.
      try {
        provider.buildSrc(params);
      } catch (err) {
        showToast(err instanceof Error ? err.message : 'Invalid params', 'error');
        return;
      }
      const newConfig: any = {
        ...row.config,
        provider: providerId,
        params,
        heading,
      };
      if (providerId === 'iframe') {
        newConfig.trust_acknowledged = trustAck;
      } else {
        // Strip trust flag when switching to a verified provider.
        delete newConfig.trust_acknowledged;
      }
      try {
        await patch(`sections?id=eq.${row.id}`, { config: newConfig });
        Object.keys(localStorage)
          .filter((k) => k.startsWith('wl_cache_sections_'))
          .forEach((k) => localStorage.removeItem(k));
        showToast('Embed saved');
        close();
        document.dispatchEvent(new CustomEvent('wl-content-rendered'));
      } catch (err) {
        console.error('Embed save failed:', err);
        showToast('Save failed', 'error');
      }
    }

    function close() {
      panel.remove();
      backdrop.remove();
      embedEditorOpen = false;
    }

    backdrop.addEventListener('click', close);
    document.body.appendChild(backdrop);
    document.body.appendChild(panel);
    renderForm();
  }


  // column-span-rows: per-block edit popover. Surfaces span radio (filtered
  // by BlockType.supportedSpans), scope toggle, and remove. Each interaction
  // PATCHes the row, busts wl_cache_sections_*, and dispatches
  // `wl-content-rendered` so page-render.ts re-renders the zone.
  async function openSectionEditPopover(sectionId: number) {
    const { BLOCK_TYPES, getSupportedSpans } = await import('../lib/blocks');
    document.querySelector('.admin-popover-backdrop')?.remove();
    document.querySelector('.admin-popover')?.remove();

    let row: any = null;
    try {
      const rows = await get(`sections?id=eq.${sectionId}`);
      row = rows[0];
    } catch (err) {
      console.error('Failed to load section row:', err);
      showToast('Could not load block', 'error');
      return;
    }
    if (!row) {
      showToast('Block not found', 'error');
      return;
    }

    const def = BLOCK_TYPES[row.section_type] || null;
    const spans = getSupportedSpans(row.section_type);
    const currentSpan: string = row.column_span || '1';
    const currentScope: 'page' | 'global' = row.scope === 'global' ? 'global' : 'page';

    const backdrop = document.createElement('div');
    backdrop.className = 'admin-popover-backdrop';
    const popover = document.createElement('div');
    popover.className = 'admin-popover';

    const spanLabels: Record<string, string> = {
      '1': 'Full',
      '1/2': 'Half',
      '1/3': 'Third',
      '2/3': 'Two-thirds',
    };
    const spanRadioHtml = spans
      .map((s) => `<button type="button" class="admin-span-radio-btn${s === currentSpan ? ' active' : ''}" data-span="${s}">${esc(spanLabels[s] || s)}</button>`)
      .join('');

    const scopeLabel = currentScope === 'global' ? 'Make page-only' : 'Make global';
    const scopeNext = currentScope === 'global' ? 'page' : 'global';

    // hero-foreground-mode: hero blocks get a "Hero settings…" link that
    // opens the type-specific popover (mode toggle + foreground fields).
    const heroLink = row.section_type === 'hero'
      ? `<div class="hero-settings-link"><label class="admin-section-edit-label">Hero</label><button type="button" class="btn btn-secondary btn-sm" data-edit-hero-settings>Hero settings…</button></div>`
      : '';

    popover.innerHTML = `
      <div class="admin-section-edit-header">
        <h3>${esc(def?.label || row.section_type)}${currentScope === 'global' ? ' <span class="admin-scope-pill">Global</span>' : ''}</h3>
        <button class="admin-tooltip-close" type="button" aria-label="Close" data-edit-close>&times;</button>
      </div>
      <div class="admin-section-edit-body">
        <label class="admin-section-edit-label">Width</label>
        <div class="admin-span-radio">${spanRadioHtml}</div>
        <label class="admin-section-edit-label mt-2">Scope</label>
        <button type="button" class="btn btn-secondary btn-sm" data-edit-scope-toggle data-edit-scope-next="${scopeNext}">${esc(scopeLabel)}</button>
        ${heroLink}
        <div class="mt-2">
          <button type="button" class="btn btn-secondary btn-sm danger" data-edit-remove>Remove block</button>
        </div>
      </div>
    `;

    document.body.appendChild(backdrop);
    document.body.appendChild(popover);

    const close = () => {
      popover.remove();
      backdrop.remove();
    };
    backdrop.addEventListener('click', close);
    popover.querySelector('[data-edit-close]')?.addEventListener('click', close);

    // hero-foreground-mode: open the hero-specific popover (mode + foreground
    // fields). Closing the generic popover first prevents two stacked dialogs.
    popover.querySelector('[data-edit-hero-settings]')?.addEventListener('click', () => {
      close();
      void openHeroEditor(sectionId);
    });

    // Span radio change → PATCH column_span
    popover.querySelectorAll<HTMLElement>('[data-span]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const newSpan = btn.dataset.span;
        if (!newSpan || newSpan === row.column_span) return;
        try {
          await patch(`sections?id=eq.${sectionId}`, { column_span: newSpan });
          row.column_span = newSpan;
          Object.keys(localStorage)
            .filter((k) => k.startsWith('wl_cache_sections_'))
            .forEach((k) => localStorage.removeItem(k));
          popover.querySelectorAll<HTMLElement>('[data-span]').forEach((b) =>
            b.classList.toggle('active', b.dataset.span === newSpan),
          );
          // Update the rendered block's data-column-span attribute live so the
          // grid re-flows immediately without waiting for a network re-fetch.
          const blockEl = document.querySelector(`[data-sortable-id="sections.${sectionId}"]`) as HTMLElement | null;
          if (blockEl) blockEl.setAttribute('data-column-span', newSpan);
          showToast('Width saved');
          document.dispatchEvent(new CustomEvent('wl-content-rendered'));
        } catch (err) {
          console.error('Span save failed:', err);
          showToast('Save failed', 'error');
        }
      });
    });

    // Scope toggle
    popover.querySelector('[data-edit-scope-toggle]')?.addEventListener('click', async (ev) => {
      const targetBtn = ev.currentTarget as HTMLElement;
      const next = targetBtn.dataset.editScopeNext as 'page' | 'global' | undefined;
      if (!next) return;
      try {
        await patch(`sections?id=eq.${sectionId}`, { scope: next });
        row.scope = next;
        Object.keys(localStorage)
          .filter((k) => k.startsWith('wl_cache_sections_'))
          .forEach((k) => localStorage.removeItem(k));
        showToast(next === 'global' ? 'Saved — appears on all pages' : 'Saved — appears on this page only');
        const flipped = next === 'global' ? 'page' : 'global';
        targetBtn.dataset.editScopeNext = flipped;
        targetBtn.textContent = flipped === 'global' ? 'Make global' : 'Make page-only';
        // Update the popover header pill.
        const heading = popover.querySelector('.admin-section-edit-header h3');
        if (heading) {
          const existingPill = heading.querySelector('.admin-scope-pill');
          if (next === 'global' && !existingPill) {
            heading.insertAdjacentHTML('beforeend', ' <span class="admin-scope-pill">Global</span>');
          } else if (next === 'page' && existingPill) {
            existingPill.remove();
          }
        }
        // Mirror onto the inline scope toggle if it's still in the DOM.
        const inlineToggle = document.querySelector(`[data-scope-toggle="${sectionId}"]`) as HTMLElement | null;
        if (inlineToggle) {
          inlineToggle.dataset.scopeNext = flipped;
          inlineToggle.textContent = flipped === 'global' ? 'Make global' : 'Make page-only';
          inlineToggle.title = inlineToggle.textContent;
          const sectionEl = inlineToggle.closest('[data-sortable-id]') as HTMLElement | null;
          if (sectionEl) {
            sectionEl.setAttribute('data-section-scope', next);
            const existingInlinePill = sectionEl.querySelector('.admin-section-actions .admin-scope-pill');
            if (next === 'global' && !existingInlinePill) {
              const pill = document.createElement('span');
              pill.className = 'admin-scope-pill';
              pill.textContent = 'Global';
              inlineToggle.before(pill);
            } else if (next === 'page' && existingInlinePill) {
              existingInlinePill.remove();
            }
          }
        }
        document.dispatchEvent(new CustomEvent('wl-content-rendered'));
      } catch (err) {
        console.error('Scope save failed:', err);
        showToast('Save failed', 'error');
      }
    });

    // Remove
    popover.querySelector('[data-edit-remove]')?.addEventListener('click', async () => {
      if (!confirm('Remove this block?')) return;
      try {
        const { del } = await import('../lib/api');
        await del(`sections?id=eq.${sectionId}`);
        Object.keys(localStorage)
          .filter((k) => k.startsWith('wl_cache_sections_'))
          .forEach((k) => localStorage.removeItem(k));
        document.querySelector(`[data-sortable-id="sections.${sectionId}"]`)?.remove();
        showToast('Block removed');
        close();
      } catch (err) {
        console.error('Remove failed:', err);
        showToast('Remove failed', 'error');
      }
    });
  }


  // --- Main init ---
  async function initAdminEditor() {
    await ready;
    const session = JSON.parse(localStorage.getItem('wl_session') || 'null');
    if (session?.user?.member?.role !== 'admin') return;
    document.body.classList.add('admin');
    loadAdminCSS();
    initEditableText();
    initEditableRich();
    initEditableImage();
    initSortable();
    initNavEditor();
    initHeroEditor();
    initEmbedEditor();
    initSectionActions();
    ensureZoneAddButtons();
    // composable-layout: brand logo and nav are now blocks rendered with
    // their own data-editable / data-editable-image attributes — no extra
    // wiring needed here.
  }

  // Use MutationObserver to re-bind after client-side renders
  const observer = new MutationObserver((mutations) => {
    if (!document.body.classList.contains('admin')) return;
    let shouldRebind = false;
    for (const m of mutations) {
      if (m.type === 'childList' && m.addedNodes.length > 0) {
        for (const node of m.addedNodes) {
          if (node instanceof HTMLElement && (
            node.querySelector('[data-editable]') ||
            node.querySelector('[data-editable-rich]') ||
            node.querySelector('[data-editable-image]') ||
            node.querySelector('[data-sortable-id]') ||
            node.hasAttribute?.('data-editable') ||
            node.hasAttribute?.('data-editable-rich') ||
            node.hasAttribute?.('data-editable-image') ||
            node.hasAttribute?.('data-sortable-id')
          )) {
            shouldRebind = true;
            break;
          }
        }
      }
      if (shouldRebind) break;
    }
    if (shouldRebind) {
      initEditableText();
      initEditableRich();
      initEditableImage();
      initSortable();
      ensureZoneAddButtons();
    }
  });

  observer.observe(document.body, { childList: true, subtree: true });

  initAdminEditor();
  document.addEventListener('astro:after-swap', initAdminEditor);
</script>
