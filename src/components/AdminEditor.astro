---
// AdminEditor.astro — Inline editing for admins
// Loaded with client:idle — only initializes after page settles
// Supports: text, rich text (Tiptap), image upload, JSONB paths, drag reorder
---
<div id="admin-editor-root"></div>
<input id="admin-image-upload-input" type="file" accept="image/*" hidden aria-hidden="true" tabindex="-1" />
<div
  id="admin-editor-drop-indicator"
  class="pointer-events-none my-[-2px] h-[3px] rounded-full bg-primary shadow-sm transition-opacity"
  data-admin-drop-indicator
  data-column-span="1"
  hidden
></div>
<div id="admin-editor-controls-root" transition:persist></div>

<script>
  import { del, get, patch } from '../lib/api';
  import { clearCache, ready, refreshMemberRecord } from '../lib/config';
  import {
    ADMIN_ACTION_PROMPT_ACTIVATE,
    ADMIN_ACTION_PROMPT_DISMISS,
    ADMIN_ACTION_PROMPT_SHOW,
    type AdminActionPromptDetail,
    type AdminActionPromptIdDetail,
  } from '../lib/admin-action-prompts';
  import { uploadFileContentAddressed } from '../lib/storage-upload';
  import { showToast as showKychonToast } from '../lib/toast-events';

  type AdminEditorControlsModule = typeof import('./kychon/AdminEditorControlsIsland');
  type AdminActionPromptModule = typeof import('./kychon/AdminActionPromptIsland');

  function getToken(): string {
    const session = JSON.parse(localStorage.getItem('wl_session') || '{}');
    return session.access_token || '';
  }

  // --- Toast notifications ---
  function showToast(message: string, type: 'success' | 'error' = 'success') {
    showKychonToast({ message, type });
  }

  function emitSectionsChanged() {
    document.dispatchEvent(new CustomEvent('wl-sections-changed'));
    document.dispatchEvent(new CustomEvent('wl-content-rendered'));
  }

  let adminEditorControlsPromise: Promise<AdminEditorControlsModule | null> | null = null;
  let adminActionPromptPromise: Promise<AdminActionPromptModule | null> | null = null;
  const adminPromptActions = new Map<string, () => Promise<void>>();
  let adminPromptActionsBound = false;

  async function ensureAdminEditorControls(): Promise<AdminEditorControlsModule | null> {
    const root = document.getElementById('admin-editor-controls-root');
    if (!root) return null;
    adminEditorControlsPromise ??= import('./kychon/AdminEditorControlsIsland')
      .then((module) => {
        module.mountAdminEditorControls(root);
        return module;
      })
      .catch((error) => {
        console.error('Failed to load admin editor controls:', error);
        adminEditorControlsPromise = null;
        return null;
      });
    return adminEditorControlsPromise;
  }

  async function ensureAdminActionPrompts(): Promise<AdminActionPromptModule | null> {
    const root = document.getElementById('admin-editor-root');
    if (!root) return null;
    adminActionPromptPromise ??= import('./kychon/AdminActionPromptIsland')
      .then((module) => {
        module.mountAdminActionPromptIsland(root);
        return module;
      })
      .catch((error) => {
        console.error('Failed to load admin action prompts:', error);
        adminActionPromptPromise = null;
        return null;
      });
    return adminActionPromptPromise;
  }

  function bindAdminPromptActions() {
    if (adminPromptActionsBound) return;
    adminPromptActionsBound = true;
    window.addEventListener(ADMIN_ACTION_PROMPT_ACTIVATE, ((event: CustomEvent<AdminActionPromptIdDetail>) => {
      const action = adminPromptActions.get(event.detail.id);
      if (!action) return;
      void action().finally(() => adminPromptActions.delete(event.detail.id));
    }) as EventListener);
    window.addEventListener(ADMIN_ACTION_PROMPT_DISMISS, ((event: CustomEvent<AdminActionPromptIdDetail>) => {
      adminPromptActions.delete(event.detail.id);
    }) as EventListener);
  }

  function promptPosition(rect: DOMRect, placement: 'above' | 'below'): Pick<AdminActionPromptDetail, 'top' | 'left'> {
    const width = 352;
    const height = 96;
    const left = Math.min(Math.max(8, rect.left), Math.max(8, window.innerWidth - width - 8));
    const rawTop = placement === 'above' ? rect.top - 56 : rect.bottom + 8;
    const top = Math.min(Math.max(8, rawTop), Math.max(8, window.innerHeight - height - 8));
    return { top, left };
  }

  async function showAdminActionPrompt(detail: AdminActionPromptDetail, action: () => Promise<void>) {
    bindAdminPromptActions();
    adminPromptActions.set(detail.id, action);
    const prompts = await ensureAdminActionPrompts();
    if (!prompts) {
      adminPromptActions.delete(detail.id);
      showToast('Editor prompt unavailable', 'error');
      return;
    }
    window.dispatchEvent(new CustomEvent<AdminActionPromptDetail>(ADMIN_ACTION_PROMPT_SHOW, { detail }));
  }

  function nextPromptId(prefix: string): string {
    return `${prefix}-${Date.now()}-${Math.random().toString(36).slice(2)}`;
  }

  async function openReactSectionSettings(sectionId: number) {
    const controls = await ensureAdminEditorControls();
    if (!controls) {
      showToast('Editor controls unavailable', 'error');
      return;
    }
    controls.openSectionEditControl(sectionId);
  }

  async function openReactZoneAdd(zone: 'header' | 'main' | 'footer') {
    const controls = await ensureAdminEditorControls();
    if (!controls) {
      showToast('Editor controls unavailable', 'error');
      return;
    }
    controls.openZoneAddControl(zone);
  }

  async function openReactNavSettings(sectionId: number) {
    const controls = await ensureAdminEditorControls();
    if (!controls) {
      showToast('Editor controls unavailable', 'error');
      return;
    }
    controls.openNavEditControl(sectionId);
  }

  async function openReactEmbedSettings(sectionId: number) {
    const controls = await ensureAdminEditorControls();
    if (!controls) {
      showToast('Editor controls unavailable', 'error');
      return;
    }
    controls.openEmbedEditControl(sectionId);
  }

  // --- Save animation on element ---
  function flashSave(el: HTMLElement, success: boolean) {
    el.classList.remove('admin-save-success', 'admin-save-error');
    void el.offsetWidth; // force reflow
    el.classList.add(success ? 'admin-save-success' : 'admin-save-error');
    setTimeout(() => el.classList.remove('admin-save-success', 'admin-save-error'), 700);
  }

  // --- Parse data-editable attribute ---
  // Supports: "table.id.field" (flat) or "table.id.column.jsonpath" (JSONB)
  interface EditTarget {
    table: string;
    id: string;
    field: string;
    jsonPath?: string;
  }

  function parseEditTarget(attr: string): EditTarget | null {
    const parts = attr.split('.');
    if (parts.length === 3) {
      return { table: parts[0], id: parts[1], field: parts[2] };
    } else if (parts.length >= 4) {
      // Support nested paths: sections.523.config.items.0.value
      return { table: parts[0], id: parts[1], field: parts[2], jsonPath: parts.slice(3).join('.') };
    }
    return null;
  }

  // --- Nested object set: "items.0.value" → config.items[0].value = newValue ---
  function setNested(obj: any, path: string, value: any) {
    const keys = path.split('.');
    let cur = obj;
    for (let i = 0; i < keys.length - 1; i++) {
      const k = /^\d+$/.test(keys[i]) ? parseInt(keys[i]) : keys[i];
      if (cur[k] === undefined) cur[k] = /^\d+$/.test(keys[i + 1]) ? [] : {};
      cur = cur[k];
    }
    const lastKey = /^\d+$/.test(keys[keys.length - 1]) ? parseInt(keys[keys.length - 1]) : keys[keys.length - 1];
    cur[lastKey] = value;
  }

  // --- Find closest data-editable-config (on self or parent) ---
  function findConfig(el: HTMLElement): { configEl: HTMLElement; config: any } | null {
    let cur: HTMLElement | null = el;
    while (cur) {
      const attr = cur.getAttribute('data-editable-config');
      if (attr) return { configEl: cur, config: JSON.parse(attr) };
      cur = cur.parentElement;
    }
    return null;
  }

  // --- Save helper: handles flat, JSONB, nested JSONB, and site_config ---
  async function saveField(el: HTMLElement, target: EditTarget, newValue: any): Promise<boolean> {
    try {
      if (target.jsonPath) {
        // JSONB: read-modify-write with nested path support
        const found = findConfig(el);
        if (!found) {
          console.error('Missing data-editable-config for JSONB edit');
          return false;
        }
        const { configEl, config } = found;
        setNested(config, target.jsonPath, newValue);
        await patch(`${target.table}?id=eq.${target.id}`, { [target.field]: config });
        configEl.setAttribute('data-editable-config', JSON.stringify(config));
      } else if (target.table === 'site_config') {
        // site_config uses key=eq.{id} instead of id=eq.{id}
        await patch(`site_config?key=eq.${target.id}`, { value: newValue });
      } else {
        await patch(`${target.table}?id=eq.${target.id}`, { [target.field]: newValue });
      }
      if (target.table === 'site_config' || target.table === 'sections' || target.table === 'pages') {
        clearCache('wl_cache_site_config');
      }
      return true;
    } catch (e) {
      console.error('Save failed:', e);
      return false;
    }
  }

  // --- Simple text editing via contenteditable ---
  const boundText = new WeakSet();

  function initEditableText() {
    document.querySelectorAll('[data-editable]').forEach((el) => {
      if (boundText.has(el)) return;
      boundText.add(el);
      const htmlEl = el as HTMLElement;
      htmlEl.setAttribute('data-lpignore', 'true'); // prevent LastPass interference
      let original = '';

      htmlEl.addEventListener('click', (e) => {
        // Don't activate if clicking a link inside
        if ((e.target as HTMLElement).closest('a')) return;
        if (htmlEl.contentEditable === 'true') return; // already editing
        original = htmlEl.textContent?.trim() || '';
        htmlEl.contentEditable = 'true';
        htmlEl.setAttribute('data-lpignore', 'true');
        // Place cursor — first click sets contentEditable but browser already
        // processed the click on a non-editable element, so no cursor appears.
        // Fix by programmatically selecting all text so the user can type.
        requestAnimationFrame(() => {
          htmlEl.focus();
          const sel = window.getSelection();
          if (sel) {
            const range = document.createRange();
            range.selectNodeContents(htmlEl);
            sel.removeAllRanges();
            sel.addRange(range);
          }
        });
      });

      htmlEl.addEventListener('blur', async () => {
        htmlEl.contentEditable = 'false';
        const attr = htmlEl.dataset.editable!;
        const target = parseEditTarget(attr);
        if (!target) return;
        const newText = htmlEl.textContent?.trim() || '';
        if (newText === original) return; // no change
        const ok = await saveField(htmlEl, target, newText);
        if (!ok) htmlEl.textContent = original;
        flashSave(htmlEl, ok);
        if (ok) showToast('Saved');
        else showToast('Save failed', 'error');
      });

      htmlEl.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          htmlEl.blur();
        }
        if (e.key === 'Escape') {
          htmlEl.textContent = original;
          htmlEl.blur();
        }
      });
    });
  }

  // --- Rich text editing via Tiptap ---
  let tiptapLoaded = false;
  let Editor: any, StarterKit: any;

  async function loadTiptap() {
    if (tiptapLoaded) return;
    try {
      const core = await import('https://esm.sh/@tiptap/core@2');
      const starter = await import('https://esm.sh/@tiptap/starter-kit@2');
      Editor = core.Editor;
      StarterKit = starter.default || starter.StarterKit;
      tiptapLoaded = true;
    } catch (e) {
      console.error('Failed to load Tiptap:', e);
    }
  }

  const boundRich = new WeakSet();

  function initEditableRich() {
    document.querySelectorAll('[data-editable-rich]').forEach((el) => {
      if (boundRich.has(el)) return;
      boundRich.add(el);
      const htmlEl = el as HTMLElement;
      htmlEl.setAttribute('data-lpignore', 'true');
      let editor: any = null;

      htmlEl.addEventListener('click', async () => {
        if (editor) return;
        await loadTiptap();
        if (!Editor) return;
        const originalContent = htmlEl.innerHTML;
        htmlEl.classList.add('tiptap-active');
        htmlEl.setAttribute('data-lpignore', 'true');
        // Clear original content — Tiptap will render its own editable copy
        htmlEl.innerHTML = '';

        editor = new Editor({
          element: htmlEl,
          extensions: [StarterKit],
          content: originalContent,
          onBlur: async () => {
            const attr = htmlEl.dataset.editableRich!;
            const target = parseEditTarget(attr);
            if (!target) return;
            const html = editor.getHTML();
            editor.destroy();
            editor = null;
            htmlEl.classList.remove('tiptap-active');
            // Restore rendered content (either saved or original)
            htmlEl.innerHTML = html;
            const ok = await saveField(htmlEl, target, html);
            flashSave(htmlEl, ok);
            if (ok) showToast('Saved');
            else showToast('Save failed', 'error');
          },
        });
      });
    });
  }

  // --- Image editing via click-to-upload (base64 JSON) ---
  const boundImage = new WeakSet();
  let pendingImageTarget: HTMLElement | null = null;
  let boundImageUploadInput: HTMLInputElement | null = null;

  // brand-identity-fields: client-side aspect-ratio check for brand_icon_url
  // uploads. Mirrors functions/upload-asset.js's server-side heuristic. When
  // the uploaded image's intrinsic width exceeds 1.5× its height, we surface a
  // hint offering a one-click reroute to brand_wordmark_url. Hint, not gate —
  // the upload to brand_icon_url still succeeds; admin can dismiss.
  const WORDMARK_ASPECT_THRESHOLD = 1.5;

  async function readImageDimensions(file: File): Promise<{ width: number; height: number } | null> {
    return new Promise((resolve) => {
      const objectUrl = URL.createObjectURL(file);
      const img = new Image();
      img.onload = () => {
        const w = img.naturalWidth || img.width;
        const h = img.naturalHeight || img.height;
        URL.revokeObjectURL(objectUrl);
        if (w > 0 && h > 0) resolve({ width: w, height: h });
        else resolve(null);
      };
      img.onerror = () => {
        URL.revokeObjectURL(objectUrl);
        resolve(null);
      };
      img.src = objectUrl;
    });
  }

  function isBrandIconTarget(target: EditTarget | null): boolean {
    return !!target && target.table === 'site_config' && target.id === 'brand_icon_url';
  }

  function showWordmarkHint(htmlEl: HTMLElement, savedUrl: string, dims: { width: number; height: number }) {
    void showAdminActionPrompt({
      id: nextPromptId('wordmark'),
      message: `This image looks like a wordmark (${dims.width}x${dims.height}). Move it to brand_wordmark_url instead?`,
      actionLabel: 'Move to wordmark',
      dismissLabel: 'Keep in icon slot',
      duration: 12000,
      ...promptPosition(htmlEl.getBoundingClientRect(), 'below'),
    }, async () => {
      try {
        // Reroute: clear the icon slot, set the wordmark slot.
        await Promise.all([
          patch(`site_config?key=eq.brand_icon_url`, { value: '' }),
          patch(`site_config?key=eq.brand_wordmark_url`, { value: savedUrl }),
        ]);
        clearCache('wl_cache_site_config');
        showToast('Saved to brand_wordmark_url');
        // Remove the now-orphan icon image so the chrome re-renders cleanly
        // on next hydration.
        const img = htmlEl.tagName === 'IMG' ? htmlEl as HTMLImageElement : htmlEl.querySelector('img');
        if (img) img.removeAttribute('src');
        emitSectionsChanged();
      } catch (e) {
        console.error('Reroute to wordmark failed:', e);
        showToast('Reroute failed', 'error');
      }
    });
  }

  function imageUploadInput(): HTMLInputElement | null {
    const input = document.getElementById('admin-image-upload-input') as HTMLInputElement | null;
    if (!input) return null;
    if (boundImageUploadInput !== input) {
      input.addEventListener('change', async () => {
        const file = input.files?.[0] || null;
        const htmlEl = pendingImageTarget;
        pendingImageTarget = null;
        input.value = '';
        if (!file || !htmlEl) return;
        await uploadEditableImage(htmlEl, file);
      });
      boundImageUploadInput = input;
    }
    return input;
  }

  async function uploadEditableImage(htmlEl: HTMLElement, file: File) {
    // Show upload state
    htmlEl.classList.add('uploading');

    try {
      const attr = htmlEl.dataset.editableImage!;
      const target = parseEditTarget(attr);

      // Read dimensions in parallel with the upload — it's a hint, so we
      // don't block the upload on it. (Failures are silent.)
      const dimsPromise = isBrandIconTarget(target)
        ? readImageDimensions(file).catch(() => null)
        : Promise.resolve(null);

      // Upload via Run402's content-addressed flow.
      const { url } = await uploadFileContentAddressed(file, {
        keyPrefix: 'assets',
        authToken: getToken(),
      });

      // Update the image element
      const img = htmlEl.tagName === 'IMG' ? htmlEl as HTMLImageElement : htmlEl.querySelector('img');
      if (img) img.src = url;

      // Save URL to database
      if (target) {
        await saveField(htmlEl, target, url);
      }
      showToast('Image uploaded');

      // brand_icon_url aspect-ratio hint (client-side mirror of the
      // server-side check in functions/upload-asset.js). Surfaces only
      // when uploading to the icon slot AND the image is much wider
      // than tall.
      const dims = await dimsPromise;
      if (
        isBrandIconTarget(target) &&
        dims &&
        dims.width > WORDMARK_ASPECT_THRESHOLD * dims.height
      ) {
        showWordmarkHint(htmlEl, url, dims);
      }
    } catch (e) {
      console.error('Image upload error:', e);
      showToast('Upload failed', 'error');
    } finally {
      htmlEl.classList.remove('uploading');
    }
  }

  function initEditableImage() {
    document.querySelectorAll('[data-editable-image]').forEach((el) => {
      if (boundImage.has(el)) return;
      boundImage.add(el);
      const htmlEl = el as HTMLElement;

      htmlEl.addEventListener('click', (e) => {
        // Don't trigger image upload if clicking a child text-editable element
        const target = e.target as HTMLElement;
        if (target.closest('[data-editable]') || target.closest('[data-editable-rich]')) return;
        const input = imageUploadInput();
        if (!input) {
          showToast('Image upload unavailable', 'error');
          return;
        }
        pendingImageTarget = htmlEl;
        input.value = '';
        input.click();
      });
    });
  }

  // --- Drag-to-reorder (document-level, supports cross-zone) ---
  // composable-layout: one document-level handler. Source zone is determined
  // from `closest('[data-zone]')`; target zone the same. Cross-zone drops PATCH
  // both `zone` and `position` together. Empty zones acquire a "Drop here"
  // placeholder via the body.admin-dragging class (CSS rule below).
  let draggedEl: HTMLElement | null = null;
  let dropIndicator: HTMLElement | null = null;
  let sourceZone: string | null = null;

  function indicatorHost(): HTMLElement | null {
    return document.getElementById('admin-editor-root');
  }

  function getDropIndicator(): HTMLElement | null {
    dropIndicator ??= document.getElementById('admin-editor-drop-indicator');
    return dropIndicator;
  }

  function ensureIndicator(): HTMLElement | null {
    const indicator = getDropIndicator();
    if (!indicator) return null;
    // column-span-rows: indicator width tracks the dragged block's span so the
    // preview matches what'll actually land. Default to '1' when nothing is
    // being dragged or the dragged block has no span attribute.
    const span = draggedEl?.getAttribute('data-column-span') || '1';
    indicator.setAttribute('data-column-span', span);
    indicator.hidden = false;
    return indicator;
  }

  function moveIndicatorToEnd(host: HTMLElement, indicator: HTMLElement): void {
    if (indicator.parentElement === host && indicator === host.lastElementChild) return;
    const last = host.lastElementChild as HTMLElement | null;
    if (last && last !== indicator) {
      last.after(indicator);
      return;
    }
    host.replaceChildren(indicator);
  }

  function findZoneContainer(el: Element | null): HTMLElement | null {
    if (!el) return null;
    return (el.closest('[data-zone]') as HTMLElement | null);
  }

  function findZoneItemHost(zone: HTMLElement): HTMLElement {
    // Header / footer: the inner .ky-container holds blocks. Main: the #sections
    // child or the page <main> itself.
    const inner = zone.querySelector(':scope > .ky-container') as HTMLElement | null;
    if (inner) return inner;
    const sections = zone.querySelector('#sections') as HTMLElement | null;
    if (sections) return sections;
    return zone;
  }

  function bindDragHandle(handle: HTMLElement) {
    if (handle.dataset.adminDragBound === 'true') return;
    const el = handle.closest('[data-sortable-id]') as HTMLElement | null;
    if (!el) return;
    handle.dataset.adminDragBound = 'true';
    handle.setAttribute('aria-label', 'Drag to reorder');
    handle.textContent = '☰';
    handle.addEventListener('dragstart', (e) => {
      draggedEl = el;
      const zone = findZoneContainer(el);
      sourceZone = zone?.dataset.zone || null;
      document.body.classList.add('admin-dragging');
      el.classList.add('dragging');
      e.dataTransfer!.effectAllowed = 'move';
      e.dataTransfer!.setData('text/plain', el.dataset.sortableId || '');
    });
  }

  function bindSortableHandles() {
    document.querySelectorAll<HTMLElement>('[data-admin-drag-handle]').forEach(bindDragHandle);
  }

  function initSortable() {
    bindSortableHandles();
    if ((document as any).__sortableDocBound) return;
    (document as any).__sortableDocBound = true;

    document.addEventListener('dragover', (e) => {
      if (!draggedEl) return;
      const target = e.target as HTMLElement | null;
      const zone = findZoneContainer(target);
      if (!zone) return;
      e.preventDefault();
      (e as DragEvent).dataTransfer!.dropEffect = 'move';

      const indicator = ensureIndicator();
      if (!indicator) return;
      const itemHost = findZoneItemHost(zone);
      const overItem = (target?.closest('[data-sortable-id]') as HTMLElement | null);
      if (overItem && overItem !== draggedEl && itemHost.contains(overItem)) {
        const rect = overItem.getBoundingClientRect();
        const midY = rect.top + rect.height / 2;
        if ((e as DragEvent).clientY < midY) overItem.before(indicator);
        else overItem.after(indicator);
      } else if (itemHost.children.length === 0 || (itemHost.children.length === 1 && itemHost.contains(indicator))) {
        moveIndicatorToEnd(itemHost, indicator);
      } else {
        const last = itemHost.lastElementChild as HTMLElement | null;
        if (last && last !== indicator) {
          last.after(indicator);
        }
      }
    });

    document.addEventListener('drop', async (e) => {
      if (!draggedEl) return;
      const targetZoneEl = findZoneContainer(e.target as HTMLElement | null);
      const indicator = dropIndicator;
      if (!targetZoneEl || !indicator || !indicator.parentElement) {
        cleanupDrag();
        return;
      }
      e.preventDefault();
      const targetZone = targetZoneEl.dataset.zone!;
      indicator.replaceWith(draggedEl);
      const moved = draggedEl;
      const wasCrossZone = sourceZone !== targetZone;
      cleanupDrag();
      await persistOrder(moved, sourceZone || 'main', targetZone);
      if (wasCrossZone) maybeOfferGlobalPromotion(moved, targetZone as 'header' | 'main' | 'footer');
    });

    document.addEventListener('dragend', cleanupDrag);
  }

  function cleanupDrag() {
    if (draggedEl) draggedEl.classList.remove('dragging');
    const indicator = getDropIndicator();
    if (indicator) {
      indicator.hidden = true;
      const host = indicatorHost();
      if (host) moveIndicatorToEnd(host, indicator);
    }
    document.body.classList.remove('admin-dragging');
    draggedEl = null;
    sourceZone = null;
  }

  async function persistOrder(moved: HTMLElement, fromZone: string, toZone: string) {
    const targetZoneEl = findZoneContainer(moved);
    if (!targetZoneEl) return;
    const targetHost = findZoneItemHost(targetZoneEl);
    const targetSiblings = Array.from(targetHost.querySelectorAll<HTMLElement>('[data-sortable-id]'));
    const updates: Promise<any>[] = [];
    targetSiblings.forEach((sib, idx) => {
      const sid = sib.dataset.sortableId;
      if (!sid) return;
      const [table, id] = sid.split('.');
      if (!table || !id) return;
      const body: Record<string, any> = { position: idx + 1 };
      if (sib === moved && fromZone !== toZone) body.zone = toZone;
      updates.push(patch(`${table}?id=eq.${id}`, body));
    });
    // Renumber source zone too (close the gap left behind)
    if (fromZone !== toZone) {
      const sourceZoneEl = document.querySelector(`[data-zone="${fromZone}"]`) as HTMLElement | null;
      if (sourceZoneEl) {
        const sourceHost = findZoneItemHost(sourceZoneEl);
        Array.from(sourceHost.querySelectorAll<HTMLElement>('[data-sortable-id]')).forEach(
          (sib, idx) => {
            const sid = sib.dataset.sortableId;
            if (!sid) return;
            const [table, id] = sid.split('.');
            if (!table || !id) return;
            updates.push(patch(`${table}?id=eq.${id}`, { position: idx + 1 }));
          },
        );
      }
    }
    try {
      await Promise.all(updates);
      // Bust caches so subsequent navigations see the new order/zone.
      Object.keys(localStorage)
        .filter((k) => k.startsWith('wl_cache_sections_'))
        .forEach((k) => localStorage.removeItem(k));
      showToast('Order saved');
      emitSectionsChanged();
    } catch (e) {
      console.error('Failed to persist order:', e);
      showToast('Save failed', 'error');
    }
  }

  function maybeOfferGlobalPromotion(moved: HTMLElement, targetZone: 'header' | 'main' | 'footer') {
    if (targetZone !== 'header' && targetZone !== 'footer') return;
    const sid = moved.dataset.sortableId;
    if (!sid) return;
    const [table, id] = sid.split('.');
    if (table !== 'sections' || !id) return;
    // Look up scope from the row.
    get(`sections?id=eq.${id}&select=scope`).then((rows: any[]) => {
      const scope = rows[0]?.scope || 'page';
      if (scope === 'global') return;
      showPromotionTooltip(moved, parseInt(id, 10));
    }).catch(() => {});
  }

  function showPromotionTooltip(target: HTMLElement, sectionId: number) {
    void showAdminActionPrompt({
      id: nextPromptId('promote'),
      message: 'This now appears here only.',
      actionLabel: 'Make global',
      duration: 5000,
      ...promptPosition(target.getBoundingClientRect(), 'above'),
    }, async () => {
      try {
        await patch(`sections?id=eq.${sectionId}`, { scope: 'global' });
        Object.keys(localStorage)
          .filter((k) => k.startsWith('wl_cache_sections_'))
          .forEach((k) => localStorage.removeItem(k));
        showToast('Saved — appears on all pages');
        emitSectionsChanged();
      } catch (e) {
        console.error('Promotion failed:', e);
        showToast('Save failed', 'error');
      }
    });
  }

  // --- Navigation block editor trigger ---
  function initNavEditor() {
    if ((document.body as any).__navEditorBound) return;
    (document.body as any).__navEditorBound = true;
    document.addEventListener('click', (event) => {
      const target = event.target as HTMLElement | null;
      const button = target?.closest('[data-nav-edit]') as HTMLElement | null;
      if (!button) return;
      event.preventDefault();
      const sectionId = parseInt(button.dataset.navEdit || '', 10);
      if (Number.isFinite(sectionId)) void openReactNavSettings(sectionId);
    });
  }


  // --- Section actions: remove / scope-toggle / add-section (delegated) ---
  function initSectionActions() {
    if ((document.body as any).__sectionActionsBound) return;
    (document.body as any).__sectionActionsBound = true;

    document.addEventListener('click', async (e) => {
      const t = e.target as HTMLElement | null;
      if (!t) return;

      // Remove section
      const removeBtn = t.closest('[data-section-remove]') as HTMLElement | null;
      if (removeBtn) {
        e.preventDefault();
        const id = removeBtn.dataset.sectionRemove;
        if (!id) return;
        if (!confirm('Remove this section?')) return;
        try {
          await del(`sections?id=eq.${id}`);
          Object.keys(localStorage)
            .filter((k) => k.startsWith('wl_cache_sections_'))
            .forEach((k) => localStorage.removeItem(k));
          removeBtn.closest('[data-sortable-id]')?.remove();
          showToast('Section removed');
          emitSectionsChanged();
        } catch (err) {
          console.error('Failed to remove section:', err);
          showToast('Remove failed', 'error');
        }
        return;
      }

      // Scope toggle
      const scopeBtn = t.closest('[data-scope-toggle]') as HTMLElement | null;
      if (scopeBtn) {
        e.preventDefault();
        const id = scopeBtn.dataset.scopeToggle;
        const next = scopeBtn.dataset.scopeNext as 'page' | 'global' | undefined;
        if (!id || !next) return;
        try {
          await patch(`sections?id=eq.${id}`, { scope: next });
          Object.keys(localStorage)
            .filter((k) => k.startsWith('wl_cache_sections_'))
            .forEach((k) => localStorage.removeItem(k));
          showToast(next === 'global' ? 'Saved — appears on all pages' : 'Saved — appears on this page only');
          emitSectionsChanged();
        } catch (err) {
          console.error('Scope toggle failed:', err);
          showToast('Save failed', 'error');
        }
        return;
      }

      // Add section in zone
      const addBtn = t.closest('[data-zone-add]') as HTMLElement | null;
      if (addBtn) {
        e.preventDefault();
        const zone = addBtn.dataset.zoneAdd as 'header' | 'main' | 'footer' | undefined;
        if (!zone) return;
        void openReactZoneAdd(zone);
        return;
      }

      // column-span-rows: per-block edit popover (span radio + scope + remove)
      const editBtn = t.closest('[data-section-edit]') as HTMLElement | null;
      if (editBtn) {
        e.preventDefault();
        const id = parseInt(editBtn.dataset.sectionEdit || '', 10);
        if (Number.isFinite(id)) openSectionEditPopover(id);
        return;
      }
    });
  }

  // --- Embed block editor trigger ---
  function initEmbedEditor() {
    if ((document.body as any).__embedEditorBound) return;
    (document.body as any).__embedEditorBound = true;
    document.addEventListener('click', (e) => {
      const t = e.target as HTMLElement | null;
      const btn = t?.closest('[data-embed-edit]') as HTMLElement | null;
      if (!btn) return;
      e.preventDefault();
      e.stopPropagation();
      const sid = parseInt(btn.dataset.embedEdit || '', 10);
      if (Number.isFinite(sid)) void openReactEmbedSettings(sid);
    });
  }


  async function openSectionEditPopover(sectionId: number) {
    await openReactSectionSettings(sectionId);
  }


  // --- Main init ---
  async function initAdminEditor() {
    await ready;
    await refreshMemberRecord();
    const session = JSON.parse(localStorage.getItem('wl_session') || 'null');
    if (session?.user?.member?.role !== 'admin') return;
    document.body.classList.add('admin');
    void ensureAdminEditorControls();
    void ensureAdminActionPrompts();
    initEditableText();
    initEditableRich();
    initEditableImage();
    initSortable();
    initNavEditor();
    initEmbedEditor();
    initSectionActions();
    // composable-layout: brand logo and nav are now blocks rendered with
    // their own data-editable / data-editable-image attributes — no extra
    // wiring needed here.
  }

  // Use MutationObserver to re-bind after client-side renders
  const observer = new MutationObserver((mutations) => {
    if (!document.body.classList.contains('admin')) return;
    let shouldRebind = false;
    for (const m of mutations) {
      if (m.type === 'childList' && m.addedNodes.length > 0) {
        for (const node of m.addedNodes) {
          if (node instanceof HTMLElement && (
            node.querySelector('[data-editable]') ||
            node.querySelector('[data-editable-rich]') ||
            node.querySelector('[data-editable-image]') ||
            node.querySelector('[data-sortable-id]') ||
            node.hasAttribute?.('data-editable') ||
            node.hasAttribute?.('data-editable-rich') ||
            node.hasAttribute?.('data-editable-image') ||
            node.hasAttribute?.('data-sortable-id')
          )) {
            shouldRebind = true;
            break;
          }
        }
      }
      if (shouldRebind) break;
    }
    if (shouldRebind) {
      initEditableText();
      initEditableRich();
      initEditableImage();
      initSortable();
    }
  });

  observer.observe(document.body, { childList: true, subtree: true });

  initAdminEditor();
  document.addEventListener('astro:after-swap', initAdminEditor);
</script>
