---
const {
  title = 'Checking access',
  body = 'Confirming your admin session.',
} = Astro.props;
---
<div class="ky-container admin-access-check" data-admin-access-checking role="status" aria-live="polite">
  <div class="card admin-access-check__card">
    <div class="admin-access-check__spinner" aria-hidden="true"></div>
    <div>
      <h2>{title}</h2>
      <p class="ky-text-muted">{body}</p>
    </div>
  </div>
</div>
