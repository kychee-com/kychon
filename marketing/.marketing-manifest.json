\">\\\\n          <div class=\\\\\\\"plan-card__name\\\\\\\">Lychee Pro</div>\\\\n          <div class=\\\\\\\"plan-card__price\\\\\\\">$9&ndash;29/mo</div>\\\\n          <div class=\\\\\\\"plan-card__price-sub\\\\\\\">ongoing, cancel anytime</div>\\\\n          <div class=\\\\\\\"plan-card__desc\\\\\\\">\\\\\\\"Your portal evolves with you.\\\\\\\"</div>\\\\n          <ul class=\\\\\\\"plan-card__features\\\\\\\">\\\\n            <li>Ongoing AI customization agent</li>\\\\n            <li>Feature requests via chat</li>\\\\n            <li>Priority support</li>\\\\n            <li>Advanced analytics</li>\\\\n          </ul>\\\\n          <a href=\\\\\\\"#demo-placeholder\\\\\\\" class=\\\\\\\"btn btn--outline\\\\\\\">Learn More</a>\\\\n        </div>\\\\n      </div>\\\\n    </div>\\\\n  </section>\\\\n\\\\n  <!-- ======== FINAL CTA ======== -->\\\\n  <section class=\\\\\\\"section section--indigo final-cta\\\\\\\">\\\\n    <div class=\\\\\\\"container\\\\\\\">\\\\n      <h2 class=\\\\\\\"t-display t-display--lg\\\\\\\">Give your congregation the home they deserve.</h2>\\\\n      <p class=\\\\\\\"t-body--lg\\\\\\\">Open source. Flat pricing. AI-powered. Yours forever.</p>\\\\n      <div class=\\\\\\\"final-cta__buttons\\\\\\\">\\\\n        <a href=\\\\\\\"#demo-placeholder\\\\\\\" class=\\\\\\\"btn btn--white btn--lg\\\\\\\">Build Your Church Portal &rarr;</a>\\\\n        <a href=\\\\\\\"https://github.com/kychee-com/wildlychee\\\\\\\" class=\\\\\\\"btn btn--outline btn--lg\\\\\\\" style=\\\\\\\"border-color:#fff;color:#fff\\\\\\\" target=\\\\\\\"_blank\\\\\\\">Fork on GitHub</a>\\\\n      </div>\\\\n    </div>\\\\n  </section>\\\\n\\\\n  <!-- ======== FOOTER ======== -->\\\\n  <footer class=\\\\\\\"footer\\\\\\\">\\\\n    <div class=\\\\\\\"container\\\\\\\">\\\\n      <p>\\\\n        <strong>Wild Lychee</strong> is open source. Built on <a href=\\\\\\\"https://run402.com\\\\\\\" target=\\\\\\\"_blank\\\\\\\">Run402</a>.\\\\n        &ensp;&middot;&ensp;\\\\n        <a href=\\\\\\\"https://github.com/kychee-com/wildlychee\\\\\\\" target=\\\\\\\"_blank\\\\\\\">GitHub</a>\\\\n        &ensp;&middot;&ensp;\\\\n        <a href=\\\\\\\"https://eagles.run402.com\\\\\\\" target=\\\\\\\"_blank\\\\\\\">Eagles Demo</a>\\\\n      </p>\\\\n    </div>\\\\n  </footer>\\\\n\\\\n  <!-- Mobile nav toggle -->\\\\n  <script>\\\\n    document.getElementById('nav-toggle')?.addEventListener('click', () => {\\\\n      document.getElementById('nav-links')?.classList.toggle('open');\\\\n    });\\\\n  </script>\\\\n\\\\n</body>\\\\n</html>\\\\n\\\"\\n    },\\n    {\\n      \\\"file\\\": \\\"css/marketing.css\\\",\\n      \\\"data\\\": \\\"/* ============================================\\\\n   Wild Lychee Marketing — Editorial Indie\\\\n   ============================================ */\\\\n\\\\n@import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Instrument+Serif:ital@0;1&display=swap');\\\\n\\\\n/* --- Tokens --- */\\\\n:root {\\\\n  --ink: #1a1625;\\\\n  --ink-muted: #6b6680;\\\\n  --ink-subtle: #9994a8;\\\\n  --cream: #faf7f2;\\\\n  --cream-dark: #f0ebe3;\\\\n  --indigo: #4338ca;\\\\n  --indigo-light: #6366f1;\\\\n  --indigo-dark: #3730a3;\\\\n  --indigo-wash: #eef2ff;\\\\n  --coral: #f97316;\\\\n  --coral-light: #fb923c;\\\\n  --green: #16a34a;\\\\n  --green-wash: #dcfce7;\\\\n  --red-wash: #fee2e2;\\\\n  --red-muted: #b91c1c;\\\\n  --font-display: 'Instrument Serif', Georgia, serif;\\\\n  --font-body: 'DM Sans', -apple-system, sans-serif;\\\\n  --max-w: 72rem;\\\\n  --ease: cubic-bezier(0.16, 1, 0.3, 1);\\\\n}\\\\n\\\\n/* --- Reset --- */\\\\n*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\\\\n\\\\nhtml { scroll-behavior: smooth; }\\\\n\\\\nbody {\\\\n  font-family: var(--font-body);\\\\n  color: var(--ink);\\\\n  background: var(--cream);\\\\n  line-height: 1.65;\\\\n  -webkit-font-smoothing: antialiased;\\\\n  overflow-x: hidden;\\\\n}\\\\n\\\\nimg { max-width: 100%; display: block; }\\\\na { color: inherit; text-decoration: none; }\\\\n\\\\n/* --- Layout --- */\\\\n.container {\\\\n  max-width: var(--max-w);\\\\n  margin: 0 auto;\\\\n  padding: 0 2rem;\\\\n}\\\\n\\\\n.section {\\\\n  padding: 7rem 0;\\\\n  position: relative;\\\\n}\\\\n\\\\n.section--cream { background: var(--cream); }\\\\n.section--white { background: #fff; }\\\\n.section--ink {\\\\n  background: var(--ink);\\\\n  color: #fff;\\\\n}\\\\n.section--indigo {\\\\n  background: var(--indigo);\\\\n  color: #fff;\\\\n}\\\\n\\\\n/* Dot-grid texture overlay */\\\\n.section--dotted::before {\\\\n  content: '';\\\\n  position: absolute;\\\\n  inset: 0;\\\\n  background-image: radial-gradient(circle, var(--ink) 0.5px, transparent 0.5px);\\\\n  background-size: 24px 24px;\\\\n  opacity: 0.04;\\\\n  pointer-events: none;\\\\n}\\\\n\\\\n/* Angled divider */\\\\n.slash {\\\\n  position: relative;\\\\n}\\\\n.slash::after {\\\\n  content: '';\\\\n  position: absolute;\\\\n  bottom: -2rem;\\\\n  left: 0;\\\\n  right: 0;\\\\n  height: 4rem;\\\\n  background: inherit;\\\\n  clip-path: polygon(0 0, 100% 0, 100% 30%, 0 100%);\\\\n  z-index: 2;\\\\n}\\\\n\\\\n/* --- Typography --- */\\\\n.t-display {\\\\n  font-family: var(--font-display);\\\\n  font-weight: 400;\\\\n  line-height: 1.1;\\\\n  letter-spacing: -0.02em;\\\\n}\\\\n\\\\n.t-display--xl { font-size: clamp(2.75rem, 6vw, 4.5rem); }\\\\n.t-display--lg { font-size: clamp(2rem, 4vw, 3rem); }\\\\n.t-display--md { font-size: clamp(1.5rem, 3vw, 2.25rem); }\\\\n\\\\n.t-overline {\\\\n  font-family: var(--font-body);\\\\n  font-size: 0.8125rem;\\\\n  font-weight: 600;\\\\n  letter-spacing: 0.1em;\\\\n  text-transform: uppercase;\\\\n  color: var(--indigo);\\\\n}\\\\n\\\\n.t-body { font-size: 1.125rem; color: var(--ink-muted); }\\\\n.t-body--lg { font-size: 1.25rem; color: var(--ink-muted); max-width: 38rem; }\\\\n.t-body--sm { font-size: 0.9375rem; color: var(--ink-muted); }\\\\n\\\\n.t-italic { font-style: italic; }\\\\n\\\\n/* --- Nav --- */\\\\n.nav {\\\\n  position: sticky;\\\\n  top: 0;\\\\n  z-index: 100;\\\\n  background: rgba(250, 247, 242, 0.9);\\\\n  backdrop-filter: blur(12px);\\\\n  -webkit-backdrop-filter: blur(12px);\\\\n  border-bottom: 1px solid rgba(26, 22, 37, 0.06);\\\\n  padding: 0.875rem 0;\\\\n}\\\\n\\\\n.nav__inner {\\\\n  display: flex;\\\\n  align-items: center;\\\\n  gap: 2rem;\\\\n}\\\\n\\\\n.nav__brand {\\\\n  font-family: var(--font-display);\\\\n  font-size: 1.375rem;\\\\n  color: var(--ink);\\\\n  display: flex;\\\\n  align-items: center;\\\\n  gap: 0.5rem;\\\\n  flex-shrink: 0;\\\\n}\\\\n\\\\n.nav__brand-icon {\\\\n  width: 1.75rem;\\\\n  height: 1.75rem;\\\\n  background: var(--indigo);\\\\n  border-radius: 6px;\\\\n  display: flex;\\\\n  align-items: center;\\\\n  justify-content: center;\\\\n  color: #fff;\\\\n  font-size: 1rem;\\\\n  transform: rotate(-6deg);\\\\n}\\\\n\\\\n.nav__links {\\\\n  display: flex;\\\\n  align-items: center;\\\\n  gap: 0.25rem;\\\\n  margin-left: auto;\\\\n}\\\\n\\\\n.nav__link {\\\\n  padding: 0.375rem 0.75rem;\\\\n  font-size: 0.875rem;\\\\n  font-weight: 500;\\\\n  color: var(--ink-muted);\\\\n  border-radius: 6px;\\\\n  transition: color 0.2s, background 0.2s;\\\\n}\\\\n\\\\n.nav__link:hover {\\\\n  color: var(--ink);\\\\n  background: rgba(0,0,0,0.04);\\\\n}\\\\n\\\\n.nav__cta {\\\\n  margin-left: 0.5rem;\\\\n}\\\\n\\\\n.nav__toggle {\\\\n  display: none;\\\\n  background: none;\\\\n  border: none;\\\\n  font-size: 1.5rem;\\\\n  cursor: pointer;\\\\n  color: var(--ink);\\\\n  padding: 0.25rem;\\\\n  margin-left: auto;\\\\n}\\\\n\\\\n/* --- Buttons --- */\\\\n.btn {\\\\n  display: inline-flex;\\\\n  align-items: center;\\\\n  gap: 0.5rem;\\\\n  padding: 0.75rem 1.5rem;\\\\n  border-radius: 8px;\\\\n  font-family: var(--font-body);\\\\n  font-size: 0.9375rem;\\\\n  font-weight: 600;\\\\n  border: none;\\\\n  cursor: pointer;\\\\n  transition: transform 0.15s var(--ease), box-shadow 0.2s, background 0.2s;\\\\n  text-decoration: none;\\\\n}\\\\n.btn:active { transform: scale(0.97); }\\\\n\\\\n.btn--primary {\\\\n  background: var(--indigo);\\\\n  color: #fff;\\\\n  box-shadow: 0 1px 3px rgba(67, 56, 202, 0.3);\\\\n}\\\\n.btn--primary:hover {\\\\n  background: var(--indigo-dark);\\\\n  box-shadow: 0 4px 12px rgba(67, 56, 202, 0.3);\\\\n}\\\\n\\\\n.btn--outline {\\\\n  background: transparent;\\\\n  color: var(--ink);\\\\n  border: 1.5px solid var(--ink);\\\\n}\\\\n.btn--outline:hover {\\\\n  background: var(--ink);\\\\n  color: var(--cream);\\\\n}\\\\n\\\\n.btn--ghost {\\\\n  background: transparent;\\\\n  color: var(--indigo);\\\\n  padding: 0.75rem 1rem;\\\\n}\\\\n.btn--ghost:hover {\\\\n  background: var(--indigo-wash);\\\\n}\\\\n\\\\n.btn--coral {\\\\n  background: var(--coral);\\\\n  color: #fff;\\\\n}\\\\n.btn--coral:hover {\\\\n  background: var(--coral-light);\\\\n}\\\\n\\\\n.btn--white {\\\\n  background: #fff;\\\\n  color: var(--indigo);\\\\n}\\\\n.btn--white:hover {\\\\n  background: var(--cream);\\\\n}\\\\n\\\\n.btn--lg {\\\\n  padding: 1rem 2rem;\\\\n  font-size: 1.0625rem;\\\\n  border-radius: 10px;\\\\n}\\\\n\\\\n/* --- Hero --- */\\\\n.hero {\\\\n  padding: 8rem 0 6rem;\\\\n  position: relative;\\\\n}\\\\n\\\\n.hero__content {\\\\n  max-width: 48rem;\\\\n}\\\\n\\\\n.hero__headline {\\\\n  margin-bottom: 1.5rem;\\\\n}\\\\n\\\\n.hero__headline em {\\\\n  color: var(--coral);\\\\n  font-style: normal;\\\\n  text-decoration: underline;\\\\n  text-decoration-color: var(--coral);\\\\n  text-underline-offset: 4px;\\\\n  text-decoration-thickness: 3px;\\\\n}\\\\n\\\\n.hero__sub {\\\\n  margin-bottom: 2.5rem;\\\\n}\\\\n\\\\n.hero__ctas {\\\\n  display: flex;\\\\n  flex-wrap: wrap;\\\\n  gap: 0.75rem;\\\\n}\\\\n\\\\n.hero__aside {\\\\n  position: absolute;\\\\n  right: 2rem;\\\\n  top: 50%;\\\\n  transform: translateY(-50%);\\\\n  width: 20rem;\\\\n  height: 20rem;\\\\n  background: var(--indigo-wash);\\\\n  border-radius: 50%;\\\\n  opacity: 0.5;\\\\n  filter: blur(60px);\\\\n  pointer-events: none;\\\\n}\\\\n\\\\n/* --- Problem cards --- */\\\\n.problem-grid {\\\\n  display: grid;\\\\n  grid-template-columns: repeat(3, 1fr);\\\\n  gap: 1.5rem;\\\\n  margin-bottom: 4rem;\\\\n}\\\\n\\\\n.problem-card {\\\\n  background: #fff;\\\\n  border: 1px solid rgba(0,0,0,0.06);\\\\n  border-radius: 12px;\\\\n  padding: 2rem;\\\\n  position: relative;\\\\n  overflow: hidden;\\\\n}\\\\n\\\\n.problem-card::before {\\\\n  content: '';\\\\n  position: absolute;\\\\n  top: 0;\\\\n  left: 0;\\\\n  right: 0;\\\\n  height: 3px;\\\\n  background: var(--red-muted);\\\\n  opacity: 0.6;\\\\n}\\\\n\\\\n.problem-card__name {\\\\n  font-weight: 700;\\\\n  font-size: 0.875rem;\\\\n  color: var(--red-muted);\\\\n  text-transform: uppercase;\\\\n  letter-spacing: 0.05em;\\\\n  margin-bottom: 0.75rem;\\\\n}\\\\n\\\\n.problem-card__price {\\\\n  font-family: var(--font-display);\\\\n  font-size: 1.75rem;\\\\n  line-height: 1.2;\\\\n  margin-bottom: 0.5rem;\\\\n}\\\\n\\\\n.problem-card__desc {\\\\n  font-size: 0.9375rem;\\\\n  color: var(--ink-muted);\\\\n  font-style: italic;\\\\n}\\\\n\\\\n.problem-transition {\\\\n  text-align: center;\\\\n  max-width: 36rem;\\\\n  margin: 0 auto;\\\\n}\\\\n\\\\n.problem-transition__what-if {\\\\n  font-family: var(--font-display);\\\\n  font-size: 2rem;\\\\n  font-style: italic;\\\\n  color: var(--indigo);\\\\n  margin-bottom: 1rem;\\\\n}\\\\n\\\\n/* --- Feature grid --- */\\\\n.feature-grid {\\\\n  display: grid;\\\\n  grid-template-columns: repeat(4, 1fr);\\\\n  gap: 1.25rem;\\\\n}\\\\n\\\\n.feature-card {\\\\n  background: #fff;\\\\n  border: 1px solid rgba(0,0,0,0.06);\\\\n  border-radius: 12px;\\\\n  padding: 1.75rem;\\\\n  transition: transform 0.2s var(--ease), box-shadow 0.2s;\\\\n}\\\\n\\\\n.feature-card:hover {\\\\n  transform: translateY(-2px);\\\\n  box-shadow: 0 8px 24px rgba(0,0,0,0.06);\\\\n}\\\\n\\\\n.feature-card__icon {\\\\n  font-size: 1.75rem;\\\\n  margin-bottom: 0.75rem;\\\\n}\\\\n\\\\n.feature-card__name {\\\\n  font-weight: 700;\\\\n  font-size: 1rem;\\\\n  margin-bottom: 0.375rem;\\\\n}\\\\n\\\\n.feature-card__desc {\\\\n  font-size: 0.875rem;\\\\n  color: var(--ink-muted);\\\\n  line-height: 1.5;\\\\n}\\\\n\\\\n/* --- AI section --- */\\\\n.ai-section {\\\\n  background: var(--ink);\\\\n  color: #fff;\\\\n  position: relative;\\\\n  overflow: hidden;\\\\n}\\\\n\\\\n.ai-section .t-overline { color: var(--coral-light); }\\\\n.ai-section .t-body--lg { color: rgba(255,255,255,0.6); }\\\\n\\\\n.ai-grid {\\\\n  display: grid;\\\\n  grid-template-columns: repeat(3, 1fr);\\\\n  gap: 1.25rem;\\\\n  margin-bottom: 2rem;\\\\n}\\\\n\\\\n.ai-card {\\\\n  background: rgba(255,255,255,0.06);\\\\n  border: 1px solid rgba(255,255,255,0.08);\\\\n  border-radius: 12px;\\\\n  padding: 1.75rem;\\\\n  transition: background 0.2s;\\\\n}\\\\n\\\\n.ai-card:hover {\\\\n  background: rgba(255,255,255,0.1);\\\\n}\\\\n\\\\n.ai-card__icon {\\\\n  font-size: 1.5rem;\\\\n  margin-bottom: 0.75rem;\\\\n}\\\\n\\\\n.ai-card__name {\\\\n  font-weight: 700;\\\\n  font-size: 1rem;\\\\n  margin-bottom: 0.375rem;\\\\n}\\\\n\\\\n.ai-card__desc {\\\\n  font-size: 0.875rem;\\\\n  color: rgba(255,255,255,0.55);\\\\n  line-height: 1.5;\\\\n}\\\\n\\\\n.ai-byok {\\\\n  display: inline-flex;\\\\n  align-items: center;\\\\n  gap: 0.5rem;\\\\n  background: rgba(255,255,255,0.06);\\\\n  border: 1px solid rgba(255,255,255,0.1);\\\\n  border-radius: 8px;\\\\n  padding: 0.75rem 1.25rem;\\\\n  font-size: 0.875rem;\\\\n  color: rgba(255,255,255,0.7);\\\\n}\\\\n\\\\n/* Background glow */\\\\n.ai-section::before {\\\\n  content: '';\\\\n  position: absolute;\\\\n  top: -10rem;\\\\n  right: -10rem;\\\\n  width: 30rem;\\\\n  height: 30rem;\\\\n  background: radial-gradient(circle, var(--indigo) 0%, transparent 70%);\\\\n  opacity: 0.15;\\\\n  pointer-events: none;\\\\n}\\\\n\\\\n/* --- Showcase gallery --- */\\\\n.showcase-grid {\\\\n  display: grid;\\\\n  grid-template-columns: repeat(3, 1fr);\\\\n  gap: 1.5rem;\\\\n}\\\\n\\\\n.showcase-card {\\\\n  border-radius: 12px;\\\\n  overflow: hidden;\\\\n  border: 1px solid rgba(0,0,0,0.08);\\\\n  background: #fff;\\\\n  transition: transform 0.2s var(--ease), box-shadow 0.2s;\\\\n}\\\\n\\\\n.showcase-card:hover {\\\\n  transform: translateY(-3px);\\\\n  box-shadow: 0 12px 32px rgba(0,0,0,0.08);\\\\n}\\\\n\\\\n.showcase-card__preview {\\\\n  height: 12rem;\\\\n  display: flex;\\\\n  align-items: center;\\\\n  justify-content: center;\\\\n  font-family: var(--font-display);\\\\n  font-size: 1.25rem;\\\\n  color: #fff;\\\\n  position: relative;\\\\n}\\\\n\\\\n.showcase-card__preview--eagles {\\\\n  background: linear-gradient(135deg, #1b365d 0%, #2d4a7a 100%);\\\\n}\\\\n.showcase-card__preview--yoga {\\\\n  background: linear-gradient(135deg, #7c3aed 0%, #a78bfa 100%);\\\\n}\\\\n.showcase-card__preview--bookclub {\\\\n  background: linear-gradient(135deg, #065f46 0%, #059669 100%);\\\\n}\\\\n\\\\n.showcase-card__coming {\\\\n  position: absolute;\\\\n  top: 0.75rem;\\\\n  right: 0.75rem;\\\\n  background: rgba(0,0,0,0.5);\\\\n  color: #fff;\\\\n  font-family: var(--font-body);\\\\n  font-size: 0.6875rem;\\\\n  font-weight: 600;\\\\n  padding: 0.25rem 0.625rem;\\\\n  border-radius: 99px;\\\\n  text-transform: uppercase;\\\\n  letter-spacing: 0.05em;\\\\n}\\\\n\\\\n.showcase-card__body {\\\\n  padding: 1.25rem 1.5rem;\\\\n}\\\\n\\\\n.showcase-card__name {\\\\n  font-weight: 700;\\\\n  font-size: 1.0625rem;\\\\n  margin-bottom: 0.25rem;\\\\n}\\\\n\\\\n.showcase-card__niche {\\\\n  font-size: 0.8125rem;\\\\n  color: var(--ink-muted);\\\\n  margin-bottom: 0.75rem;\\\\n}\\\\n\\\\n.showcase-card__link {\\\\n  font-size: 0.875rem;\\\\n  font-weight: 600;\\\\n  color: var(--indigo);\\\\n  display: inline-flex;\\\\n  align-items: center;\\\\n  gap: 0.25rem;\\\\n}\\\\n.showcase-card__link:hover { text-decoration: underline; }\\\\n\\\\n/* --- Pricing --- */\\\\n.pricing-comparison {\\\\n  overflow-x: auto;\\\\n  margin-bottom: 4rem;\\\\n  -webkit-overflow-scrolling: touch;\\\\n}\\\\n\\\\n.pricing-table {\\\\n  width: 100%;\\\\n  border-collapse: collapse;\\\\n  font-size: 0.9375rem;\\\\n  min-width: 32rem;\\\\n}\\\\n\\\\n.pricing-table th {\\\\n  text-align: left;\\\\n  padding: 1rem 1.25rem;\\\\n  font-weight: 600;\\\\n  font-size: 0.8125rem;\\\\n  text-transform: uppercase;\\\\n  letter-spacing: 0.05em;\\\\n  color: var(--ink-muted);\\\\n  border-bottom: 2px solid var(--ink);\\\\n}\\\\n\\\\n.pricing-table td {\\\\n  padding: 1rem 1.25rem;\\\\n  border-bottom: 1px solid rgba(0,0,0,0.06);\\\\n}\\\\n\\\\n.pricing-table tr:last-child td { border-bottom: none; }\\\\n\\\\n.pricing-table__highlight {\\\\n  color: var(--indigo);\\\\n  font-weight: 700;\\\\n}\\\\n\\\\n.pricing-table__muted {\\\\n  color: var(--ink-subtle);\\\\n}\\\\n\\\\n.plans-grid {\\\\n  display: grid;\\\\n  grid-template-columns: repeat(3, 1fr);\\\\n  gap: 1.5rem;\\\\n}\\\\n\\\\n.plan-card {\\\\n  background: #fff;\\\\n  border: 1px solid rgba(0,0,0,0.08);\\\\n  border-radius: 12px;\\\\n  padding: 2rem;\\\\n  display: flex;\\\\n  flex-direction: column;\\\\n}\\\\n\\\\n.plan-card--featured {\\\\n  border-color: var(--indigo);\\\\n  box-shadow: 0 0 0 1px var(--indigo);\\\\n  position: relative;\\\\n}\\\\n\\\\n.plan-card--featured::before {\\\\n  content: 'Most Popular';\\\\n  position: absolute;\\\\n  top: -0.75rem;\\\\n  left: 1.5rem;\\\\n  background: var(--indigo);\\\\n  color: #fff;\\\\n  font-size: 0.6875rem;\\\\n  font-weight: 700;\\\\n  text-transform: uppercase;\\\\n  letter-spacing: 0.05em;\\\\n  padding: 0.25rem 0.75rem;\\\\n  border-radius: 99px;\\\\n}\\\\n\\\\n.plan-card__name {\\\\n  font-family: var(--font-display);\\\\n  font-size: 1.5rem;\\\\n  margin-bottom: 0.25rem;\\\\n}\\\\n\\\\n.plan-card__price {\\\\n  font-size: 2rem;\\\\n  font-weight: 800;\\\\n  color: var(--indigo);\\\\n  margin-bottom: 0.125rem;\\\\n}\\\\n\\\\n.plan-card__price-sub {\\\\n  font-size: 0.8125rem;\\\\n  color: var(--ink-muted);\\\\n  margin-bottom: 1.25rem;\\\\n}\\\\n\\\\n.plan-card__desc {\\\\n  font-size: 0.9375rem;\\\\n  color: var(--ink-muted);\\\\n  font-style: italic;\\\\n  margin-bottom: 1.5rem;\\\\n  flex: 1;\\\\n}\\\\n\\\\n.plan-card__features {\\\\n  list-style: none;\\\\n  margin-bottom: 1.5rem;\\\\n}\\\\n\\\\n.plan-card__features li {\\\\n  font-size: 0.875rem;\\\\n  padding: 0.375rem 0;\\\\n  border-bottom: 1px solid rgba(0,0,0,0.04);\\\\n  display: flex;\\\\n  align-items: center;\\\\n  gap: 0.5rem;\\\\n}\\\\n\\\\n.plan-card__features li::before {\\\\n  content: '\\\\\\\\2713';\\\\n  color: var(--green);\\\\n  font-weight: 700;\\\\n  font-size: 0.75rem;\\\\n}\\\\n\\\\n/* --- Niche cards --- */\\\\n.niche-grid {\\\\n  display: grid;\\\\n  grid-template-columns: repeat(4, 1fr);\\\\n  gap: 1rem;\\\\n}\\\\n\\\\n.niche-card {\\\\n  background: #fff;\\\\n  border: 1px solid rgba(0,0,0,0.06);\\\\n  border-radius: 12px;\\\\n  padding: 1.5rem;\\\\n  text-align: center;\\\\n  transition: transform 0.2s var(--ease), box-shadow 0.2s;\\\\n}\\\\n\\\\n.niche-card:hover {\\\\n  transform: translateY(-2px);\\\\n  box-shadow: 0 8px 24px rgba(0,0,0,0.06);\\\\n}\\\\n\\\\n.niche-card--disabled {\\\\n  opacity: 0.5;\\\\n  pointer-events: none;\\\\n}\\\\n\\\\n.niche-card__icon {\\\\n  font-size: 2rem;\\\\n  margin-bottom: 0.5rem;\\\\n}\\\\n\\\\n.niche-card__name {\\\\n  font-weight: 700;\\\\n  font-size: 0.9375rem;\\\\n  margin-bottom: 0.25rem;\\\\n}\\\\n\\\\n.niche-card__sub {\\\\n  font-size: 0.75rem;\\\\n  color: var(--ink-subtle);\\\\n}\\\\n\\\\n/* --- Final CTA --- */\\\\n.final-cta {\\\\n  text-align: center;\\\\n}\\\\n\\\\n.final-cta .t-display--lg {\\\\n  color: #fff;\\\\n  margin-bottom: 0.75rem;\\\\n}\\\\n\\\\n.final-cta .t-body--lg {\\\\n  color: rgba(255,255,255,0.6);\\\\n  margin: 0 auto 2.5rem;\\\\n}\\\\n\\\\n.final-cta__buttons {\\\\n  display: flex;\\\\n  justify-content: center;\\\\n  gap: 0.75rem;\\\\n  flex-wrap: wrap;\\\\n}\\\\n\\\\n/* --- Footer --- */\\\\n.footer {\\\\n  padding: 2.5rem 0;\\\\n  border-top: 1px solid rgba(0,0,0,0.06);\\\\n  text-align: center;\\\\n  font-size: 0.8125rem;\\\\n  color: var(--ink-muted);\\\\n}\\\\n\\\\n.footer a {\\\\n  color: var(--indigo);\\\\n  font-weight: 500;\\\\n}\\\\n.footer a:hover { text-decoration: underline; }\\\\n\\\\n/* --- Section header utility --- */\\\\n.section-header {\\\\n  margin-bottom: 3rem;\\\\n}\\\\n\\\\n.section-header--center {\\\\n  text-align: center;\\\\n  max-width: 40rem;\\\\n  margin-left: auto;\\\\n  margin-right: auto;\\\\n}\\\\n\\\\n.section-header .t-overline { margin-bottom: 0.75rem; }\\\\n.section-header .t-display--lg { margin-bottom: 1rem; }\\\\n\\\\n/* --- Spacing utils --- */\\\\n.mb-1 { margin-bottom: 0.5rem; }\\\\n.mb-2 { margin-bottom: 1rem; }\\\\n.mb-3 { margin-bottom: 1.5rem; }\\\\n.mb-4 { margin-bottom: 2rem; }\\\\n.mb-6 { margin-bottom: 3rem; }\\\\n.mt-2 { margin-top: 1rem; }\\\\n.mt-4 { margin-top: 2rem; }\\\\n\\\\n/* ============================================\\\\n   Responsive\\\\n   ============================================ */\\\\n\\\\n@media (max-width: 1024px) {\\\\n  .feature-grid { grid-template-columns: repeat(2, 1fr); }\\\\n  .ai-grid { grid-template-columns: repeat(2, 1fr); }\\\\n  .niche-grid { grid-template-columns: repeat(2, 1fr); }\\\\n  .plans-grid { grid-template-columns: 1fr; max-width: 28rem; }\\\\n}\\\\n\\\\n@media (max-width: 768px) {\\\\n  .section { padding: 4rem 0; }\\\\n  .container { padding: 0 1.25rem; }\\\\n\\\\n  /* Nav mobile */\\\\n  .nav__links { display: none; }\\\\n  .nav__links.open {\\\\n    display: flex;\\\\n    flex-direction: column;\\\\n    position: absolute;\\\\n    top: 100%;\\\\n    left: 0;\\\\n    right: 0;\\\\n    background: var(--cream);\\\\n    border-bottom: 1px solid rgba(0,0,0,0.06);\\\\n    padding: 1rem 1.25rem;\\\\n    gap: 0.125rem;\\\\n  }\\\\n  .nav__links.open .nav__cta { margin-left: 0; margin-top: 0.5rem; }\\\\n  .nav__toggle { display: block; }\\\\n\\\\n  /* Hero */\\\\n  .hero { padding: 5rem 0 4rem; }\\\\n  .hero__aside { display: none; }\\\\n  .hero__ctas { flex-direction: column; }\\\\n  .hero__ctas .btn { justify-content: center; }\\\\n\\\\n  /* Grids */\\\\n  .problem-grid { grid-template-columns: 1fr; }\\\\n  .feature-grid { grid-template-columns: 1fr; }\\\\n  .ai-grid { grid-template-columns: 1fr; }\\\\n  .showcase-grid { grid-template-columns: 1fr; }\\\\n  .plans-grid { grid-template-columns: 1fr; }\\\\n  .niche-grid { grid-template-columns: repeat(2, 1fr); }\\\\n\\\\n  .pricing-table { font-size: 0.8125rem; }\\\\n  .pricing-table th, .pricing-table td { padding: 0.75rem; }\\\\n}\\\\n\\\\n@media (max-width: 480px) {\\\\n  .niche-grid { grid-template-columns: 1fr; }\\\\n}\\\\n\\\"\\n    },\\n    {\\n      \\\"file\\\": \\\"hoa.html\\\",\\n      \\\"data\\\": \\\"<!DOCTYPE html>\\\\n<html lang=\\\\\\\"en\\\\\\\">\\\\n<head>\\\\n  <meta charset=\\\\\\\"UTF-8\\\\\\\">\\\\n  <meta name=\\\\\\\"viewport\\\\\\\" content=\\\\\\\"width=device-width, initial-scale=1.0\\\\\\\">\\\\n  <title>Wild Lychee for HOAs — AI-Powered Community Portal</title>\\\\n  <meta name=\\\\\\\"description\\\\\\\" content=\\\\\\\"A modern HOA portal with maintenance tracking, document archives, voting, and resident communication. $5-20/mo flat. No per-unit fees.\\\\\\\">\\\\n  <link rel=\\\\\\\"stylesheet\\\\\\\" href=\\\\\\\"/css/marketing.css\\\\\\\">\\\\n</head>\\\\n<body>\\\\n\\\\n  <!-- ======== NAV ======== -->\\\\n  <nav class=\\\\\\\"nav\\\\\\\">\\\\n    <div class=\\\\\\\"container nav__inner\\\\\\\">\\\\n      <a href=\\\\\\\"/\\\\\\\" class=\\\\\\\"nav__brand\\\\\\\">\\\\n        <span class=\\\\\\\"nav__brand-icon\\\\\\\">&#127819;</span>\\\\n        Wild Lychee\\\\n      </a>\\\\n      <button class=\\\\\\\"nav__toggle\\\\\\\" id=\\\\\\\"nav-toggle\\\\\\\" aria-label=\\\\\\\"Menu\\\\\\\">&#9776;</button>\\\\n      <div class=\\\\\\\"nav__links\\\\\\\" id=\\\\\\\"nav-links\\\\\\\">\\\\n        <a href=\\\\\\\"/\\\\\\\" class=\\\\\\\"nav__link\\\\\\\">&larr; Back to Wild Lychee</a>\\\\n        <a href=\\\\\\\"#features\\\\\\\" class=\\\\\\\"nav__link\\\\\\\">Features</a>\\\\n        <a href=\\\\\\\"#pricing\\\\\\\" class=\\\\\\\"nav__link\\\\\\\">Pricing</a>\\\\n        <a href=\\\\\\\"https://github.com/kychee-com/wildlychee\\\\\\\" class=\\\\\\\"nav__link\\\\\\\" target=\\\\\\\"_blank\\\\\\\">GitHub</a>\\\\n        <a href=\\\\\\\"#demo-placeholder\\\\\\\" class=\\\\\\\"btn btn--primary btn--lg nav__cta\\\\\\\">Try the Demo</a>\\\\n      </div>\\\\n    </div>\\\\n  </nav>\\\\n\\\\n  <!-- ======== HERO ======== -->\\\\n  <section class=\\\\\\\"hero section section--cream section--dotted\\\\\\\">\\\\n    <div class=\\\\\\\"container hero__content\\\\\\\">\\\\n      <p class=\\\\\\\"t-overline mb-2\\\\\\\">Wild Lychee for HOAs</p>\\\\n      <h1 class=\\\\\\\"t-display t-display--xl hero__headline\\\\\\\">\\\\n        Your HOA deserves better than email chains and PDF attachments.\\\\n      </h1>\\\\n      <p class=\\\\\\\"t-body--lg hero__sub\\\\\\\">\\\\n        Maintenance requests, document archives, voting, announcements, and resident communication &mdash; all in one portal your board actually controls. No per-unit fees. No lock-in. From <strong style=\\\\\\\"color:var(--ink)\\\\\\\">$5/mo</strong>.\\\\n      </p>\\\\n      <div class=\\\\\\\"hero__ctas\\\\\\\">\\\\n        <a href=\\\\\\\"#demo-placeholder\\\\\\\" class=\\\\\\\"btn btn--primary btn--lg\\\\\\\">Build Your HOA Portal &rarr;</a>\\\\n        <a href=\\\\\\\"https://github.com/kychee-com/wildlychee\\\\\\\" class=\\\\\\\"btn btn--outline btn--lg\\\\\\\" target=\\\\\\\"_blank\\\\\\\">Fork on GitHub</a>\\\\n      </div>\\\\n    </div>\\\\n    <div class=\\\\\\\"hero__aside\\\\\\\" aria-hidden=\\\\\\\"true\\\\\\\"></div>\\\\n  </section>\\\\n\\\\n  <!-- ======== FEATURES ======== -->\\\\n  <section class=\\\\\\\"section section--white\\\\\\\" id=\\\\\\\"features\\\\\\\">\\\\n    <div class=\\\\\\\"container\\\\\\\">\\\\n      <div class=\\\\\\\"section-header\\\\\\\">\\\\n        <p class=\\\\\\\"t-overline\\\\\\\">Built for HOAs</p>\\\\n        <h2 class=\\\\\\\"t-display t-display--lg\\\\\\\">Everything your community association needs.</h2>\\\\n        <p class=\\\\\\\"t-body--lg mt-2\\\\\\\">Six HOA-specific features, ready out of the box. Toggle them on with a config flag.</p>\\\\n      </div>\\\\n\\\\n      <div class=\\\\\\\"feature-grid\\\\\\\">\\\\n        <div class=\\\\\\\"feature-card\\\\\\\">\\\\n          <div class=\\\\\\\"feature-card__icon\\\\\\\">&#128295;</div>\\\\n          <div class=\\\\\\\"feature-card__name\\\\\\\">Maintenance Requests</div>\\\\n          <div class=\\\\\\\"feature-card__desc\\\\\\\">Residents submit issues with photos and descriptions. Board tracks status from open to resolved.</div>\\\\n        </div>\\\\n        <div class=\\\\\\\"feature-card\\\\\\\">\\\\n          <div class=\\\\\\\"feature-card__icon\\\\\\\">&#128196;</div>\\\\n          <div class=\\\\\\\"feature-card__name\\\\\\\">Document Archive</div>\\\\n          <div class=\\\\\\\"feature-card__desc\\\\\\\">CC&amp;Rs, meeting minutes, financial reports, and bylaws &mdash; organized, searchable, and always accessible.</div>\\\\n        </div>\\\\n        <div class=\\\\\\\"feature-card\\\\\\\">\\\\n          <div class=\\\\\\\"feature-card__icon\\\\\\\">&#9989;</div>\\\\n          <div class=\\\\\\\"feature-card__name\\\\\\\">Voting &amp; Polls</div>\\\\n          <div class=\\\\\\\"feature-card__desc\\\\\\\">Run board elections, budget approvals, and community polls with transparent results and audit trails.</div>\\\\n        </div>\\\\n        <div class=\\\\\\\"feature-card\\\\\\\">\\\\n          <div class=\\\\\\\"feature-card__icon\\\\\\\">&#128100;</div>\\\\n          <div class=\\\\\\\"feature-card__name\\\\\\\">Resident &amp; Board Roles</div>\\\\n          <div class=\\\\\\\"feature-card__desc\\\\\\\">Separate permissions for residents, board members, and property managers. Everyone sees what they need.</div>\\\\n        </div>\\\\n        <div class=\\\\\\\"feature-card\\\\\\\">\\\\n          <div class=\\\\\\\"feature-card__icon\\\\\\\">&#128247;</div>\\\\n          <div class=\\\\\\\"feature-card__name\\\\\\\">Issue Submission</div>\\\\n          <div class=\\\\\\\"feature-card__desc\\\\\\\">Report problems with photo uploads, location details, and priority levels. Track resolution in real time.</div>\\\\n        </div>\\\\n        <div class=\\\\\\\"feature-card\\\\\\\">\\\\n          <div class=\\\\\\\"feature-card__icon\\\\\\\">&#128226;</div>\\\\n          <div class=\\\\\\\"feature-card__name\\\\\\\">Announcement Wall</div>\\\\n          <div class=\\\\\\\"feature-card__desc\\\\\\\">Board posts announcements with reactions and comments. Pin important notices. Replace those paper flyers.</div>\\\\n        </div>\\\\n      </div>\\\\n    </div>\\\\n  </section>\\\\n\\\\n  <!-- ======== PRICING ======== -->\\\\n  <section class=\\\\\\\"section section--cream section--dotted\\\\\\\" id=\\\\\\\"pricing\\\\\\\">\\\\n    <div class=\\\\\\\"container\\\\\\\">\\\\n      <div class=\\\\\\\"section-header section-header--center\\\\\\\">\\\\n        <p class=\\\\\\\"t-overline\\\\\\\">Pricing</p>\\\\n        <h2 class=\\\\\\\"t-display t-display--lg\\\\\\\">Flat pricing. No per-unit fees. Ever.</h2>\\\\n      </div>\\\\n\\\\n      <div class=\\\\\\\"plans-grid\\\\\\\">\\\\n        <div class=\\\\\\\"plan-card\\\\\\\">\\\\n          <div class=\\\\\\\"plan-card__name\\\\\\\">DIY Template</div>\\\\n          <div class=\\\\\\\"plan-card__price\\\\\\\">Free</div>\\\\n          <div class=\\\\\\\"plan-card__price-sub\\\\\\\">+ $5&ndash;20/mo Run402 hosting</div>\\\\n          <div class=\\\\\\\"plan-card__desc\\\\\\\">\\\\\\\"For developers and AI agents.\\\\\\\"</div>\\\\n          <ul class=\\\\\\\"plan-card__features\\\\\\\">\\\\n            <li>Full source code (open source)</li>\\\\n            <li>All features included</li>\\\\n            <li>Self-deploy to Run402</li>\\\\n            <li>Community support</li>\\\\n          </ul>\\\\n          <a href=\\\\\\\"https://github.com/kychee-com/wildlychee\\\\\\\" class=\\\\\\\"btn btn--outline\\\\\\\" target=\\\\\\\"_blank\\\\\\\">Fork on GitHub</a>\\\\n        </div>\\\\n\\\\n        <div class=\\\\\\\"plan-card plan-card--featured\\\\\\\">\\\\n          <div class=\\\\\\\"plan-card__name\\\\\\\">Studio Build</div>\\\\n          <div class=\\\\\\\"plan-card__price\\\\\\\">$29</div>\\\\n          <div class=\\\\\\\"plan-card__price-sub\\\\\\\">one-time + $5&ndash;20/mo hosting</div>\\\\n          <div class=\\\\\\\"plan-card__desc\\\\\\\">\\\\\\\"Tell us about your HOA. Live in 5 minutes.\\\\\\\"</div>\\\\n          <ul class=\\\\\\\"plan-card__features\\\\\\\">\\\\n            <li>AI investigates your existing site</li>\\\\n            <li>Guided interview &rarr; custom portal</li>\\\\n            <li>Brand colors, logo, content migrated</li>\\\\n            <li>Multi-language translation</li>\\\\n            <li>Chrome-verified deployment</li>\\\\n          </ul>\\\\n          <a href=\\\\\\\"#demo-placeholder\\\\\\\" class=\\\\\\\"btn btn--primary\\\\\\\">Build My Portal &rarr;</a>\\\\n        </div>\\\\n\\\\n        <div class=\\\\\\\"plan-card\\\\\\\">\\\\n          <div class=\\\\\\\"plan-card__name\\\\\\\">Lychee Pro</div>\\\\n          <div class=\\\\\\\"plan-card__price\\\\\\\">$9&ndash;29/mo</div>\\\\n          <div class=\\\\\\\"plan-card__price-sub\\\\\\\">ongoing, cancel anytime</div>\\\\n          <div class=\\\\\\\"plan-card__desc\\\\\\\">\\\\\\\"Your portal evolves with you.\\\\\\\"</div>\\\\n          <ul class=\\\\\\\"plan-card__features\\\\\\\">\\\\n            <li>Ongoing AI customization agent</li>\\\\n            <li>Feature requests via chat</li>\\\\n            <li>Priority support</li>\\\\n            <li>Advanced analytics</li>\\\\n          </ul>\\\\n          <a href=\\\\\\\"#demo-placeholder\\\\\\\" class=\\\\\\\"btn btn--outline\\\\\\\">Learn More</a>\\\\n        </div>\\\\n      </div>\\\\n    </div>\\\\n  </section>\\\\n\\\\n  <!-- ======== FINAL CTA ======== -->\\\\n  <section class=\\\\\\\"section section--indigo final-cta\\\\\\\">\\\\n    <div class=\\\\\\\"container\\\\\\\">\\\\n      <h2 class=\\\\\\\"t-display t-display--lg\\\\\\\">Ditch the email chains. Give your HOA a real portal.</h2>\\\\n      <p class=\\\\\\\"t-body--lg\\\\\\\">Open source. Flat pricing. AI-powered. Yours forever.</p>\\\\n      <div class=\\\\\\\"final-cta__buttons\\\\\\\">\\\\n        <a href=\\\\\\\"#demo-placeholder\\\\\\\" class=\\\\\\\"btn btn--white btn--lg\\\\\\\">Build Your HOA Portal &rarr;</a>\\\\n        <a href=\\\\\\\"https://github.com/kychee-com/wildlychee\\\\\\\" class=\\\\\\\"btn btn--outline btn--lg\\\\\\\" style=\\\\\\\"border-color:#fff;color:#fff\\\\\\\" target=\\\\\\\"_blank\\\\\\\">Fork on GitHub</a>\\\\n      </div>\\\\n    </div>\\\\n  </section>\\\\n\\\\n  <!-- ======== FOOTER ======== -->\\\\n  <footer class=\\\\\\\"footer\\\\\\\">\\\\n    <div class=\\\\\\\"container\\\\\\\">\\\\n      <p>\\\\n        <strong>Wild Lychee</strong> is open source. Built on <a href=\\\\\\\"https://run402.com\\\\\\\" target=\\\\\\\"_blank\\\\\\\">Run402</a>.\\\\n        &ensp;&middot;&ensp;\\\\n        <a href=\\\\\\\"https://github.com/kychee-com/wildlychee\\\\\\\" target=\\\\\\\"_blank\\\\\\\">GitHub</a>\\\\n        &ensp;&middot;&ensp;\\\\n        <a href=\\\\\\\"https://eagles.run402.com\\\\\\\" target=\\\\\\\"_blank\\\\\\\">Eagles Demo</a>\\\\n      </p>\\\\n    </div>\\\\n  </footer>\\\\n\\\\n  <!-- Mobile nav toggle -->\\\\n  <script>\\\\n    document.getElementById('nav-toggle')?.addEventListener('click', () => {\\\\n      document.getElementById('nav-links')?.classList.toggle('open');\\\\n    });\\\\n  </script>\\\\n\\\\n</body>\\\\n</html>\\\\n\\\"\\n    },\\n    {\\n      \\\"file\\\": \\\"index.html\\\",\\n      \\\"data\\\": \\\"<!DOCTYPE html>\\\\n<html lang=\\\\\\\"en\\\\\\\">\\\\n<head>\\\\n  <meta charset=\\\\\\\"UTF-8\\\\\\\">\\\\n  <meta name=\\\\\\\"viewport\\\\\\\" content=\\\\\\\"width=device-width, initial-scale=1.0\\\\\\\">\\\\n  <title>Wild Lychee — AI-Powered Community Portals</title>\\\\n  <meta name=\\\\\\\"description\\\\\\\" content=\\\\\\\"Open-source membership portal with AI features. Member directory, events, forum, newsletters — $5-20/mo. Own your data.\\\\\\\">\\\\n  <link rel=\\\\\\\"stylesheet\\\\\\\" href=\\\\\\\"/css/marketing.css\\\\\\\">\\\\n</head>\\\\n<body>\\\\n\\\\n  <!-- ======== NAV ======== -->\\\\n  <nav class=\\\\\\\"nav\\\\\\\">\\\\n    <div class=\\\\\\\"container nav__inner\\\\\\\">\\\\n      <a href=\\\\\\\"/\\\\\\\" class=\\\\\\\"nav__brand\\\\\\\">\\\\n        <span class=\\\\\\\"nav__brand-icon\\\\\\\">&#127819;</span>\\\\n        Wild Lychee\\\\n      </a>\\\\n      <button class=\\\\\\\"nav__toggle\\\\\\\" id=\\\\\\\"nav-toggle\\\\\\\" aria-label=\\\\\\\"Menu\\\\\\\">&#9776;</button>\\\\n      <div class=\\\\\\\"nav__links\\\\\\\" id=\\\\\\\"nav-links\\\\\\\">\\\\n        <a href=\\\\\\\"#features\\\\\\\" class=\\\\\\\"nav__link\\\\\\\">Features</a>\\\\n        <a href=\\\\\\\"#showcase\\\\\\\" class=\\\\\\\"nav__link\\\\\\\">Showcase</a>\\\\n        <a href=\\\\\\\"#pricing\\\\\\\" class=\\\\\\\"nav__link\\\\\\\">Pricing</a>\\\\n        <a href=\\\\\\\"#niches\\\\\\\" class=\\\\\\\"nav__link\\\\\\\">Who It's For</a>\\\\n        <a href=\\\\\\\"https://github.com/kychee-com/wildlychee\\\\\\\" class=\\\\\\\"nav__link\\\\\\\" target=\\\\\\\"_blank\\\\\\\">GitHub</a>\\\\n        <a href=\\\\\\\"#demo-placeholder\\\\\\\" class=\\\\\\\"btn btn--primary btn--lg nav__cta\\\\\\\">Try the Demo</a>\\\\n      </div>\\\\n    </div>\\\\n  </nav>\\\\n\\\\n  <!-- ======== HERO ======== -->\\\\n  <section class=\\\\\\\"hero section section--cream section--dotted\\\\\\\">\\\\n    <div class=\\\\\\\"container hero__content\\\\\\\">\\\\n      <p class=\\\\\\\"t-overline mb-2\\\\\\\">Open Source Community Platform</p>\\\\n      <h1 class=\\\\\\\"t-display t-display--xl hero__headline\\\\\\\">\\\\n        Your community deserves better than <em>Wild Apricot</em>.\\\\n      </h1>\\\\n      <p class=\\\\\\\"t-body--lg hero__sub\\\\\\\">\\\\n        Wild Lychee is an AI-powered membership portal you actually own. Member directory, events, forum, announcements, newsletters &mdash; all for <strong style=\\\\\\\"color:var(--ink)\\\\\\\">$5&ndash;20/mo</strong> on your own infrastructure. No per-member fees. No lock-in. No surprise price hikes.\\\\n      </p>\\\\n      <div class=\\\\\\\"hero__ctas\\\\\\\">\\\\n        <a href=\\\\\\\"#demo-placeholder\\\\\\\" class=\\\\\\\"btn btn--primary btn--lg\\\\\\\">Try the Demo &rarr;</a>\\\\n        <a href=\\\\\\\"#showcase\\\\\\\" class=\\\\\\\"btn btn--outline btn--lg\\\\\\\">See It Live</a>\\\\n        <a href=\\\\\\\"https://github.com/kychee-com/wildlychee\\\\\\\" class=\\\\\\\"btn btn--ghost btn--lg\\\\\\\" target=\\\\\\\"_blank\\\\\\\">Fork on GitHub</a>\\\\n      </div>\\\\n    </div>\\\\n    <div class=\\\\\\\"hero__aside\\\\\\\" aria-hidden=\\\\\\\"true\\\\\\\"></div>\\\\n  </section>\\\\n\\\\n  <!-- ======== THE PROBLEM ======== -->\\\\n  <section class=\\\\\\\"section section--white\\\\\\\">\\\\n    <div class=\\\\\\\"container\\\\\\\">\\\\n      <div class=\\\\\\\"section-header section-header--center\\\\\\\">\\\\n        <p class=\\\\\\\"t-overline\\\\\\\">The Problem</p>\\\\n        <h2 class=\\\\\\\"t-display t-display--lg\\\\\\\">Community software is a racket.</h2>\\\\n      </div>\\\\n\\\\n      <div class=\\\\\\\"problem-grid\\\\\\\">\\\\n        <div class=\\\\\\\"problem-card\\\\\\\">\\\\n          <div class=\\\\\\\"problem-card__name\\\\\\\">Wild Apricot</div>\\\\n          <div class=\\\\\\\"problem-card__price\\\\\\\">$530/mo</div>\\\\n          <div class=\\\\\\\"problem-card__desc\\\\\\\">At 2,000 members. For a glorified spreadsheet with a 2008 UI.</div>\\\\n        </div>\\\\n        <div class=\\\\\\\"problem-card\\\\\\\">\\\\n          <div class=\\\\\\\"problem-card__name\\\\\\\">Circle</div>\\\\n          <div class=\\\\\\\"problem-card__price\\\\\\\">$89/mo + fees</div>\\\\n          <div class=\\\\\\\"problem-card__desc\\\\\\\">Per-seat pricing. And they just raised prices. Again.</div>\\\\n        </div>\\\\n        <div class=\\\\\\\"problem-card\\\\\\\">\\\\n          <div class=\\\\\\\"problem-card__name\\\\\\\">Bettermode</div>\\\\n          <div class=\\\\\\\"problem-card__price\\\\\\\">Price hikes yearly</div>\\\\n          <div class=\\\\\\\"problem-card__desc\\\\\\\">Your data locked behind their API. Good luck migrating.</div>\\\\n        </div>\\\\n      </div>\\\\n\\\\n      <div class=\\\\\\\"problem-transition\\\\\\\">\\\\n        <p class=\\\\\\\"problem-transition__what-if\\\\\\\">What if you could just&hellip; own it?</p>\\\\n        <p class=\\\\\\\"t-body\\\\\\\">An open-source portal that runs on your infrastructure, costs a flat $5&ndash;20/mo regardless of member count, and lets an AI agent customize it for you. That's Wild Lychee.</p>\\\\n      </div>\\\\n    </div>\\\\n  </section>\\\\n\\\\n  <!-- ======== FEATURES ======== -->\\\\n  <section class=\\\\\\\"section section--cream section--dotted\\\\\\\" id=\\\\\\\"features\\\\\\\">\\\\n    <div class=\\\\\\\"container\\\\\\\">\\\\n      <div class=\\\\\\\"section-header\\\\\\\">\\\\n        <p class=\\\\\\\"t-overline\\\\\\\">Everything You Need</p>\\\\n        <h2 class=\\\\\\\"t-display t-display--lg\\\\\\\">One template. Every feature.</h2>\\\\n        <p class=\\\\\\\"t-body--lg mt-2\\\\\\\">All features ship. Toggle them on with a config flag. No plugins, no marketplace, no upsells.</p>\\\\n      </div>\\\\n\\\\n      <div class=\\\\\\\"feature-grid\\\\\\\">\\\\n        <div class=\\\\\\\"feature-card\\\\\\\">\\\\n          <div class=\\\\\\\"feature-card__icon\\\\\\\">&#128101;</div>\\\\n          <div class=\\\\\\\"feature-card__name\\\\\\\">Member Directory</div>\\\\n          <div class=\\\\\\\"feature-card__desc\\\\\\\">Searchable profiles with custom fields, tiers, and role-based access.</div>\\\\n        </div>\\\\n        <div class=\\\\\\\"feature-card\\\\\\\">\\\\n          <div class=\\\\\\\"feature-card__icon\\\\\\\">&#128197;</div>\\\\n          <div class=\\\\\\\"feature-card__name\\\\\\\">Events &amp; RSVP</div>\\\\n          <div class=\\\\\\\"feature-card__desc\\\\\\\">Calendar with capacity tracking, reminders, and attendee management.</div>\\\\n        </div>\\\\n        <div class=\\\\\\\"feature-card\\\\\\\">\\\\n          <div class=\\\\\\\"feature-card__icon\\\\\\\">&#128226;</div>\\\\n          <div class=\\\\\\\"feature-card__name\\\\\\\">Announcements</div>\\\\n          <div class=\\\\\\\"feature-card__desc\\\\\\\">Rich text posts with emoji reactions. Pin the important ones.</div>\\\\n        </div>\\\\n        <div class=\\\\\\\"feature-card\\\\\\\">\\\\n          <div class=\\\\\\\"feature-card__icon\\\\\\\">&#128218;</div>\\\\n          <div class=\\\\\\\"feature-card__name\\\\\\\">Resource Library</div>\\\\n          <div class=\\\\\\\"feature-card__desc\\\\\\\">Files, links, and documents with member-only access control.</div>\\\\n        </div>\\\\n        <div class=\\\\\\\"feature-card\\\\\\\">\\\\n          <div class=\\\\\\\"feature-card__icon\\\\\\\">&#128172;</div>\\\\n          <div class=\\\\\\\"feature-card__name\\\\\\\">Forum</div>\\\\n          <div class=\\\\\\\"feature-card__desc\\\\\\\">Categories, topics, threaded replies, and moderation tools.</div>\\\\n        </div>\\\\n        <div class=\\\\\\\"feature-card\\\\\\\">\\\\n          <div class=\\\\\\\"feature-card__icon\\\\\\\">&#127963;&#65039;</div>\\\\n          <div class=\\\\\\\"feature-card__name\\\\\\\">Committees</div>\\\\n          <div class=\\\\\\\"feature-card__desc\\\\\\\">Working groups with roles, member assignments, and descriptions.</div>\\\\n        </div>\\\\n        <div class=\\\\\\\"feature-card\\\\\\\">\\\\n          <div class=\\\\\\\"feature-card__icon\\\\\\\">&#9999;&#65039;</div>\\\\n          <div class=\\\\\\\"feature-card__name\\\\\\\">Inline Editing</div>\\\\n          <div class=\\\\\\\"feature-card__desc\\\\\\\">The page IS the admin panel. Click to edit, no separate dashboard.</div>\\\\n        </div>\\\\n        <div class=\\\\\\\"feature-card\\\\\\\">\\\\n          <div class=\\\\\\\"feature-card__icon\\\\\\\">&#9889;</div>\\\\n          <div class=\\\\\\\"feature-card__name\\\\\\\">Config-Driven</div>\\\\n          <div class=\\\\\\\"feature-card__desc\\\\\\\">Restructure your entire site with SQL. No code changes needed.</div>\\\\n        </div>\\\\n      </div>\\\\n    </div>\\\\n  </section>\\\\n\\\\n  <!-- ======== AI FEATURES ======== -->\\\\n  <section class=\\\\\\\"section ai-section\\\\\\\" id=\\\\\\\"ai\\\\\\\">\\\\n    <div class=\\\\\\\"container\\\\\\\">\\\\n      <div class=\\\\\\\"section-header\\\\\\\">\\\\n        <p class=\\\\\\\"t-overline\\\\\\\">AI-Powered</p>\\\\n        <h2 class=\\\\\\\"t-display t-display--lg\\\\\\\">Six AI features. Your API key.</h2>\\\\n        <p class=\\\\\\\"t-body--lg mt-2\\\\\\\">Every AI feature is optional, bring-your-own-key, and runs on your schedule. No vendor lock-in. No surprise bills from us.</p>\\\\n      </div>\\\\n\\\\n      <div class=\\\\\\\"ai-grid\\\\\\\">\\\\n        <div class=\\\\\\\"ai-card\\\\\\\">\\\\n          <div class=\\\\\\\"ai-card__icon\\\\\\\">&#128737;&#65039;</div>\\\\n          <div class=\\\\\\\"ai-card__name\\\\\\\">Content Moderation</div>\\\\n          <div class=\\\\\\\"ai-card__desc\\\\\\\">Auto-flag spam and toxicity. Review queue for admins. Runs every 15 minutes.</div>\\\\n        </div>\\\\n        <div class=\\\\\\\"ai-card\\\\\\\">\\\\n          <div class=\\\\\\\"ai-card__icon\\\\\\\">&#127760;</div>\\\\n          <div class=\\\\\\\"ai-card__name\\\\\\\">Auto-Translation</div>\\\\n          <div class=\\\\\\\"ai-card__desc\\\\\\\">Publish once, serve in any language. Triggered on content publish.</div>\\\\n        </div>\\\\n        <div class=\\\\\\\"ai-card\\\\\\\">\\\\n          <div class=\\\\\\\"ai-card__icon\\\\\\\">&#128240;</div>\\\\n          <div class=\\\\\\\"ai-card__name\\\\\\\">Newsletter Writer</div>\\\\n          <div class=\\\\\\\"ai-card__desc\\\\\\\">AI drafts your weekly update from recent activity. You approve and send.</div>\\\\n        </div>\\\\n        <div class=\\\\\\\"ai-card\\\\\\\">\\\\n          <div class=\\\\\\\"ai-card__icon\\\\\\\">&#127919;</div>\\\\n          <div class=\\\\\\\"ai-card__name\\\\\\\">Smart Onboarding</div>\\\\n          <div class=\\\\\\\"ai-card__desc\\\\\\\">Personalized welcome message for each new member based on their profile.</div>\\\\n        </div>\\\\n        <div class=\\\\\\\"ai-card\\\\\\\">\\\\n          <div class=\\\\\\\"ai-card__icon\\\\\\\">&#128202;</div>\\\\n          <div class=\\\\\\\"ai-card__name\\\\\\\">Member Insights</div>\\\\n          <div class=\\\\\\\"ai-card__desc\\\\\\\">Spot at-risk members before they leave. Daily analysis of engagement patterns.</div>\\\\n        </div>\\\\n        <div class=\\\\\\\"ai-card\\\\\\\">\\\\n          <div class=\\\\\\\"ai-card__icon\\\\\\\">&#128221;</div>\\\\n          <div class=\\\\\\\"ai-card__name\\\\\\\">Event Recaps</div>\\\\n          <div class=\\\\\\\"ai-card__desc\\\\\\\">AI writes the post-event summary from attendance and photos. You approve it.</div>\\\\n        </div>\\\\n      </div>\\\\n\\\\n      <div class=\\\\\\\"ai-byok\\\\\\\">\\\\n        &#128273;&ensp; Bring your own API key. Your AI, your cost, your control.\\\\n      </div>\\\\n    </div>\\\\n  </section>\\\\n\\\\n  <!-- ======== SHOWCASE ======== -->\\\\n  <section class=\\\\\\\"section section--cream section--dotted\\\\\\\" id=\\\\\\\"showcase\\\\\\\">\\\\n    <div class=\\\\\\\"container\\\\\\\">\\\\n      <div class=\\\\\\\"section-header section-header--center\\\\\\\">\\\\n        <p class=\\\\\\\"t-overline\\\\\\\">See It Live</p>\\\\n        <h2 class=\\\\\\\"t-display t-display--lg\\\\\\\">Real communities. Real content.</h2>\\\\n        <p class=\\\\\\\"t-body--lg mt-2\\\\\\\" style=\\\\\\\"margin-left:auto;margin-right:auto;\\\\\\\">Browse these showcase communities to see what a Wild Lychee portal looks and feels like with real (AI-generated) content.</p>\\\\n      </div>\\\\n\\\\n      <div class=\\\\\\\"showcase-grid\\\\\\\">\\\\n        <a href=\\\\\\\"https://eagles.run402.com\\\\\\\" target=\\\\\\\"_blank\\\\\\\" class=\\\\\\\"showcase-card\\\\\\\">\\\\n          <div class=\\\\\\\"showcase-card__preview showcase-card__preview--eagles\\\\\\\">\\\\n            The Eagles\\\\n          </div>\\\\n          <div class=\\\\\\\"showcase-card__body\\\\\\\">\\\\n            <div class=\\\\\\\"showcase-card__name\\\\\\\">The Eagles &mdash; Good Samaritans of Wichita</div>\\\\n            <div class=\\\\\\\"showcase-card__niche\\\\\\\">Charity &amp; Volunteers</div>\\\\n            <span class=\\\\\\\"showcase-card__link\\\\\\\">Browse &rarr;</span>\\\\n          </div>\\\\n        </a>\\\\n        <div class=\\\\\\\"showcase-card\\\\\\\">\\\\n          <div class=\\\\\\\"showcase-card__preview showcase-card__preview--yoga\\\\\\\">\\\\n            <span class=\\\\\\\"showcase-card__coming\\\\\\\">Coming Soon</span>\\\\n            Sunrise Yoga\\\\n          </div>\\\\n          <div class=\\\\\\\"showcase-card__body\\\\\\\">\\\\n            <div class=\\\\\\\"showcase-card__name\\\\\\\">Sunrise Yoga Collective</div>\\\\n            <div class=\\\\\\\"showcase-card__niche\\\\\\\">Wellness &amp; Fitness Studio</div>\\\\n          </div>\\\\n        </div>\\\\n        <div class=\\\\\\\"showcase-card\\\\\\\">\\\\n          <div class=\\\\\\\"showcase-card__preview showcase-card__preview--bookclub\\\\\\\">\\\\n            <span class=\\\\\\\"showcase-card__coming\\\\\\\">Coming Soon</span>\\\\n            Page Turners\\\\n          </div>\\\\n          <div class=\\\\\\\"showcase-card__body\\\\\\\">\\\\n            <div class=\\\\\\\"showcase-card__name\\\\\\\">Page Turners Book Club</div>\\\\n            <div class=\\\\\\\"showcase-card__niche\\\\\\\">Social &amp; Reading Group</div>\\\\n          </div>\\\\n        </div>\\\\n      </div>\\\\n    </div>\\\\n  </section>\\\\n\\\\n  <!-- ======== PRICING ======== -->\\\\n  <section class=\\\\\\\"section section--white\\\\\\\" id=\\\\\\\"pricing\\\\\\\">\\\\n    <div class=\\\\\\\"container\\\\\\\">\\\\n      <div class=\\\\\\\"section-header section-header--center\\\\\\\">\\\\n        <p class=\\\\\\\"t-overline\\\\\\\">Pricing</p>\\\\n        <h2 class=\\\\\\\"t-display t-display--lg\\\\\\\">Flat pricing. No per-member fees. Ever.</h2>\\\\n      </div>\\\\n\\\\n      <!-- Competitor comparison -->\\\\n      <div class=\\\\\\\"pricing-comparison mb-6\\\\\\\">\\\\n        <table class=\\\\\\\"pricing-table\\\\\\\">\\\\n          <thead>\\\\n            <tr>\\\\n              <th>Members</th>\\\\n              <th>Wild Apricot</th>\\\\n              <th>Circle</th>\\\\n              <th>Wild Lychee</th>\\\\n            </tr>\\\\n          </thead>\\\\n          <tbody>\\\\n            <tr>\\\\n              <td>100</td>\\\\n              <td class=\\\\\\\"pricing-table__muted\\\\\\\">$100/mo</td>\\\\n              <td class=\\\\\\\"pricing-table__muted\\\\\\\">$89/mo</td>\\\\n              <td class=\\\\\\\"pricing-table__highlight\\\\\\\">$5/mo</td>\\\\n            </tr>\\\\n            <tr>\\\\n              <td>500</td>\\\\n              <td class=\\\\\\\"pricing-table__muted\\\\\\\">$200/mo</td>\\\\n              <td class=\\\\\\\"pricing-table__muted\\\\\\\">$89/mo</td>\\\\n              <td class=\\\\\\\"pricing-table__highlight\\\\\\\">$5/mo</td>\\\\n            </tr>\\\\n            <tr>\\\\n              <td>2,000</td>\\\\n              <td class=\\\\\\\"pricing-table__muted\\\\\\\">$530/mo</td>\\\\n              <td class=\\\\\\\"pricing-table__muted\\\\\\\">$219/mo</td>\\\\n              <td class=\\\\\\\"pricing-table__highlight\\\\\\\">$10/mo</td>\\\\n            </tr>\\\\n            <tr>\\\\n              <td>5,000</td>\\\\n              <td class=\\\\\\\"pricing-table__muted\\\\\\\">$900/mo</td>\\\\n              <td class=\\\\\\\"pricing-table__muted\\\\\\\">$399/mo</td>\\\\n              <td class=\\\\\\\"pricing-table__highlight\\\\\\\">$20/mo</td>\\\\n            </tr>\\\\n          </tbody>\\\\n        </table>\\\\n      </div>\\\\n\\\\n      <!-- Plans -->\\\\n      <div class=\\\\\\\"plans-grid\\\\\\\">\\\\n        <div class=\\\\\\\"plan-card\\\\\\\">\\\\n          <div class=\\\\\\\"plan-card__name\\\\\\\">DIY Template</div>\\\\n          <div class=\\\\\\\"plan-card__price\\\\\\\">Free</div>\\\\n          <div class=\\\\\\\"plan-card__price-sub\\\\\\\">+ $5&ndash;20/mo Run402 hosting</div>\\\\n          <div class=\\\\\\\"plan-card__desc\\\\\\\">\\\\\\\"For developers and AI agents.\\\\\\\"</div>\\\\n          <ul class=\\\\\\\"plan-card__features\\\\\\\">\\\\n            <li>Full source code (open source)</li>\\\\n            <li>All features included</li>\\\\n            <li>Self-deploy to Run402</li>\\\\n            <li>Community support</li>\\\\n          </ul>\\\\n          <a href=\\\\\\\"https://github.com/kychee-com/wildlychee\\\\\\\" class=\\\\\\\"btn btn--outline\\\\\\\" target=\\\\\\\"_blank\\\\\\\">Fork on GitHub</a>\\\\n        </div>\\\\n\\\\n        <div class=\\\\\\\"plan-card plan-card--featured\\\\\\\">\\\\n          <div class=\\\\\\\"plan-card__name\\\\\\\">Studio Build</div>\\\\n          <div class=\\\\\\\"plan-card__price\\\\\\\">$29</div>\\\\n          <div class=\\\\\\\"plan-card__price-sub\\\\\\\">one-time + $5&ndash;20/mo hosting</div>\\\\n          <div class=\\\\\\\"plan-card__desc\\\\\\\">\\\\\\\"Tell us about your community. Live in 5 minutes.\\\\\\\"</div>\\\\n          <ul class=\\\\\\\"plan-card__features\\\\\\\">\\\\n            <li>AI investigates your existing site</li>\\\\n            <li>Guided interview &rarr; custom portal</li>\\\\n            <li>Brand colors, logo, content migrated</li>\\\\n            <li>Multi-language translation</li>\\\\n            <li>Chrome-verified deployment</li>\\\\n          </ul>\\\\n          <a href=\\\\\\\"#demo-placeholder\\\\\\\" class=\\\\\\\"btn btn--primary\\\\\\\">Build My Portal &rarr;</a>\\\\n        </div>\\\\n\\\\n        <div class=\\\\\\\"plan-card\\\\\\\">\\\\n          <div class=\\\\\\\"plan-card__name\\\\\\\">Lychee Pro</div>\\\\n          <div class=\\\\\\\"plan-card__price\\\\\\\">$9&ndash;29/mo</div>\\\\n          <div class=\\\\\\\"plan-card__price-sub\\\\\\\">ongoing, cancel anytime</div>\\\\n          <div class=\\\\\\\"plan-card__desc\\\\\\\">\\\\\\\"Your portal evolves with you.\\\\\\\"</div>\\\\n          <ul class=\\\\\\\"plan-card__features\\\\\\\">\\\\n            <li>Ongoing AI customization agent</li>\\\\n            <li>Feature requests via chat</li>\\\\n            <li>Priority support</li>\\\\n            <li>Advanced analytics</li>\\\\n          </ul>\\\\n          <a href=\\\\\\\"#demo-placeholder\\\\\\\" class=\\\\\\\"btn btn--outline\\\\\\\">Learn More</a>\\\\n        </div>\\\\n      </div>\\\\n    </div>\\\\n  </section>\\\\n\\\\n  <!-- ======== WHO IT'S FOR ======== -->\\\\n  <section class=\\\\\\\"section section--cream\\\\\\\" id=\\\\\\\"niches\\\\\\\">\\\\n    <div class=\\\\\\\"container\\\\\\\">\\\\n      <div class=\\\\\\\"section-header section-header--center\\\\\\\">\\\\n        <p class=\\\\\\\"t-overline\\\\\\\">Who It's For</p>\\\\n        <h2 class=\\\\\\\"t-display t-display--lg\\\\\\\">Built for communities of every kind.</h2>\\\\n        <p class=\\\\\\\"t-body--lg mt-2\\\\\\\" style=\\\\\\\"margin-left:auto;margin-right:auto;\\\\\\\">Wild Lychee adapts to your community type with niche-specific configurations, seed data, and features.</p>\\\\n      </div>\\\\n\\\\n      <div class=\\\\\\\"niche-grid\\\\\\\">\\\\n        <a href=\\\\\\\"/churches.html\\\\\\\" class=\\\\\\\"niche-card\\\\\\\">\\\\n          <div class=\\\\\\\"niche