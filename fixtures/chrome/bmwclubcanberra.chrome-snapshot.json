      "section_type": "features",
      "config": {
        "columns": 1,
        "items": [
          {
            "icon": "",
            "title": "THE Capital ROUNDEL",
            "desc": "The Capital Roundel magazine is the lifeblood of our Club. The magazine is sent via PDF to all members on a quarterly basis and is one of the benefits of membership. Content varies from issue to issue, but the publication mostly contains information on new releases, initiatives from BMW, reviews of cars, products, historical and topical articles.",
            "cta_text": "The Capital Roundel",
            "cta_href": "/page.html?slug=magazine"
          }
        ]
      },
      "position": 3,
      "visible": true,
      "column_span": "1"
    },
