      "section_type": "custom",
      "config": {
        "html": "<style>\nhtml[data-theme=\"dark\"] { --color-bg:#ffffff; --color-surface:#F7F8FC; --color-text:#15142A; --color-text-muted:#5C6175; --color-border:#DCE0EA; }\nbody, .page { background:#ffffff; color:#15142A; }\n.page .nav { background:#fff; border-bottom:0; padding:.55rem 0 0; box-shadow:0 1px 0 rgba(26,18,77,.12); }\n.nav > .container { flex-wrap:wrap; align-items:flex-start; gap:.55rem 1rem; }\n.nav .section:has(.aage-chrome-style-anchor) { position:absolute; width:0; height:0; overflow:hidden; padding:0; margin:0; }\n.brand-header--wordmark .brand-wordmark { height:4.75rem; max-width:min(42vw,18rem); }\n.nav .block-social-links { order:2; padding:0; opacity:1; margin-left:auto; --social-link-size:1.75rem; --social-link-icon-size:.95rem; --social-link-radius:.15rem; --social-link-bg:#1A124D; --social-link-color:#fff; --social-link-border:transparent; --social-link-hover-color:#fff; }\n.nav .block-social-links__list { justify-content:flex-end; gap:.35rem; }\n.nav .block-social-links__link { box-shadow:0 1px 2px rgba(26,18,77,.12); transition:transform .15s ease, box-shadow .15s ease, filter .15s ease; }\n.nav .block-social-links__link--facebook { background:#3b5998; }\n.nav .block-social-links__link--x { background:#000; }\n.nav .block-social-links__link--linkedin { background:#0A66C2; }\n.nav .block-social-links__link--instagram { background:linear-gradient(135deg,#F58529 0%,#DD2A7B 45%,#8134AF 72%,#515BD4 100%); }\n.nav .block-social-links__link:hover { color:#fff; transform:translateY(-1px); filter:saturate(1.08); box-shadow:0 4px 10px rgba(26,18,77,.18); }\n.nav .section-site-search { order:3; padding:0; opacity:1; margin-left:0; }\n.nav .section-site-search > .container { max-width:none; margin:0; padding:0; }\n.nav .site-search { width:auto; }\n.nav .site-search__form { display:flex; align-items:stretch; gap:0; height:2rem; border:1px solid #1A124D; background:#fff; }\n.nav .site-search__input { min-width:13rem; width:18vw; max-width:18rem; height:auto; border:0; border-radius:0; padding:0 .65rem; background:#fff; color:#15142A; font:inherit; }\n.nav .site-search__input:focus { outline:2px solid #F7941D; outline-offset:1px; }\n.nav .site-search__submit { min-height:0; border:0; border-radius:0; background:#F7941D; color:#1A124D; padding:0 .8rem; font-weight:700; cursor:pointer; }\n.nav .site-search__suggestions { text-align:left; min-width:100%; }\n.nav-links { order:4; flex-basis:100%; margin-left:0; display:flex; flex-wrap:wrap; align-items:stretch; gap:0; background:#1A124D; padding:0 .5rem; }\n.nav-link { border-radius:0; color:#fff; padding:.62rem .72rem; font-size:.8rem; font-weight:700; }\n.nav-link:hover, .nav-link.active { background:#F7941D; color:#1A124D; }\n.nav-item-wrap { display:flex; align-items:stretch; }\n.nav-chevron-toggle { color:#fff; border-radius:0; }\n.nav-item-wrap:hover .nav-chevron-toggle { background:#F7941D; color:#1A124D; }\n.nav-user { align-self:center; }\n.section-hero[style*=\"aage-inner-page-banner\"] { min-height:18rem; padding:5rem 0; background-color:#1A124D; background-repeat:repeat-y; background-size:auto 100%; background-position:right center; text-align:left; }\n.section-hero[style*=\"aage-inner-page-banner\"]::before { background:linear-gradient(90deg, #1A124D 0%, rgba(26,18,77,.94) 48%, rgba(26,18,77,.36) 100%); }\n.section-hero[style*=\"aage-inner-page-banner\"] .container { text-align:left; }\n.section-hero[style*=\"aage-inner-page-banner\"] h1 { max-width:49rem; margin:0; font-size:clamp(2rem, 5vw, 3.85rem); line-height:1.08; }\n.aage-home-rows { display:grid; gap:2.25rem; max-width:76rem; margin:3rem auto 4rem; padding:0 1.5rem; }\n.aage-home-row { display:grid; grid-template-columns:1fr 2fr; align-items:stretch; gap:2.25rem; background:#fff; }\n.aage-home-row:nth-child(even) { grid-template-columns:2fr 1fr; }\n.aage-home-row:nth-child(even) .aage-home-media { order:-1; }\n.aage-home-copy { display:flex; flex-direction:column; justify-content:center; border-radius:1.5rem; padding:3rem clamp(1.5rem, 3vw, 2.5rem); color:#fff; }\n.aage-home-row:nth-child(1) .aage-home-copy { background:#F7941D; color:#1A124D; }\n.aage-home-row:nth-child(2) .aage-home-copy, .aage-home-row:nth-child(4) .aage-home-copy { background:#1A124D; color:#fff; }\n.aage-home-row:nth-child(3) .aage-home-copy { background:#1C75BC; color:#fff; }\n.aage-home-copy h2 { color:inherit; font-size:clamp(1.6rem, 3vw, 2.4rem); margin-bottom:.85rem; }\n.aage-home-copy p { color:inherit; font-size:1.05rem; margin-bottom:1.35rem; font-weight:600; }\n.aage-home-copy a { align-self:flex-start; display:inline-flex; border-radius:999px; background:#F7941D; color:#1A124D; padding:.7rem 1.4rem; font-weight:700; text-decoration:none; }\n.aage-home-row:nth-child(1) .aage-home-copy a { background:#1A124D; color:#fff; }\n.aage-home-media img { width:100%; height:100%; min-height:17rem; display:block; border-radius:1.5rem; aspect-ratio:850 / 350; object-fit:cover; }\n.footer { background:#1A124D; color:#fff; border-top:0; text-align:left; padding:2.25rem 0 1.25rem; }\n.footer a { color:#fff; text-decoration:none; }\n.footer a:hover { color:#F7941D; }\n.footer .section { padding:0; opacity:1; }\n.footer .section > .container { max-width:none; padding:0; margin:0; }\n.aage-footer-grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:2.25rem; }\n.aage-footer h3 { color:#F7941D; font-size:1.05rem; margin-bottom:.75rem; }\n.aage-footer p, .aage-footer li { font-size:.95rem; line-height:1.7; color:#fff; }\n.aage-footer ul { list-style:none; display:grid; gap:.25rem; }\n.aage-footer-copy { text-align:right; margin-top:1.5rem; font-size:.9rem; }\n@media (max-width: 900px) {\n  .nav > .container { align-items:center; }\n  .brand-header--wordmark .brand-wordmark { height:3.6rem; max-width:15rem; }\n  .nav .section-site-search { width:100%; margin-left:0; }\n  .nav .site-search { width:100%; }\n  .nav .site-search__form { width:100%; }\n  .nav .site-search__input { width:100%; max-width:none; min-width:0; }\n  .aage-home-rows { margin:2rem auto; gap:1.5rem; }\n  .aage-home-row, .aage-home-row:nth-child(even) { grid-template-columns:1fr; }\n  .aage-home-row:nth-child(even) .aage-home-media { order:0; }\n  .aage-footer-grid { grid-template-columns:1fr; }\n  .aage-footer-copy { text-align:left; }\n}\n</style>\n<span class=\"aage-chrome-style-anchor\" hidden></span>"
